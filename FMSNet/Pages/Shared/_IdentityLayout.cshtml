<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FMSNet</title>
    <link rel="stylesheet" href="~/css/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/brutalist.css" />
</head>
<body style="background-color: var(--bg-primary); display: flex; align-items: center; justify-content: center; min-height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-6">
                 <h1 class="text-center mb-4" style="font-weight: 900; letter-spacing: -2px; font-size: 3rem;">FMSNet</h1>
                 @RenderBody()
            </div>
        </div>
    </div>
    <script src="~/Identity/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/Identity/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/Identity/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>