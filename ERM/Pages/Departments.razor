@page "/departments"
@using ERM.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject ERM.Services.ExportService ExportService
@inject IJSRuntime JSRuntime

<PageTitle>Department Management</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Department Management</h1>
    <div>
        <RadzenButton Icon="add_circle_outline" Text="Add Department" Click="@AddDepartment" ButtonStyle="ButtonStyle.Primary" />
        <RadzenButton Icon="file_download" Text="Export Excel" Click="@ExportExcel" ButtonStyle="ButtonStyle.Success" Class="ml-2" />
        <RadzenButton Icon="file_download" Text="Export CSV" Click="@ExportCsv" ButtonStyle="ButtonStyle.Info" Class="ml-2" />
    </div>
</div>

<RadzenDataGrid @ref="grid" Data="@departments" TItem="Department" AllowFiltering="true" AllowSorting="true" AllowPaging="true" PageSize="10" ColumnWidth="150px">
    <Columns>
        <RadzenDataGridColumn TItem="Department" Property="Name" Title="Department Name" />
        <RadzenDataGridColumn TItem="Department" Property="Description" Title="Description" />
        <RadzenDataGridColumn TItem="Department" Title="Actions" Sortable="false" Filterable="false" Width="120px">
            <Template Context="data">
                <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@(() => EditDepartment(data))" @onclick:stopPropagation="true" />
                <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(() => DeleteDepartment(data))" @onclick:stopPropagation="true" Class="ml-2" />
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

@code {
    RadzenDataGrid<Department> grid;
    IEnumerable<Department> departments;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {
        departments = await DbContext.Departments.ToListAsync();
    }

    async Task AddDepartment()
    {
        var result = await DialogService.OpenAsync<DepartmentDialog>("Add Department", new Dictionary<string, object> { { "Department", new Department() } });
        if (result != null)
        {
            DbContext.Departments.Add(result);
            await DbContext.SaveChangesAsync();
            await LoadData();
            NotificationService.Notify(NotificationSeverity.Success, "Added", "Department added successfully");
        }
    }

    async Task EditDepartment(Department department)
    {
        var result = await DialogService.OpenAsync<DepartmentDialog>("Edit Department", new Dictionary<string, object> { { "Department", department } });
        if (result != null)
        {
            DbContext.Departments.Update(result);
            await DbContext.SaveChangesAsync();
            await LoadData();
            NotificationService.Notify(NotificationSeverity.Info, "Updated", "Department updated successfully");
        }
    }

    async Task DeleteDepartment(Department department)
    {
        var confirm = await DialogService.Confirm("Are you sure?", "Delete Department", new ConfirmOptions() { OkButtonText = "Yes", CancelButtonText = "No" });
        if (confirm == true)
        {
            DbContext.Departments.Remove(department);
            await DbContext.SaveChangesAsync();
            await LoadData();
            NotificationService.Notify(NotificationSeverity.Error, "Deleted", "Department deleted");
        }
    }

    async Task ExportExcel()
    {
        var bytes = ExportService.ExportToExcel(departments, "Departments");
        await JSRuntime.InvokeVoidAsync("downloadFileFromBytes", "Departments.xlsx", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", Convert.ToBase64String(bytes));
    }

    async Task ExportCsv()
    {
        var bytes = ExportService.ExportToCsv(departments);
        await JSRuntime.InvokeVoidAsync("downloadFileFromBytes", "Departments.csv", "text/csv", Convert.ToBase64String(bytes));
    }
}