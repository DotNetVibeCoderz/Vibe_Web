@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView>
    <Authorized>
        <div class="d-flex align-items-center gap-3">
            <span class="text-white">Hello, @context.User.Identity.Name!</span>
            <form action="Account/Logout" method="post">
                <button type="submit" class="btn btn-link text-white text-decoration-none">Logout</button>
            </form>
        </div>
    </Authorized>
    <NotAuthorized>
        <a href="Account/Login" class="text-white text-decoration-none">Login</a>
    </NotAuthorized>
</AuthorizeView>
