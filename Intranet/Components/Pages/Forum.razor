@page "/forum"
@using Intranet.Data
@using Intranet.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext
@inject AuthenticationStateProvider AuthState

<PageTitle>Forum Diskusi</PageTitle>

@if (SelectedTopic == null)
{
    <div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center space-y-4 sm:space-y-0">
        <div>
            <h2 class="text-2xl font-bold text-gray-800 dark:text-white">Forum Diskusi</h2>
            <p class="text-gray-500 dark:text-gray-400 text-sm">Tempat berkumpul, berdiskusi, dan berbagi ide</p>
        </div>
        <button @onclick="OpenCreateTopicModal" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded shadow transition flex items-center">
            <i class="fas fa-plus mr-2"></i> Buat Topik Baru
        </button>
    </div>

    <!-- Tabs & Search -->
    <div class="bg-white dark:bg-gray-800 rounded-t-lg border-b border-gray-200 dark:border-gray-700 flex flex-col sm:flex-row justify-between items-center px-4 py-3 gap-4">
        <div class="flex space-x-1">
            <button class="px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-200 rounded-md text-sm font-medium hover:bg-gray-200 dark:hover:bg-gray-600 transition">Terbaru</button>
        </div>
        <div class="relative w-full sm:w-64">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3">
                <i class="fas fa-search text-gray-400"></i>
            </span>
            <input type="text" @bind="SearchQuery" @bind:event="oninput" placeholder="Cari diskusi..." class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white text-sm" />
        </div>
    </div>

    <!-- Forum List -->
    <div class="bg-white dark:bg-gray-800 rounded-b-lg shadow-sm border-x border-b border-gray-200 dark:border-gray-700">
        @if (Topics == null)
        {
            <div class="p-8 text-center text-gray-500">Loading topics...</div>
        }
        else if (!FilteredTopics.Any())
        {
            <div class="p-12 text-center text-gray-500 dark:text-gray-400 flex flex-col items-center">
                <i class="fas fa-comments text-5xl mb-4 text-gray-300 dark:text-gray-600"></i>
                <p>Belum ada topik diskusi yang ditemukan.</p>
            </div>
        }
        else
        {
            <ul class="divide-y divide-gray-200 dark:divide-gray-700">
                @foreach (var topic in FilteredTopics)
                {
                    <li class="p-4 hover:bg-gray-50 dark:hover:bg-gray-700 transition flex items-start gap-4">
                        <div class="flex flex-col items-center space-y-1 bg-gray-100 dark:bg-gray-900 rounded-md p-2 min-w-[3rem]">
                            <button @onclick="() => VoteTopic(topic, 1)" class="text-gray-400 hover:text-blue-500 transition"><i class="fas fa-arrow-up"></i></button>
                            <span class="text-sm font-bold text-gray-700 dark:text-gray-300">@topic.Likes</span>
                            <button @onclick="() => VoteTopic(topic, -1)" class="text-gray-400 hover:text-red-500 transition"><i class="fas fa-arrow-down"></i></button>
                        </div>

                        <div class="flex-1 cursor-pointer" @onclick="() => SelectTopicItem(topic)">
                            <div class="flex items-center gap-2 mb-1">
                                <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2 py-0.5 rounded dark:bg-blue-900 dark:text-blue-200">@topic.Category</span>
                                <span class="text-xs text-gray-500 dark:text-gray-400">• Diposting oleh <span class="font-medium text-gray-700 dark:text-gray-300">@topic.Author</span> • @GetTimeAgo(topic.CreatedAt)</span>
                            </div>
                            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1 hover:text-blue-600 dark:hover:text-blue-400 transition">@topic.Title</h3>
                            <div class="text-sm text-gray-600 dark:text-gray-300 line-clamp-2">
                                @((MarkupString)topic.Content)
                            </div>
                            <div class="mt-3 flex items-center text-xs text-gray-500 dark:text-gray-400 space-x-4">
                                <span class="flex items-center hover:bg-gray-200 dark:hover:bg-gray-600 p-1 rounded transition"><i class="far fa-comment-alt mr-1"></i> @(topic.Posts?.Count ?? 0) Komentar</span>
                            </div>
                        </div>
                    </li>
                }
            </ul>
        }
    </div>
}
else
{
    <!-- Topic Detail View -->
    <div class="mb-6">
        <button @onclick="() => SelectedTopic = null" class="text-blue-600 hover:text-blue-800 font-medium flex items-center mb-4 transition">
            <i class="fas fa-arrow-left mr-2"></i> Kembali ke List Forum
        </button>

        <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="p-6">
                <div class="flex items-start gap-4">
                    <div class="flex flex-col items-center space-y-1 bg-gray-100 dark:bg-gray-900 rounded-md p-2 min-w-[3rem]">
                        <button @onclick="() => VoteTopic(SelectedTopic, 1)" class="text-gray-400 hover:text-blue-500 transition"><i class="fas fa-arrow-up"></i></button>
                        <span class="text-sm font-bold text-gray-700 dark:text-gray-300">@SelectedTopic.Likes</span>
                        <button @onclick="() => VoteTopic(SelectedTopic, -1)" class="text-gray-400 hover:text-red-500 transition"><i class="fas fa-arrow-down"></i></button>
                    </div>
                    <div class="flex-1">
                        <div class="flex items-center gap-2 mb-2">
                            <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2 py-0.5 rounded dark:bg-blue-900 dark:text-blue-200">@SelectedTopic.Category</span>
                            <span class="text-xs text-gray-500 dark:text-gray-400">• Diposting oleh <span class="font-medium text-gray-700 dark:text-gray-300">@SelectedTopic.Author</span> • @GetTimeAgo(SelectedTopic.CreatedAt)</span>
                        </div>
                        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">@SelectedTopic.Title</h2>
                        <div class="text-gray-700 dark:text-gray-300 prose dark:prose-invert max-w-none">
                            @((MarkupString)SelectedTopic.Content)
                        </div>
                    </div>
                </div>
            </div>

            <!-- Comments Section -->
            <div class="bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700 p-6">
                <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4">@((SelectedTopic.Posts?.Count ?? 0)) Komentar</h3>
                
                <!-- Comment Form -->
                <div class="mb-8">
                    <textarea @bind="NewCommentContent" rows="3" placeholder="Tulis komentar kamu..." class="w-full border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm py-2 px-3 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white sm:text-sm mb-2"></textarea>
                    <div class="flex justify-end">
                        <button @onclick="AddComment" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded shadow transition text-sm">
                            Kirim Komentar
                        </button>
                    </div>
                </div>

                <!-- Comment List -->
                <div class="space-y-6">
                    @if (SelectedTopic.Posts == null || !SelectedTopic.Posts.Any())
                    {
                        <p class="text-center text-gray-500 py-4">Belum ada komentar. Jadi yang pertama!</p>
                    }
                    else
                    {
                        @foreach (var post in SelectedTopic.Posts.OrderBy(p => p.CreatedAt))
                        {
                            <div class="flex gap-4">
                                <div class="w-10 h-10 rounded-full bg-gray-200 flex-shrink-0 flex items-center justify-center font-bold text-gray-500">@post.Author.Substring(0, 1).ToUpper()</div>
                                <div class="flex-1">
                                    <div class="flex items-center gap-2 mb-1">
                                        <span class="font-bold text-gray-900 dark:text-white text-sm">@post.Author</span>
                                        <span class="text-xs text-gray-500">@GetTimeAgo(post.CreatedAt)</span>
                                    </div>
                                    <div class="text-gray-700 dark:text-gray-300 text-sm">
                                        @((MarkupString)post.Content.Replace("\n", "<br>"))
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Form Create Topic -->
@if (IsCreateModalOpen)
{
    <div class="fixed z-50 inset-0 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true" @onclick="CloseModal"></div>
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>
            <div class="inline-block align-bottom bg-white dark:bg-gray-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-2xl sm:w-full">
                <div class="bg-white dark:bg-gray-800 px-4 pt-5 pb-4 sm:p-6">
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4 border-b border-gray-200 dark:border-gray-700 pb-2">Buat Topik Baru</h3>
                    
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Pilih Kategori</label>
                            <select @bind="NewTopic.Category" class="w-full border border-gray-300 dark:border-gray-600 rounded-md shadow-sm py-2 px-3 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white sm:text-sm">
                                <option value="General">General</option>
                                <option value="Ask HR">Ask HR</option>
                                <option value="IT Support">IT Support</option>
                                <option value="Random/OOT">Random / Out of Topic</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Judul Topik</label>
                            <input type="text" @bind="NewTopic.Title" placeholder="Tulis judul yang menarik..." class="w-full border border-gray-300 dark:border-gray-600 rounded-md shadow-sm py-2 px-3 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white sm:text-sm" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Isi Diskusi</label>
                            <textarea @bind="NewTopic.Content" rows="6" placeholder="Ceritakan lebih banyak di sini..." class="w-full border border-gray-300 dark:border-gray-600 rounded-md shadow-sm py-2 px-3 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white sm:text-sm"></textarea>
                        </div>
                    </div>
                </div>
                <div class="bg-gray-50 dark:bg-gray-700 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                    <button type="button" @onclick="SaveTopic" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:ml-3 sm:w-auto sm:text-sm transition">
                        Posting
                    </button>
                    <button type="button" @onclick="CloseModal" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 dark:border-gray-600 shadow-sm px-4 py-2 bg-white dark:bg-gray-800 text-base font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm transition">
                        Batal
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ForumTopic>? Topics;
    private ForumTopic? SelectedTopic;
    private bool IsCreateModalOpen = false;
    private ForumTopic NewTopic = new() { Category = "General" };
    private string NewCommentContent = "";
    private string SearchQuery = "";
    private string CurrentUser = "Anonymous";

    private IEnumerable<ForumTopic> FilteredTopics => 
        string.IsNullOrWhiteSpace(SearchQuery) 
            ? (Topics ?? new List<ForumTopic>()) 
            : (Topics ?? new List<ForumTopic>()).Where(t => t.Title.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) || t.Content.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            CurrentUser = authState.User.Identity.Name ?? "User";
        }
        await LoadTopics();
    }

    private async Task LoadTopics()
    {
        Topics = await DbContext.ForumTopics
            .Include(t => t.Posts)
            .OrderByDescending(t => t.CreatedAt)
            .ToListAsync();
            
        if (SelectedTopic != null)
        {
            SelectedTopic = Topics.FirstOrDefault(t => t.Id == SelectedTopic.Id);
        }
    }

    private void OpenCreateTopicModal()
    {
        NewTopic = new ForumTopic { Category = "General" };
        IsCreateModalOpen = true;
    }

    private void CloseModal()
    {
        IsCreateModalOpen = false;
    }

    private async Task SaveTopic()
    {
        if (!string.IsNullOrWhiteSpace(NewTopic.Title) && !string.IsNullOrWhiteSpace(NewTopic.Content))
        {
            NewTopic.Author = CurrentUser;
            NewTopic.CreatedAt = DateTime.UtcNow;
            NewTopic.Likes = 0;
            
            NewTopic.Content = NewTopic.Content.Replace("\n", "<br>");

            DbContext.ForumTopics.Add(NewTopic);
            await DbContext.SaveChangesAsync();
            await LoadTopics();
            CloseModal();
        }
    }

    private void SelectTopicItem(ForumTopic topic)
    {
        SelectedTopic = topic;
        NewCommentContent = "";
    }

    private async Task AddComment()
    {
        if (SelectedTopic != null && !string.IsNullOrWhiteSpace(NewCommentContent))
        {
            var post = new ForumPost
            {
                ForumTopicId = SelectedTopic.Id,
                Content = NewCommentContent,
                Author = CurrentUser,
                CreatedAt = DateTime.UtcNow
            };

            DbContext.ForumPosts.Add(post);
            await DbContext.SaveChangesAsync();
            
            NewCommentContent = "";
            await LoadTopics();
        }
    }

    private async Task VoteTopic(ForumTopic topic, int value)
    {
        topic.Likes += value;
        DbContext.ForumTopics.Update(topic);
        await DbContext.SaveChangesAsync();
    }

    private string GetTimeAgo(DateTime dt)
    {
        var ts = DateTime.UtcNow - dt;
        if (ts.TotalMinutes < 1) return "Baru saja";
        if (ts.TotalMinutes < 60) return $"{(int)ts.TotalMinutes} menit yang lalu";
        if (ts.TotalHours < 24) return $"{(int)ts.TotalHours} jam yang lalu";
        if (ts.TotalDays < 7) return $"{(int)ts.TotalDays} hari yang lalu";
        return dt.ToString("dd MMM yyyy");
    }
}