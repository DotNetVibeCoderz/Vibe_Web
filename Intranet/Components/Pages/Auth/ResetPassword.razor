@page "/reset-password"
@using Intranet.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext
@inject NavigationManager NavManager

<div class="flex items-center justify-center min-h-screen bg-gray-100 dark:bg-gray-900 w-full px-4">
    <div class="w-full max-w-md bg-white dark:bg-gray-800 rounded-lg shadow-xl p-8 border border-gray-200 dark:border-gray-700">
        <div class="text-center mb-8">
            <h2 class="text-3xl font-bold text-gray-800 dark:text-white mb-2">Reset Password</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400">Enter your details to reset your password</p>
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="mb-4 bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative" role="alert">
                <span class="block sm:inline">@ErrorMessage</span>
            </div>
        }

        @if (ShowSuccess)
        {
            <div class="mb-4 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded relative" role="alert">
                <span class="block sm:inline">Password has been reset successfully. You can now login.</span>
            </div>
            <div class="mt-4 text-center">
                <a href="/login" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 transition">Go to Login</a>
            </div>
        }
        else
        {
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Username</label>
                    <input type="text" @bind="Username" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white" placeholder="admin" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Email</label>
                    <input type="email" @bind="Email" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white" placeholder="admin@intranet.local" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">New Password</label>
                    <input type="password" @bind="NewPassword" class="w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white" placeholder="••••••••" />
                </div>

                <button @onclick="PerformReset" class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition mt-6">
                    Reset Password
                </button>
            </div>

            <div class="mt-6 text-center">
                <p class="text-sm text-gray-600 dark:text-gray-400">
                    Remember your password? <a href="/login" class="font-medium text-blue-600 hover:text-blue-500 dark:text-blue-400">Sign in</a>
                </p>
            </div>
        }
    </div>
</div>

@code {
    private string Username = "";
    private string Email = "";
    private string NewPassword = "";
    private string ErrorMessage = "";
    private bool ShowSuccess = false;

    private async Task PerformReset()
    {
        if (string.IsNullOrWhiteSpace(Username) || string.IsNullOrWhiteSpace(Email) || string.IsNullOrWhiteSpace(NewPassword))
        {
            ErrorMessage = "Please fill in all fields.";
            return;
        }

        var user = await DbContext.Users.FirstOrDefaultAsync(u => u.Username == Username && u.Email == Email);
        
        if (user == null)
        {
            ErrorMessage = "User details do not match our records.";
            return;
        }

        user.PasswordHash = NewPassword;
        DbContext.Users.Update(user);
        await DbContext.SaveChangesAsync();
        
        ShowSuccess = true;
        ErrorMessage = "";
    }
}