@page "/projects"
@using Intranet.Data
@using Intranet.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext

<PageTitle>Tasks & Projects</PageTitle>

<div class="mb-6 flex justify-between items-center">
    <h2 class="text-2xl font-bold text-gray-800 dark:text-white">Tasks & Projects</h2>
    <div class="flex space-x-2">
        <button @onclick="OpenProjectModal" class="bg-gray-200 hover:bg-gray-300 text-gray-800 dark:bg-gray-700 dark:text-white dark:hover:bg-gray-600 font-bold py-2 px-4 rounded shadow transition">
            <i class="fas fa-folder-plus mr-2"></i> New Project
        </button>
        <button @onclick="OpenTaskModal" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded shadow transition">
            <i class="fas fa-plus mr-2"></i> New Task
        </button>
    </div>
</div>

@if (ProjectList == null)
{
    <p>Loading projects...</p>
}
else if (!ProjectList.Any())
{
    <div class="bg-white dark:bg-gray-800 p-8 rounded-lg shadow text-center text-gray-500 dark:text-gray-400">
        <i class="fas fa-project-diagram text-5xl mb-4 text-gray-300 dark:text-gray-600"></i>
        <p>No projects found. Create a new project to get started.</p>
    </div>
}
else
{
    @foreach (var project in ProjectList)
    {
        <div class="bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-6 mb-6">
            <div class="border-b border-gray-200 dark:border-gray-700 pb-4 mb-4 flex justify-between items-start">
                <div>
                    <div class="flex items-center space-x-3">
                        <h3 class="text-xl font-bold text-gray-900 dark:text-white">@project.Name</h3>
                        <span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-green-900 dark:text-green-300">@project.Status</span>
                    </div>
                    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">@project.Description</p>
                </div>
                <div class="flex space-x-2">
                    <button @onclick="() => EditProject(project)" class="text-blue-500 hover:text-blue-700"><i class="fas fa-edit"></i></button>
                    <button @onclick="() => DeleteProject(project)" class="text-red-500 hover:text-red-700"><i class="fas fa-trash"></i></button>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                @{ var projectTasks = Tasks?.Where(t => t.ProjectId == project.Id).ToList() ?? new List<TaskItem>(); }
                
                <!-- Todo Column -->
                <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-4">
                    <h4 class="font-semibold text-gray-700 dark:text-gray-300 mb-3 flex items-center"><span class="w-3 h-3 rounded-full bg-red-500 mr-2"></span> To Do</h4>
                    <div class="space-y-3">
                        @foreach (var task in projectTasks.Where(t => t.Status == "Todo"))
                        {
                            <TaskCard Task="task" OnEdit="EditTask" OnDelete="DeleteTask" />
                        }
                    </div>
                </div>

                <!-- In Progress Column -->
                <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-4">
                    <h4 class="font-semibold text-gray-700 dark:text-gray-300 mb-3 flex items-center"><span class="w-3 h-3 rounded-full bg-blue-500 mr-2"></span> In Progress</h4>
                    <div class="space-y-3">
                        @foreach (var task in projectTasks.Where(t => t.Status == "InProgress"))
                        {
                            <TaskCard Task="task" OnEdit="EditTask" OnDelete="DeleteTask" />
                        }
                    </div>
                </div>

                <!-- Done Column -->
                <div class="bg-gray-50 dark:bg-gray-900 rounded-lg p-4">
                    <h4 class="font-semibold text-gray-700 dark:text-gray-300 mb-3 flex items-center"><span class="w-3 h-3 rounded-full bg-green-500 mr-2"></span> Done</h4>
                    <div class="space-y-3">
                        @foreach (var task in projectTasks.Where(t => t.Status == "Done"))
                        {
                            <TaskCard Task="task" OnEdit="EditTask" OnDelete="DeleteTask" />
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

<!-- Project Modal -->
@if (IsProjectModalOpen)
{
    <div class="fixed z-50 inset-0 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" @onclick="CloseModals"></div>
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
            <div class="inline-block align-bottom bg-white dark:bg-gray-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
                <div class="bg-white dark:bg-gray-800 px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white mb-4">@(EditingProject.Id == 0 ? "New Project" : "Edit Project")</h3>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Project Name</label>
                            <input type="text" @bind="EditingProject.Name" class="mt-1 block w-full border border-gray-300 dark:border-gray-600 rounded-md py-2 px-3 focus:ring-blue-500 focus:border-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Description</label>
                            <textarea @bind="EditingProject.Description" rows="3" class="mt-1 block w-full border border-gray-300 dark:border-gray-600 rounded-md py-2 px-3 focus:ring-blue-500 focus:border-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white"></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Status</label>
                            <select @bind="EditingProject.Status" class="mt-1 block w-full border border-gray-300 dark:border-gray-600 rounded-md py-2 px-3 focus:ring-blue-500 focus:border-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                                <option value="Active">Active</option>
                                <option value="OnHold">On Hold</option>
                                <option value="Completed">Completed</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="bg-gray-50 dark:bg-gray-700 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                    <button type="button" @onclick="SaveProject" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 sm:ml-3 sm:w-auto sm:text-sm">Save</button>
                    <button type="button" @onclick="CloseModals" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 dark:border-gray-600 shadow-sm px-4 py-2 bg-white dark:bg-gray-800 text-base font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Task Modal -->
@if (IsTaskModalOpen)
{
    <div class="fixed z-50 inset-0 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" @onclick="CloseModals"></div>
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
            <div class="inline-block align-bottom bg-white dark:bg-gray-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
                <div class="bg-white dark:bg-gray-800 px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white mb-4">@(EditingTask.Id == 0 ? "New Task" : "Edit Task")</h3>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Project</label>
                            <select @bind="EditingTask.ProjectId" class="mt-1 block w-full border border-gray-300 dark:border-gray-600 rounded-md py-2 px-3 focus:ring-blue-500 focus:border-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                                <option value="0">-- Select Project --</option>
                                @if (ProjectList != null) { @foreach (var p in ProjectList) { <option value="@p.Id">@p.Name</option> } }
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Title</label>
                            <input type="text" @bind="EditingTask.Title" class="mt-1 block w-full border border-gray-300 dark:border-gray-600 rounded-md py-2 px-3 focus:ring-blue-500 focus:border-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Description</label>
                            <textarea @bind="EditingTask.Description" rows="2" class="mt-1 block w-full border border-gray-300 dark:border-gray-600 rounded-md py-2 px-3 focus:ring-blue-500 focus:border-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white"></textarea>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Assignee Username</label>
                                <input type="text" @bind="EditingTask.Assignee" placeholder="e.g. user" class="mt-1 block w-full border border-gray-300 dark:border-gray-600 rounded-md py-2 px-3 focus:ring-blue-500 focus:border-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Status</label>
                                <select @bind="EditingTask.Status" class="mt-1 block w-full border border-gray-300 dark:border-gray-600 rounded-md py-2 px-3 focus:ring-blue-500 focus:border-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                                    <option value="Todo">To Do</option>
                                    <option value="InProgress">In Progress</option>
                                    <option value="Done">Done</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-gray-50 dark:bg-gray-700 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                    <button type="button" @onclick="SaveTask" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 sm:ml-3 sm:w-auto sm:text-sm">Save</button>
                    <button type="button" @onclick="CloseModals" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 dark:border-gray-600 shadow-sm px-4 py-2 bg-white dark:bg-gray-800 text-base font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Project>? ProjectList;
    private List<TaskItem>? Tasks;
    private bool IsProjectModalOpen = false;
    private bool IsTaskModalOpen = false;
    private Project EditingProject = new();
    private TaskItem EditingTask = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        ProjectList = await DbContext.Projects.ToListAsync();
        Tasks = await DbContext.Tasks.ToListAsync();
    }

    private void OpenProjectModal() { EditingProject = new Project { Status = "Active", StartDate = DateTime.UtcNow }; IsProjectModalOpen = true; }
    private void EditProject(Project p) { EditingProject = new Project { Id = p.Id, Name = p.Name, Description = p.Description, Status = p.Status, StartDate = p.StartDate, EndDate = p.EndDate }; IsProjectModalOpen = true; }
    private void OpenTaskModal() { EditingTask = new TaskItem { Status = "Todo", DueDate = DateTime.UtcNow.AddDays(7) }; IsTaskModalOpen = true; }
    private void EditTask(TaskItem t) { EditingTask = new TaskItem { Id = t.Id, ProjectId = t.ProjectId, Title = t.Title, Description = t.Description, Assignee = t.Assignee, Status = t.Status, DueDate = t.DueDate }; IsTaskModalOpen = true; }
    private void CloseModals() { IsProjectModalOpen = false; IsTaskModalOpen = false; }

    private async Task SaveProject()
    {
        if (string.IsNullOrWhiteSpace(EditingProject.Name)) return;

        if (EditingProject.Id == 0) DbContext.Projects.Add(EditingProject);
        else
        {
            var p = await DbContext.Projects.FindAsync(EditingProject.Id);
            if (p != null) { p.Name = EditingProject.Name; p.Description = EditingProject.Description; p.Status = EditingProject.Status; DbContext.Projects.Update(p); }
        }
        await DbContext.SaveChangesAsync();
        await LoadData();
        CloseModals();
    }

    private async Task DeleteProject(Project p)
    {
        DbContext.Projects.Remove(p);
        // Also remove related tasks
        var relatedTasks = DbContext.Tasks.Where(t => t.ProjectId == p.Id);
        DbContext.Tasks.RemoveRange(relatedTasks);
        
        await DbContext.SaveChangesAsync();
        await LoadData();
    }

    private async Task SaveTask()
    {
        if (EditingTask.ProjectId == 0 || string.IsNullOrWhiteSpace(EditingTask.Title)) return;

        if (EditingTask.Id == 0) DbContext.Tasks.Add(EditingTask);
        else
        {
            var t = await DbContext.Tasks.FindAsync(EditingTask.Id);
            if (t != null) { t.ProjectId = EditingTask.ProjectId; t.Title = EditingTask.Title; t.Description = EditingTask.Description; t.Assignee = EditingTask.Assignee; t.Status = EditingTask.Status; DbContext.Tasks.Update(t); }
        }
        await DbContext.SaveChangesAsync();
        await LoadData();
        CloseModals();
    }

    private async Task DeleteTask(TaskItem t)
    {
        var task = await DbContext.Tasks.FindAsync(t.Id);
        if (task != null)
        {
            DbContext.Tasks.Remove(task);
            await DbContext.SaveChangesAsync();
            await LoadData();
        }
    }
}