@page "/social"
@using Intranet.Data
@using Intranet.Models
@using Intranet.Services.Storage
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext
@inject AuthenticationStateProvider AuthState
@inject IFileStorageService StorageService

<PageTitle>Social Feed</PageTitle>

<div class="max-w-3xl mx-auto py-6">
    <div class="flex justify-between items-center mb-6">
        <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white">Social Feed</h2>
        <div class="text-sm text-gray-500 bg-white dark:bg-gray-800 px-3 py-1 rounded-full shadow-sm border border-gray-200 dark:border-gray-700">
            Welcome back, <span class="font-bold text-blue-600">@CurrentUser</span>
        </div>
    </div>

    <!-- Create Post Widget -->
    <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-lg border border-gray-200 dark:border-gray-700 p-6 mb-8 transition-all hover:shadow-xl">
        <div class="flex space-x-4">
            <img src="@CurrentUserAvatar" alt="Avatar" class="w-12 h-12 rounded-full border-2 border-blue-100 dark:border-gray-700 shadow-sm object-cover bg-white" />
            <div class="flex-1">
                <textarea @bind="NewPostContent" rows="3" class="w-full px-5 py-3 border border-gray-200 dark:border-gray-700 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-white resize-none transition-all" placeholder="Share something with your colleagues..."></textarea>
                
                @if (IsUploading)
                {
                    <div class="text-xs text-blue-500 mt-3 flex items-center animate-pulse">
                        <i class="fas fa-spinner fa-spin mr-2"></i> Uploading attachment...
                    </div>
                }
                
                @if (!string.IsNullOrEmpty(AttachedImageUrl))
                {
                    <div class="mt-4 relative inline-block group">
                        <img src="@AttachedImageUrl" class="h-24 w-auto rounded-xl shadow-md border border-gray-200 dark:border-gray-700 object-cover" />
                        <button @onclick="() => AttachedImageUrl = string.Empty" class="absolute -top-2 -right-2 bg-red-500 hover:bg-red-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-xs shadow-lg transition-transform transform hover:scale-110">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                }

                @if (!string.IsNullOrEmpty(AttachedFileUrl))
                {
                    <div class="mt-4 inline-flex items-center bg-blue-50 dark:bg-blue-900 dark:bg-opacity-20 px-4 py-2 rounded-xl text-sm relative pr-10 shadow-sm border border-blue-100 dark:border-blue-800 text-blue-700 dark:text-blue-300">
                        <i class="fas fa-file-alt mr-2"></i> @AttachedFileName
                        <button @onclick="() => AttachedFileUrl = string.Empty" class="absolute right-2 text-red-500 hover:text-red-700 transition"><i class="fas fa-times-circle"></i></button>
                    </div>
                }

                <div class="flex justify-between items-center mt-4 pt-4 border-t border-gray-50 dark:border-gray-700">
                    <div class="flex space-x-1">
                        <label class="p-2.5 text-gray-500 dark:text-gray-400 hover:bg-blue-50 dark:hover:bg-gray-700 hover:text-blue-600 rounded-full transition cursor-pointer" title="Attach Image">
                            <i class="far fa-image text-lg"></i>
                            <InputFile OnChange="UploadImage" accept="image/*" class="hidden" />
                        </label>
                        <label class="p-2.5 text-gray-500 dark:text-gray-400 hover:bg-blue-50 dark:hover:bg-gray-700 hover:text-blue-600 rounded-full transition cursor-pointer" title="Attach Document">
                            <i class="fas fa-paperclip text-lg"></i>
                            <InputFile OnChange="UploadDoc" accept=".pdf,.doc,.docx,.xls,.xlsx" class="hidden" />
                        </label>
                        <div class="relative">
                            <button @onclick="() => ShowEmojiPicker = !ShowEmojiPicker" class="p-2.5 text-gray-500 dark:text-gray-400 hover:bg-blue-50 dark:hover:bg-gray-700 hover:text-blue-600 rounded-full transition" title="Add Emoji"><i class="far fa-smile text-lg"></i></button>
                            @if (ShowEmojiPicker)
                            {
                                <div class="absolute bottom-12 left-0 bg-white dark:bg-gray-700 shadow-2xl rounded-xl p-3 grid grid-cols-6 gap-2 border border-gray-100 dark:border-gray-600 z-50 w-56 animate-in zoom-in-50">
                                    @foreach (var e in Emojis)
                                    {
                                        <button @onclick="() => AddEmoji(e)" class="text-xl hover:bg-gray-100 dark:hover:bg-gray-600 rounded p-1 transition">@e</button>
                                    }
                                </div>
                                <div class="fixed inset-0 z-40" @onclick="() => ShowEmojiPicker = false"></div>
                            }
                        </div>
                    </div>
                    <button @onclick="CreatePost" disabled="@(string.IsNullOrWhiteSpace(NewPostContent) || IsUploading)" class="px-8 py-2.5 bg-blue-600 text-white rounded-xl shadow-lg hover:bg-blue-700 disabled:opacity-50 disabled:bg-gray-400 transition transform active:scale-95 font-bold">Post</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Feed -->
    <div class="space-y-8">
        @if (Posts == null)
        {
            <div class="text-center py-20 text-gray-500">
                <i class="fas fa-circle-notch fa-spin text-4xl mb-4"></i>
                <p>Loading your feed...</p>
            </div>
        }
        else if (!Posts.Any())
        {
            <div class="text-center py-20 bg-white dark:bg-gray-800 rounded-2xl border border-gray-100 dark:border-gray-700 shadow-sm">
                <i class="fas fa-rss text-6xl text-gray-200 dark:text-gray-700 mb-4"></i>
                <p class="text-gray-500 dark:text-gray-400">Your feed is empty. Be the first to post!</p>
            </div>
        }
        else
        {
            @foreach (var post in Posts)
            {
                var hasLiked = UserLikedPostIds.Contains(post.Id);
                
                <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-md border border-gray-100 dark:border-gray-700 overflow-hidden transition-all hover:shadow-lg">
                    <!-- Post Header -->
                    <div class="p-5 flex justify-between items-center">
                        <div class="flex space-x-3">
                            <img src="@post.AuthorAvatar" alt="@post.Author" class="w-11 h-11 rounded-full border border-gray-100 shadow-sm object-cover bg-white" />
                            <div>
                                <h4 class="font-bold text-gray-900 dark:text-white leading-tight">@post.Author</h4>
                                <p class="text-[11px] text-gray-500 dark:text-gray-400 mt-0.5 flex items-center">
                                    <i class="far fa-clock mr-1"></i> @GetTimeAgo(post.CreatedAt)
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- Post Content -->
                    <div class="px-5 pb-4 text-gray-800 dark:text-gray-200 text-sm leading-relaxed whitespace-pre-wrap">@post.Content</div>

                    <!-- Attachments -->
                    @if (!string.IsNullOrEmpty(post.AttachedImageUrl))
                    {
                        <div class="px-2 pb-2">
                            <img src="@post.AttachedImageUrl" class="rounded-xl w-full max-h-[500px] object-cover cursor-pointer hover:opacity-95 transition" @onclick="() => OpenImageOverlay(post.AttachedImageUrl)" />
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(post.AttachedFileUrl))
                    {
                        <div class="px-5 pb-4">
                            <a href="@post.AttachedFileUrl" target="_blank" class="flex items-center space-x-3 text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900 dark:bg-opacity-30 p-3 rounded-xl hover:bg-blue-100 dark:hover:bg-opacity-50 border border-blue-100 dark:border-blue-800 transition group">
                                <div class="bg-blue-600 text-white p-2 rounded-lg shadow-sm group-hover:scale-110 transition"><i class="fas fa-file-download"></i></div>
                                <span class="text-xs font-bold truncate">Download Attachment</span>
                            </a>
                        </div>
                    }

                    <!-- Post Actions -->
                    <div class="px-5 py-3 flex items-center space-x-6 text-gray-500 dark:text-gray-400 border-t border-gray-50 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 dark:bg-opacity-50">
                        <button @onclick="() => LikePost(post)" class="flex items-center space-x-2 transition transform active:scale-90 @(hasLiked ? "text-blue-600 font-bold" : "hover:text-blue-600")">
                            <i class="@(hasLiked ? "fas fa-thumbs-up" : "far fa-thumbs-up") text-lg"></i>
                            <span class="text-sm">@post.Likes</span>
                        </button>
                        <button class="flex items-center space-x-2 hover:text-blue-600 transition">
                            <i class="far fa-comment text-lg"></i>
                            <span class="text-sm">@(post.Comments?.Count ?? 0)</span>
                        </button>
                    </div>

                    <!-- Comments Section -->
                    <div class="px-5 py-4 space-y-4 bg-white dark:bg-gray-800">
                        @if (post.Comments != null && post.Comments.Any())
                        {
                            <div class="space-y-4 max-h-60 overflow-y-auto pr-2 custom-scrollbar">
                                @foreach (var comment in post.Comments.OrderBy(c => c.CreatedAt))
                                {
                                    <div class="flex space-x-3 group">
                                        <img src="@comment.AuthorAvatar" class="w-8 h-8 rounded-full border border-gray-100 shadow-sm object-cover bg-white" />
                                        <div class="bg-gray-100 dark:bg-gray-700 px-4 py-2 rounded-2xl flex-1 relative">
                                            <div class="flex justify-between items-center mb-0.5">
                                                <span class="font-bold text-xs text-gray-900 dark:text-white">@comment.Author</span>
                                                <span class="text-[9px] text-gray-400">@GetTimeAgo(comment.CreatedAt)</span>
                                            </div>
                                            <p class="text-xs text-gray-800 dark:text-gray-200 leading-relaxed">@comment.Content</p>
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        <!-- Add Comment -->
                        <div class="flex items-center space-x-3 pt-2">
                            <img src="@CurrentUserAvatar" class="w-8 h-8 rounded-full border border-gray-100 object-cover bg-white" />
                            <div class="flex-1 relative">
                                <input type="text" placeholder="Write a comment..." class="w-full border border-gray-200 dark:border-gray-700 rounded-full py-2 px-5 text-xs focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-white transition-all pr-10"
                                       @onchange="@(e => CommentPost(post, e.Value?.ToString()))" />
                                <i class="far fa-paper-plane absolute right-4 top-2.5 text-gray-300"></i>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@if (ShowImageOverlay)
{
    <div class="fixed inset-0 z-50 bg-black bg-opacity-95 flex items-center justify-center p-6 animate-in fade-in" @onclick="() => ShowImageOverlay = false">
        <img src="@OverlayImageUrl" class="max-w-full max-h-full rounded-lg shadow-2xl border-4 border-white dark:border-gray-800" />
        <button class="absolute top-8 right-8 text-white text-4xl hover:scale-110 transition"><i class="fas fa-times-circle"></i></button>
    </div>
}

@code {
    private List<SocialPost>? Posts;
    private HashSet<int> UserLikedPostIds = new();
    private string NewPostContent = "";
    private string AttachedImageUrl = "";
    private string AttachedFileUrl = "";
    private string AttachedFileName = "";
    private string CurrentUser = "Anonymous";
    private string CurrentUserAvatar = "https://i.pravatar.cc/150";
    private bool IsUploading = false;
    private bool ShowEmojiPicker = false;
    private bool ShowImageOverlay = false;
    private string OverlayImageUrl = "";

    private string[] Emojis = { "😀", "😂", "🥰", "😍", "🤩", "🤔", "🙄", "🤨", "😭", "🤯", "🥳", "👍", "🙏", "🔥", "💯", "✅", "❌", "🚀" };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            CurrentUser = user.Identity.Name ?? "User";
            
            var userEntity = await DbContext.Users.FirstOrDefaultAsync(u => u.Username == CurrentUser);
            if (userEntity != null) CurrentUserAvatar = userEntity.AvatarUrl;
        }

        await LoadPosts();
    }

    private async Task LoadPosts()
    {
        Posts = await DbContext.SocialPosts
            .Include(p => p.Comments)
            .OrderByDescending(p => p.CreatedAt)
            .ToListAsync();

        var likes = await DbContext.SocialLikes.Where(l => l.Username == CurrentUser).ToListAsync();
        UserLikedPostIds = likes.Select(l => l.SocialPostId).ToHashSet();
    }

    private async Task UploadImage(InputFileChangeEventArgs e)
    {
        IsUploading = true;
        try
        {
            using var stream = e.File.OpenReadStream(10 * 1024 * 1024);
            AttachedImageUrl = await StorageService.SaveFileAsync(stream, e.File.Name);
        }
        catch { }
        finally { IsUploading = false; }
    }

    private async Task UploadDoc(InputFileChangeEventArgs e)
    {
        IsUploading = true;
        try
        {
            using var stream = e.File.OpenReadStream(20 * 1024 * 1024);
            AttachedFileUrl = await StorageService.SaveFileAsync(stream, e.File.Name);
            AttachedFileName = e.File.Name;
        }
        catch { }
        finally { IsUploading = false; }
    }

    private void AddEmoji(string emoji)
    {
        NewPostContent += emoji;
        ShowEmojiPicker = false;
    }

    private async Task CreatePost()
    {
        if (string.IsNullOrWhiteSpace(NewPostContent)) return;

        var post = new SocialPost
        {
            Content = NewPostContent,
            AttachedImageUrl = AttachedImageUrl,
            AttachedFileUrl = AttachedFileUrl,
            Author = CurrentUser,
            AuthorAvatar = CurrentUserAvatar,
            CreatedAt = DateTime.UtcNow,
            Likes = 0
        };

        DbContext.SocialPosts.Add(post);
        await DbContext.SaveChangesAsync();

        NewPostContent = "";
        AttachedImageUrl = "";
        AttachedFileUrl = "";
        AttachedFileName = "";
        await LoadPosts();
    }

    private async Task LikePost(SocialPost post)
    {
        if (UserLikedPostIds.Contains(post.Id)) return;

        var like = new SocialLike { SocialPostId = post.Id, Username = CurrentUser };
        DbContext.SocialLikes.Add(like);
        
        post.Likes++;
        DbContext.SocialPosts.Update(post);
        await DbContext.SaveChangesAsync();
        
        UserLikedPostIds.Add(post.Id);
    }

    private async Task CommentPost(SocialPost post, string? content)
    {
        if (string.IsNullOrWhiteSpace(content)) return;

        var comment = new SocialComment
        {
            SocialPostId = post.Id,
            Content = content,
            Author = CurrentUser,
            AuthorAvatar = CurrentUserAvatar,
            CreatedAt = DateTime.UtcNow
        };

        DbContext.SocialComments.Add(comment);
        await DbContext.SaveChangesAsync();
        await LoadPosts();
    }

    private void OpenImageOverlay(string url)
    {
        OverlayImageUrl = url;
        ShowImageOverlay = true;
    }

    private string GetTimeAgo(DateTime dt)
    {
        var ts = DateTime.UtcNow - dt;
        if (ts.TotalMinutes < 1) return "Just now";
        if (ts.TotalMinutes < 60) return $"{(int)ts.TotalMinutes}m ago";
        if (ts.TotalHours < 24) return $"{(int)ts.TotalHours}h ago";
        if (ts.TotalDays < 7) return $"{(int)ts.TotalDays}d ago";
        return dt.ToString("MMM dd");
    }
}