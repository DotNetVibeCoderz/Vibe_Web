@page "/profile"
@using Intranet.Data
@using Intranet.Models
@using Intranet.Services.Storage
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext
@inject AuthenticationStateProvider AuthState
@inject IFileStorageService StorageService

<PageTitle>My Profile</PageTitle>

<div class="max-w-4xl mx-auto py-8 px-4">
    <div class="bg-white dark:bg-gray-800 shadow-xl rounded-2xl border border-gray-200 dark:border-gray-700 overflow-hidden">
        
        <!-- Header Banner -->
        <div class="h-48 bg-gradient-to-r from-blue-600 via-indigo-600 to-purple-700 relative">
            <div class="absolute inset-0 bg-black bg-opacity-10"></div>
        </div>
        
        @if (CurrentUser == null)
        {
            <div class="p-20 text-center text-gray-500">
                <i class="fas fa-spinner fa-spin text-3xl mb-4"></i>
                <p>Loading profile...</p>
            </div>
        }
        else
        {
            <div class="px-8 pb-8 relative">
                <!-- Profile Image Placement Fix -->
                <div class="flex flex-col md:flex-row items-center md:items-end -mt-20 mb-8 space-y-4 md:space-y-0 md:space-x-6">
                    <div class="relative group">
                        <img src="@CurrentUser.AvatarUrl" alt="Avatar" class="w-40 h-40 rounded-full border-8 border-white dark:border-gray-800 bg-white shadow-lg object-cover" />
                        <label class="absolute bottom-2 right-2 bg-blue-600 hover:bg-blue-700 text-white p-2.5 rounded-full shadow-lg cursor-pointer transition transform hover:scale-110">
                            <i class="fas fa-camera"></i>
                            <InputFile OnChange="HandleAvatarUpload" class="hidden" accept="image/*" />
                        </label>
                    </div>
                    
                    <div class="text-center md:text-left pb-2">
                        <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white">@CurrentUser.FullName</h2>
                        <p class="text-lg font-medium text-gray-500 dark:text-gray-400">@CurrentUser.JobTitle • <span class="text-blue-600 dark:text-blue-400">@CurrentUser.Department</span></p>
                    </div>
                </div>

                <div class="border-t border-gray-100 dark:border-gray-700 pt-8 mt-4">
                    @if (ShowSuccess)
                    {
                        <div class="mb-6 bg-green-50 dark:bg-green-900 dark:bg-opacity-20 border-l-4 border-green-500 p-4 rounded-r-lg">
                            <div class="flex">
                                <div class="flex-shrink-0"><i class="fas fa-check-circle text-green-500"></i></div>
                                <div class="ml-3"><p class="text-sm font-medium text-green-800 dark:text-green-200">Profile updated successfully.</p></div>
                                <button @onclick="() => ShowSuccess = false" class="ml-auto text-green-500 hover:text-green-700"><i class="fas fa-times"></i></button>
                            </div>
                        </div>
                    }

                    <div class="grid grid-cols-1 gap-y-8 sm:grid-cols-2 sm:gap-x-12">
                        <div class="space-y-1">
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider">Username</label>
                            <div class="flex items-center mt-1 bg-gray-50 dark:bg-gray-900 rounded-lg px-4 py-2.5 border border-gray-200 dark:border-gray-700 text-gray-500 dark:text-gray-400">
                                <i class="fas fa-user-lock mr-3 text-gray-400"></i>
                                <span class="text-sm font-medium">@CurrentUser.Username</span>
                            </div>
                            <p class="text-[10px] text-gray-400 italic mt-1">Username cannot be changed</p>
                        </div>

                        <div class="space-y-1">
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider">Email Address</label>
                            <div class="relative mt-1">
                                <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-400"><i class="fas fa-envelope"></i></span>
                                <input type="email" @bind="CurrentUser.Email" class="block w-full pl-11 pr-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white sm:text-sm transition shadow-sm" />
                            </div>
                        </div>

                        <div class="space-y-1">
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider">Full Name</label>
                            <input type="text" @bind="CurrentUser.FullName" class="mt-1 block w-full px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white sm:text-sm transition shadow-sm" />
                        </div>

                        <div class="space-y-1">
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider">Change Password</label>
                            <div class="relative mt-1">
                                <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-gray-400"><i class="fas fa-key"></i></span>
                                <input type="password" @bind="NewPassword" placeholder="New password (leave blank to keep)" class="block w-full pl-11 pr-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white sm:text-sm transition shadow-sm" />
                            </div>
                        </div>
                    </div>

                    <div class="mt-12 flex justify-center md:justify-end border-t border-gray-100 dark:border-gray-700 pt-8">
                        <button type="button" @onclick="SaveProfile" class="inline-flex items-center justify-center py-3 px-10 border border-transparent shadow-lg text-base font-bold rounded-xl text-white bg-blue-600 hover:bg-blue-700 focus:ring-4 focus:ring-blue-300 transition transform hover:-translate-y-1 active:scale-95">
                            <i class="fas fa-save mr-2"></i> Save Profile Settings
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private User? CurrentUser;
    private string NewPassword = "";
    private bool ShowSuccess = false;
    private bool IsUploading = false;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var username = authState.User.Identity?.Name;
        
        if (!string.IsNullOrEmpty(username))
        {
            CurrentUser = await DbContext.Users.FirstOrDefaultAsync(u => u.Username == username);
        }
    }

    private async Task HandleAvatarUpload(InputFileChangeEventArgs e)
    {
        if (CurrentUser == null) return;
        
        IsUploading = true;
        try
        {
            var file = e.File;
            var maxFileSize = 5 * 1024 * 1024; // 5 MB
            using var stream = file.OpenReadStream(maxFileSize);
            var filePath = await StorageService.SaveFileAsync(stream, file.Name);
            CurrentUser.AvatarUrl = filePath;
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally { IsUploading = false; }
    }

    private async Task SaveProfile()
    {
        if (CurrentUser != null)
        {
            if (!string.IsNullOrWhiteSpace(NewPassword))
            {
                CurrentUser.PasswordHash = NewPassword;
            }

            DbContext.Users.Update(CurrentUser);
            await DbContext.SaveChangesAsync();
            
            NewPassword = "";
            ShowSuccess = true;
            _ = Task.Delay(3000).ContinueWith(_ => { ShowSuccess = false; InvokeAsync(StateHasChanged); });
        }
    }
}