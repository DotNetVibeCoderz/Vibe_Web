@page "/directory"
@using Intranet.Data
@using Intranet.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext
@inject NavigationManager NavManager

<PageTitle>Employee Directory</PageTitle>

<div class="mb-6 flex flex-col sm:flex-row justify-between items-start sm:items-center space-y-4 sm:space-y-0">
    <h2 class="text-2xl font-bold text-gray-800 dark:text-white">Employee Directory</h2>
    <div class="flex w-full sm:w-auto space-x-2">
        <div class="relative w-full sm:w-64">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3">
                <i class="fas fa-search text-gray-400"></i>
            </span>
            <input type="text" @bind="SearchQuery" @bind:event="oninput" placeholder="Search employees..." class="w-full pl-10 pr-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
        </div>
        <select @bind="SelectedDepartment" class="border border-gray-300 dark:border-gray-600 rounded-lg px-4 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-blue-500 focus:border-blue-500">
            <option value="">All Departments</option>
            @foreach (var dept in Departments)
            {
                <option value="@dept">@dept</option>
            }
        </select>
    </div>
</div>

@if (FilteredUsers == null)
{
    <div class="flex justify-center py-10">
        <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-blue-600"></div>
    </div>
}
else if (!FilteredUsers.Any())
{
    <div class="bg-white dark:bg-gray-800 p-8 rounded-lg shadow text-center text-gray-500 dark:text-gray-400">
        <i class="fas fa-users-slash text-4xl mb-4"></i>
        <p>No employees found matching your criteria.</p>
    </div>
}
else
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        @foreach (var user in FilteredUsers)
        {
            <div class="bg-white dark:bg-gray-800 rounded-lg shadow-md border border-gray-200 dark:border-gray-700 hover:shadow-lg transition overflow-hidden">
                <div class="h-24 bg-gradient-to-r from-blue-400 to-indigo-500"></div>
                <div class="px-6 pb-6 relative">
                    <img src="@user.AvatarUrl" alt="@user.FullName" class="w-20 h-20 rounded-full border-4 border-white dark:border-gray-800 mx-auto -mt-10 mb-4 bg-white" />
                    <div class="text-center">
                        <h3 class="text-lg font-semibold text-gray-900 dark:text-white">@user.FullName</h3>
                        <p class="text-sm text-blue-600 dark:text-blue-400 font-medium">@user.JobTitle</p>
                        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">@user.Department</p>
                    </div>
                    <div class="mt-4 pt-4 border-t border-gray-200 dark:border-gray-700 flex justify-center space-x-3">
                        <a href="mailto:@user.Email" class="p-2 text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 bg-gray-100 dark:bg-gray-700 rounded-full transition" title="Email">
                            <i class="fas fa-envelope"></i>
                        </a>
                        <button @onclick="() => NavigateToChat(user.Username)" class="p-2 text-gray-500 hover:text-green-600 dark:text-gray-400 dark:hover:text-green-400 bg-gray-100 dark:bg-gray-700 rounded-full transition" title="Message">
                            <i class="fas fa-comment"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<User>? AllUsers;
    private List<string> Departments = new();
    
    private string _searchQuery = "";
    private string SearchQuery
    {
        get => _searchQuery;
        set { _searchQuery = value; FilterData(); }
    }

    private string _selectedDepartment = "";
    private string SelectedDepartment
    {
        get => _selectedDepartment;
        set { _selectedDepartment = value; FilterData(); }
    }

    private IEnumerable<User>? FilteredUsers;

    protected override async Task OnInitializedAsync()
    {
        AllUsers = await DbContext.Users.Where(u => u.IsActive).OrderBy(u => u.FullName).ToListAsync();
        Departments = AllUsers.Select(u => u.Department).Where(d => !string.IsNullOrEmpty(d)).Distinct().OrderBy(d => d).ToList();
        FilterData();
    }

    private void FilterData()
    {
        if (AllUsers == null) return;

        var query = AllUsers.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(SearchQuery))
        {
            query = query.Where(u => u.FullName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) || 
                                     u.JobTitle.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(SelectedDepartment))
        {
            query = query.Where(u => u.Department == SelectedDepartment);
        }

        FilteredUsers = query.ToList();
    }

    private void NavigateToChat(string username)
    {
        NavManager.NavigateTo($"/chat/{username}");
    }
}