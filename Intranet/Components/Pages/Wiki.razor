@page "/wiki"
@using Intranet.Data
@using Intranet.Models
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext
@inject AuthenticationStateProvider AuthState

<PageTitle>Knowledge Base / Wiki</PageTitle>

<div class="flex flex-col md:flex-row gap-8">
    <div class="w-full md:w-1/4 bg-white dark:bg-gray-800 rounded-lg shadow border border-gray-200 dark:border-gray-700 p-4 h-fit sticky top-24">
        <h3 class="font-bold text-lg text-gray-900 dark:text-white mb-4 border-b border-gray-200 dark:border-gray-700 pb-2">Wiki Articles</h3>
        
        <div class="mb-4">
            <input type="text" placeholder="Filter articles..." @bind="FilterText" @bind:event="oninput" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md focus:ring-blue-500 focus:border-blue-500 bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white text-sm" />
        </div>

        <ul class="space-y-2">
            @if (FilteredArticles != null)
            {
                @foreach (var article in FilteredArticles)
                {
                    <li>
                        <button @onclick="() => SelectArticle(article)" class="w-full text-left px-3 py-2 rounded-md hover:bg-gray-100 dark:hover:bg-gray-700 text-sm font-medium @(SelectedArticle?.Id == article.Id ? "bg-blue-50 text-blue-600 dark:bg-gray-700 dark:text-blue-400" : "text-gray-700 dark:text-gray-300")">
                            @article.Title
                        </button>
                    </li>
                }
            }
        </ul>
        @if (IsAdminOrCreator)
        {
            <button @onclick="OpenAddModal" class="w-full mt-6 bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded shadow text-sm flex items-center justify-center transition">
                <i class="fas fa-plus mr-2"></i> Create Article
            </button>
        }
    </div>

    <div class="w-full md:w-3/4">
        @if (SelectedArticle == null)
        {
            <div class="bg-white dark:bg-gray-800 p-12 rounded-lg shadow text-center text-gray-500 dark:text-gray-400 border border-gray-200 dark:border-gray-700">
                <i class="fas fa-book-open text-6xl mb-4 text-blue-200 dark:text-blue-900"></i>
                <h3 class="text-xl font-bold text-gray-700 dark:text-gray-300 mb-2">Welcome to the Knowledge Base</h3>
                <p>Select an article from the index on the left to start reading, or create a new one to share your knowledge with the team.</p>
            </div>
        }
        else
        {
            <div class="bg-white dark:bg-gray-800 p-8 rounded-lg shadow border border-gray-200 dark:border-gray-700">
                <div class="flex justify-between items-start mb-6">
                    <div>
                        <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-2">@SelectedArticle.Title</h2>
                        <div class="text-sm text-gray-500 dark:text-gray-400 flex items-center space-x-4">
                            <span><i class="far fa-user mr-1"></i> @SelectedArticle.Author</span>
                            <span><i class="far fa-calendar-alt mr-1"></i> Last updated: @SelectedArticle.UpdatedAt.ToString("MMM dd, yyyy")</span>
                        </div>
                    </div>
                    @if (IsAdminOrCreator)
                    {
                        <div class="flex space-x-2">
                            <button @onclick="() => OpenEditModal(SelectedArticle)" class="text-gray-500 hover:text-blue-600 dark:text-gray-400 dark:hover:text-blue-400 transition" title="Edit Article"><i class="fas fa-edit text-xl"></i></button>
                            <button @onclick="() => DeleteArticle(SelectedArticle)" class="text-gray-500 hover:text-red-600 dark:text-gray-400 dark:hover:text-red-400 transition" title="Delete Article"><i class="fas fa-trash text-xl"></i></button>
                        </div>
                    }
                </div>

                <div class="prose dark:prose-invert max-w-none text-gray-800 dark:text-gray-200">
                    @((MarkupString)SelectedArticle.Content)
                </div>
            </div>
        }
    </div>
</div>

@if (IsModalOpen)
{
    <div class="fixed z-50 inset-0 overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" @onclick="CloseModal"></div>
            <span class="hidden sm:inline-block sm:align-middle sm:h-screen">&#8203;</span>
            <div class="inline-block align-bottom bg-white dark:bg-gray-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-5xl sm:w-full">
                <div class="bg-white dark:bg-gray-800 px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                    <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-white mb-4">@(EditingArticle.Id == 0 ? "Create Article" : "Edit Article")</h3>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Title</label>
                            <input type="text" @bind="EditingArticle.Title" class="mt-1 block w-full border border-gray-300 dark:border-gray-600 rounded-md py-2 px-3 focus:ring-blue-500 focus:border-blue-500 sm:text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-white" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Content (Rich Text)</label>
                            <RichTextEditor @ref="HtmlEditor" Content="@EditingArticle.Content" />
                        </div>
                    </div>
                </div>
                <div class="bg-gray-50 dark:bg-gray-700 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                    <button type="button" @onclick="SaveArticle" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 sm:ml-3 sm:w-auto sm:text-sm">Save</button>
                    <button type="button" @onclick="CloseModal" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 dark:border-gray-600 shadow-sm px-4 py-2 bg-white dark:bg-gray-800 text-base font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<WikiArticle>? Articles;
    private IEnumerable<WikiArticle>? FilteredArticles;
    private WikiArticle? SelectedArticle;
    private bool IsAdminOrCreator = false;
    private bool IsModalOpen = false;
    private WikiArticle EditingArticle = new();
    private string CurrentUser = "Anonymous";
    private RichTextEditor HtmlEditor = default!;

    private string _filterText = "";
    private string FilterText
    {
        get => _filterText;
        set { _filterText = value; ApplyFilter(); }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var role = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
        IsAdminOrCreator = (role == "admin" || role == "creator");
        if (authState.User.Identity?.IsAuthenticated == true) CurrentUser = authState.User.Identity.Name ?? "User";

        await LoadData();
        SelectedArticle = Articles?.FirstOrDefault();
    }

    private async Task LoadData()
    {
        Articles = await DbContext.WikiArticles.OrderBy(a => a.Title).ToListAsync();
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (Articles == null) return;
        if (string.IsNullOrWhiteSpace(FilterText)) FilteredArticles = Articles;
        else FilteredArticles = Articles.Where(a => a.Title.Contains(FilterText, StringComparison.OrdinalIgnoreCase));
    }

    private void SelectArticle(WikiArticle article) { SelectedArticle = article; }

    private void OpenAddModal() { EditingArticle = new WikiArticle(); IsModalOpen = true; }
    private void OpenEditModal(WikiArticle a) { EditingArticle = new WikiArticle { Id = a.Id, Title = a.Title, Content = a.Content }; IsModalOpen = true; }
    private void CloseModal() { IsModalOpen = false; }

    private async Task SaveArticle()
    {
        EditingArticle.Content = await HtmlEditor.GetHtml();

        if (string.IsNullOrWhiteSpace(EditingArticle.Title)) return;

        if (EditingArticle.Id == 0)
        {
            EditingArticle.CreatedAt = DateTime.UtcNow;
            EditingArticle.UpdatedAt = DateTime.UtcNow;
            EditingArticle.Author = CurrentUser;
            DbContext.WikiArticles.Add(EditingArticle);
        }
        else
        {
            var a = await DbContext.WikiArticles.FindAsync(EditingArticle.Id);
            if (a != null)
            {
                a.Title = EditingArticle.Title;
                a.Content = EditingArticle.Content;
                a.UpdatedAt = DateTime.UtcNow;
                a.Author = CurrentUser;
                DbContext.WikiArticles.Update(a);
            }
        }
        await DbContext.SaveChangesAsync();
        await LoadData();
        SelectedArticle = Articles?.FirstOrDefault(x => x.Title == EditingArticle.Title);
        CloseModal();
    }

    private async Task DeleteArticle(WikiArticle a)
    {
        DbContext.WikiArticles.Remove(a);
        await DbContext.SaveChangesAsync();
        await LoadData();
        SelectedArticle = Articles?.FirstOrDefault();
    }
}