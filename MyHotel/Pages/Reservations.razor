@page "/reservations"
@using MyHotel.Data
@using MyHotel.Models
@using Microsoft.EntityFrameworkCore
@using MyHotel.Pages.Dialogs
@using System.Text
@inject AppDbContext DbContext
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime

<PageTitle>Reservations</PageTitle>

<MudText Typo="Typo.h3" Class="mb-4">Reservations</MudText>

<MudDataGrid T="Reservation" Items="@ReservationsList" Filterable="true" SortMode="SortMode.Multiple" QuickFilter="@quickFilter">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Reservation List</MudText>
        <MudSpacer />
        <MudTextField @bind-Value="searchString" Placeholder="Search by Guest or Room..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0 mr-4"></MudTextField>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddDialog" Class="mr-2">Add New</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Download" OnClick="ExportCsv">Export CSV</MudButton>
    </ToolBarContent>
    <Columns>
        <PropertyColumn Property="x => x.Guest.FirstName" Title="Guest" />
        <PropertyColumn Property="x => x.Room.Number" Title="Room" />
        <PropertyColumn Property="x => x.CheckInDate" Title="Check In" Format="dd MMM yyyy" />
        <PropertyColumn Property="x => x.CheckOutDate" Title="Check Out" Format="dd MMM yyyy" />
        <PropertyColumn Property="x => x.TotalAmount" Title="Total Amount" Format="C0" />
        <PropertyColumn Property="x => x.Status" Title="Status">
            <CellTemplate>
                <MudChip T="string" Color="@GetStatusColor(context.Item.Status)" Size="Size.Small">@context.Item.Status</MudChip>
            </CellTemplate>
        </PropertyColumn>
        <TemplateColumn CellClass="d-flex justify-end">
            <CellTemplate>
                <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" OnClick="@(() => Edit(context.Item))" />
                <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" Color="Color.Error" OnClick="@(() => Delete(context.Item))" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <PagerContent>
        <MudDataGridPager T="Reservation" />
    </PagerContent>
</MudDataGrid>

@code {
    List<Reservation> ReservationsList = new();
    string searchString = "";

    Func<Reservation, bool> quickFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(searchString)) return true;
        if (x.Guest?.FirstName.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.Guest?.LastName.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.Room?.Number.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true) return true;
        if (x.Status.Contains(searchString, StringComparison.OrdinalIgnoreCase)) return true;
        return false;
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {
        ReservationsList = await DbContext.Reservations
            .Include(r => r.Guest)
            .Include(r => r.Room)
            .ToListAsync();
    }

    Color GetStatusColor(string status)
    {
        return status switch
        {
            "Confirmed" => Color.Success,
            "CheckedIn" => Color.Info,
            "CheckedOut" => Color.Dark,
            "Cancelled" => Color.Error,
            _ => Color.Default
        };
    }

    async Task OpenAddDialog()
    {
        var guests = await DbContext.Guests.ToListAsync();
        var rooms = await DbContext.Rooms.ToListAsync();
        
        var options = new DialogOptions { CloseOnEscapeKey = true, FullWidth = true };
        var parameters = new DialogParameters { ["Guests"] = guests, ["Rooms"] = rooms };
        
        var dialog = await DialogService.ShowAsync<ReservationDialog>("Add Reservation", parameters, options);
        var result = await dialog.Result;
        
        if (result != null && !result.Canceled && result.Data is Reservation newRes)
        {
            DbContext.Reservations.Add(newRes);
            await DbContext.SaveChangesAsync();
            await LoadData();
            Snackbar.Add("Reservation added", Severity.Success);
        }
    }

    async Task Edit(Reservation res)
    {
        var guests = await DbContext.Guests.ToListAsync();
        var rooms = await DbContext.Rooms.ToListAsync();
        
        var editModel = new Reservation 
        { 
            Id = res.Id, GuestId = res.GuestId, RoomId = res.RoomId, 
            CheckInDate = res.CheckInDate, CheckOutDate = res.CheckOutDate, 
            Status = res.Status, TotalAmount = res.TotalAmount 
        };
        
        var parameters = new DialogParameters { ["Model"] = editModel, ["Guests"] = guests, ["Rooms"] = rooms };
        var dialog = await DialogService.ShowAsync<ReservationDialog>("Edit Reservation", parameters);
        var result = await dialog.Result;
        
        if (result != null && !result.Canceled && result.Data is Reservation updated)
        {
            var entity = await DbContext.Reservations.FindAsync(updated.Id);
            if(entity != null){
                entity.GuestId = updated.GuestId;
                entity.RoomId = updated.RoomId;
                entity.CheckInDate = updated.CheckInDate;
                entity.CheckOutDate = updated.CheckOutDate;
                entity.Status = updated.Status;
                entity.TotalAmount = updated.TotalAmount;
                await DbContext.SaveChangesAsync();
                await LoadData();
                Snackbar.Add("Reservation updated", Severity.Success);
            }
        }
    }

    async Task Delete(Reservation res)
    {
        bool? result = await DialogService.ShowMessageBoxAsync(
            "Warning", 
            $"Are you sure you want to delete this reservation?", 
            yesText: "Delete", cancelText: "Cancel");
            
        if (result == true)
        {
            DbContext.Reservations.Remove(res);
            await DbContext.SaveChangesAsync();
            await LoadData();
            Snackbar.Add("Reservation deleted", Severity.Success);
        }
    }

    async Task ExportCsv()
    {
        var sb = new StringBuilder();
        sb.AppendLine("GuestName,RoomNumber,CheckInDate,CheckOutDate,Status,TotalAmount");
        foreach (var item in ReservationsList)
        {
            var guestName = $"{item.Guest?.FirstName} {item.Guest?.LastName}";
            var roomNum = item.Room?.Number;
            sb.AppendLine($"{guestName},{roomNum},{item.CheckInDate:yyyy-MM-dd},{item.CheckOutDate:yyyy-MM-dd},{item.Status},{item.TotalAmount}");
        }
        await JSRuntime.InvokeVoidAsync("downloadFile", "Reservations.csv", "text/csv", sb.ToString());
    }
}