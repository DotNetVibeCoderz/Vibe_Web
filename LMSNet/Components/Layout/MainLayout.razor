@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<div class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-64 bg-gray-800 text-white flex-shrink-0 flex flex-col">
        <div class="h-16 flex items-center justify-center font-bold text-xl border-b border-gray-700 tracking-wide">
            <span class="text-blue-500 mr-2"><i class="fas fa-graduation-cap"></i></span> LMS<span class="text-gray-400">Net</span>
        </div>
        <nav class="flex-1 overflow-y-auto py-4 space-y-1">
            <NavLink href="/" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-700 hover:text-white transition-colors" Match="NavLinkMatch.All">
                <i class="fas fa-home w-5 mr-3"></i> Dashboard
            </NavLink>
            <NavLink href="/courses" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
                <i class="fas fa-book w-5 mr-3"></i> Courses
            </NavLink>
            <NavLink href="/my-learning" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
                <i class="fas fa-chalkboard-teacher w-5 mr-3"></i> My Learning
            </NavLink>
            
            <AuthorizeView Roles="admin,mentor,creator">
                <div class="px-6 py-2 mt-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Instructor</div>
                <NavLink href="/instructor/courses" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
                    <i class="fas fa-laptop-code w-5 mr-3"></i> Manage Courses
                </NavLink>
                <NavLink href="/instructor/students" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
                    <i class="fas fa-users w-5 mr-3"></i> Students
                </NavLink>
            </AuthorizeView>

            <AuthorizeView Roles="admin">
                <div class="px-6 py-2 mt-4 text-xs font-semibold text-gray-500 uppercase tracking-wider">Admin</div>
                <NavLink href="/admin/users" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
                    <i class="fas fa-user-shield w-5 mr-3"></i> Users Management
                </NavLink>
                <NavLink href="/admin/master-data" class="flex items-center px-6 py-3 text-gray-300 hover:bg-gray-700 hover:text-white transition-colors">
                    <i class="fas fa-database w-5 mr-3"></i> Master Data
                </NavLink>
            </AuthorizeView>
        </nav>
        <div class="p-4 border-t border-gray-700">
             <button @onclick="ToggleTheme" class="flex items-center w-full px-4 py-2 text-sm text-gray-300 hover:bg-gray-700 rounded transition-colors">
                 <i class="fas fa-moon w-5 mr-2"></i> Toggle Theme
             </button>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="flex-1 flex flex-col overflow-hidden relative">
        <!-- Header -->
        <header class="h-16 bg-white dark:bg-gray-800 shadow-sm flex items-center justify-between px-6 z-10 border-b border-gray-200 dark:border-gray-700">
            <div class="flex-1">
                <!-- Global Search -->
                <div class="relative w-64">
                    <input type="text" @bind="searchText" @onkeyup="HandleSearch" class="w-full bg-gray-100 dark:bg-gray-700 border-none rounded-full py-2 pl-10 pr-4 focus:ring-2 focus:ring-blue-500 dark:text-gray-200" placeholder="Search courses..." />
                    <i class="fas fa-search absolute left-4 top-3 text-gray-400"></i>
                </div>
            </div>
            
            <div class="flex items-center space-x-4">
                <AuthorizeView>
                    <Authorized>
                        <div class="relative group cursor-pointer flex items-center space-x-2">
                            <img src="https://ui-avatars.com/api/?name=@context.User.Identity?.Name&background=0D8ABC&color=fff" class="w-8 h-8 rounded-full" />
                            <span class="text-sm font-medium">@context.User.Identity?.Name</span>
                            <i class="fas fa-chevron-down text-xs text-gray-500"></i>
                            
                            <div class="absolute right-0 top-10 w-48 bg-white dark:bg-gray-800 rounded-md shadow-lg py-1 hidden group-hover:block border border-gray-200 dark:border-gray-700">
                                <a href="/profile" class="block px-4 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700">Profile</a>
                                <div class="border-t border-gray-100 dark:border-gray-700"></div>
                                <form action="Account/Logout" method="post">
                                    <button type="submit" class="block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-gray-100 dark:hover:bg-gray-700">Logout</button>
                                </form>
                            </div>
                        </div>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/Account/Login" class="text-gray-600 dark:text-gray-300 hover:text-blue-500 font-medium text-sm">Log in</a>
                        <a href="/Account/Register" class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 font-medium text-sm transition-colors">Sign up</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </header>

        <!-- Main Workspace -->
        <main class="flex-1 overflow-x-hidden overflow-y-auto bg-gray-50 dark:bg-gray-900 p-6">
            @Body
        </main>
    </div>
</div>

@code {
    [Inject] IJSRuntime JSRuntime { get; set; } = default!;
    
    private string searchText = "";

    private async Task ToggleTheme()
    {
        await JSRuntime.InvokeVoidAsync("toggleDarkMode");
    }

    private void HandleSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(searchText))
        {
            NavigationManager.NavigateTo($"/courses?q={Uri.EscapeDataString(searchText)}");
            searchText = "";
        }
    }
}
