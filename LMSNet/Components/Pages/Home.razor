@page "/"
@page "/dashboard"
@using LMSNet.Data
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@attribute [Authorize]

<PageTitle>Dashboard - LMSNet</PageTitle>

<div class="space-y-6">
    <!-- Welcome Banner -->
    <div class="bg-gradient-to-r from-blue-600 to-indigo-700 rounded-xl shadow-lg p-8 text-white flex justify-between items-center relative overflow-hidden">
        <div class="relative z-10">
            <h1 class="text-3xl font-bold mb-2">Welcome back, @UserDisplayName! 👋</h1>
            <p class="text-blue-100 text-lg">You have @EnrolledCount courses in progress.</p>
            @if (RecentEnrollment != null)
            {
                <button @onclick="() => NavigateToLearning(RecentEnrollment.CourseId)" class="mt-6 bg-white text-blue-600 px-6 py-2 rounded-full font-semibold hover:bg-gray-50 transition-colors shadow-md">
                    Resume Learning
                </button>
            }
        </div>
        <div class="hidden md:block absolute right-0 bottom-0 opacity-20 pointer-events-none">
             <i class="fas fa-graduation-cap text-9xl -mb-8 mr-8 transform -rotate-12"></i>
        </div>
    </div>

    <!-- Stats Section -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700 flex items-center space-x-4">
            <div class="p-3 bg-blue-100 text-blue-600 rounded-lg">
                <i class="fas fa-book-open text-xl"></i>
            </div>
            <div>
                <p class="text-sm text-gray-500 dark:text-gray-400 font-medium">Enrolled Courses</p>
                <p class="text-2xl font-bold text-gray-800 dark:text-white">@EnrolledCount</p>
            </div>
        </div>
        
        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700 flex items-center space-x-4">
            <div class="p-3 bg-green-100 text-green-600 rounded-lg">
                <i class="fas fa-check-circle text-xl"></i>
            </div>
            <div>
                <p class="text-sm text-gray-500 dark:text-gray-400 font-medium">Completed</p>
                <p class="text-2xl font-bold text-gray-800 dark:text-white">@CompletedCount</p>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700 flex items-center space-x-4">
            <div class="p-3 bg-yellow-100 text-yellow-600 rounded-lg">
                <i class="fas fa-medal text-xl"></i>
            </div>
            <div>
                <p class="text-sm text-gray-500 dark:text-gray-400 font-medium">Certificates</p>
                <p class="text-2xl font-bold text-gray-800 dark:text-white">@CompletedCount</p>
            </div>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700 flex items-center space-x-4">
            <div class="p-3 bg-purple-100 text-purple-600 rounded-lg">
                <i class="fas fa-clock text-xl"></i>
            </div>
            <div>
                <p class="text-sm text-gray-500 dark:text-gray-400 font-medium">Avg. Progress</p>
                <p class="text-2xl font-bold text-gray-800 dark:text-white">@AvgProgress%</p>
            </div>
        </div>
    </div>

    <!-- Recent Courses -->
    <div>
        <div class="flex justify-between items-center mb-4">
            <h2 class="text-xl font-bold text-gray-800 dark:text-white">Continue Learning</h2>
            <a href="/my-learning" class="text-blue-500 hover:text-blue-600 text-sm font-medium">View All <i class="fas fa-arrow-right ml-1"></i></a>
        </div>
        
        @if (RecentEnrollments == null || !RecentEnrollments.Any())
        {
            <div class="text-center py-10 bg-white dark:bg-gray-800 rounded-xl border border-dashed border-gray-300 dark:border-gray-700">
                <p class="text-gray-500 dark:text-gray-400">You haven't enrolled in any courses yet.</p>
                <a href="/courses" class="text-blue-500 mt-2 inline-block font-medium">Browse Catalog</a>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                @foreach(var enrollment in RecentEnrollments)
                {
                    <div @onclick="() => NavigateToLearning(enrollment.CourseId)" class="bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-sm border border-gray-100 dark:border-gray-700 hover:shadow-md transition-shadow group cursor-pointer">
                        <div class="h-40 bg-gray-200 dark:bg-gray-700 relative">
                            <img src="@(string.IsNullOrEmpty(enrollment.Course.ThumbnailUrl) ? "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?ixlib=rb-1.2.1&auto=format&fit=crop&w=800&q=80" : enrollment.Course.ThumbnailUrl)" alt="@enrollment.Course.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                            <div class="absolute inset-0 bg-black bg-opacity-40 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                <i class="fas fa-play-circle text-white text-4xl"></i>
                            </div>
                        </div>
                        <div class="p-5">
                            <h3 class="text-lg font-bold text-gray-800 dark:text-white mb-2 line-clamp-2">@enrollment.Course.Title</h3>
                            
                            <!-- Progress Bar -->
                            <div class="mb-2 flex justify-between text-xs text-gray-500 dark:text-gray-400 font-medium">
                                <span>@enrollment.ProgressPercentage% Complete</span>
                            </div>
                            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2 mb-4">
                                <div class="bg-blue-600 h-2 rounded-full" style="width: @enrollment.ProgressPercentage%"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState { get; set; }
    
    private string UserDisplayName { get; set; } = "Student";
    private int EnrolledCount = 0;
    private int CompletedCount = 0;
    private int AvgProgress = 0;
    private List<Enrollment>? RecentEnrollments;
    private Enrollment? RecentEnrollment;

    protected override async Task OnInitializedAsync()
    {
        if (authenticationState is not null)
        {
            var authState = await authenticationState;
            var user = authState?.User;

            if (user?.Identity is not null && user.Identity.IsAuthenticated)
            {
                UserDisplayName = user.FindFirst("FirstName")?.Value ?? user.Identity.Name ?? "Student";
                var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                
                if (!string.IsNullOrEmpty(userId))
                {
                    var enrollments = await DbContext.Enrollments
                        .Include(e => e.Course)
                        .Where(e => e.StudentId == userId)
                        .ToListAsync();
                        
                    EnrolledCount = enrollments.Count;
                    CompletedCount = enrollments.Count(e => e.ProgressPercentage >= 100);
                    AvgProgress = enrollments.Any() ? (int)enrollments.Average(e => e.ProgressPercentage) : 0;
                    
                    RecentEnrollments = enrollments.OrderByDescending(e => e.EnrolledAt).Take(3).ToList();
                    RecentEnrollment = RecentEnrollments.FirstOrDefault();
                }
            }
        }
    }

    private void NavigateToLearning(int courseId)
    {
        NavigationManager.NavigateTo($"/learning/{courseId}");
    }
}