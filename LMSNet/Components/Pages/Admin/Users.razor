@page "/admin/users"
@using LMSNet.Data
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using System.ComponentModel.DataAnnotations
@inject ApplicationDbContext DbContext
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@attribute [Authorize(Roles = "admin")]

<PageTitle>User Management - LMSNet</PageTitle>

<div class="space-y-6">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold text-gray-800 dark:text-white">User Management</h1>
        <button @onclick="ShowAddUserModal" class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 font-medium text-sm transition-colors shadow-sm flex items-center">
            <i class="fas fa-user-plus mr-2"></i> Add User
        </button>
    </div>

    <!-- Filters & Search -->
    <div class="bg-white dark:bg-gray-800 p-4 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 mb-6 flex flex-wrap gap-4 items-center justify-between">
        <div class="flex items-center space-x-4 flex-1">
            <div class="relative w-full max-w-md">
                <input type="text" @bind="SearchTerm" @bind:event="oninput" placeholder="Search by name, email..." class="w-full bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md py-2 pl-10 pr-4 focus:ring-2 focus:ring-blue-500 dark:text-gray-200 text-sm" />
                <i class="fas fa-search absolute left-3 top-3 text-gray-400"></i>
            </div>
            
            <select @bind="SelectedRole" class="bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md py-2 px-4 focus:ring-2 focus:ring-blue-500 dark:text-gray-200 text-sm">
                <option value="">All Roles</option>
                <option value="admin">Admin</option>
                <option value="mentor">Mentor</option>
                <option value="student">Student</option>
                <option value="creator">Creator</option>
            </select>
            
            <select @bind="SelectedStatus" class="bg-gray-50 dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md py-2 px-4 focus:ring-2 focus:ring-blue-500 dark:text-gray-200 text-sm">
                <option value="">All Status</option>
                <option value="active">Active</option>
                <option value="inactive">Inactive</option>
            </select>
        </div>
    </div>

    <!-- Users Table -->
    <div class="bg-white dark:bg-gray-800 shadow-sm rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-800">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">User</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Registered Date</th>
                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-800">
                    @if (FilteredUsers == null)
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-4 text-center text-sm text-gray-500 dark:text-gray-400">Loading users...</td>
                        </tr>
                    }
                    else if (!FilteredUsers.Any())
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-4 text-center text-sm text-gray-500 dark:text-gray-400">No users found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var userWithRole in FilteredUsers)
                        {
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 h-10 w-10">
                                            <img class="h-10 w-10 rounded-full object-cover" src="https://ui-avatars.com/api/?name=@(userWithRole.User.FirstName + "+" + userWithRole.User.LastName)&background=random" alt="" />
                                        </div>
                                        <div class="ml-4">
                                            <div class="text-sm font-medium text-gray-900 dark:text-white">@(userWithRole.User.FirstName) @(userWithRole.User.LastName)</div>
                                            <div class="text-sm text-gray-500 dark:text-gray-400">@userWithRole.User.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex flex-wrap gap-1">
                                        @if(userWithRole.Roles != null && userWithRole.Roles.Any())
                                        {
                                            foreach(var role in userWithRole.Roles)
                                            {
                                                var bgClass = role == "admin" ? "bg-red-100 text-red-800" :
                                                              role == "mentor" ? "bg-purple-100 text-purple-800" :
                                                              role == "creator" ? "bg-blue-100 text-blue-800" :
                                                              "bg-green-100 text-green-800";
                                                
                                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full @bgClass">
                                                    @role
                                                </span>
                                            }
                                        }
                                        else
                                        {
                                            <span class="text-sm text-gray-500 italic">None</span>
                                        }
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                                    @userWithRole.User.RegisteredAt.ToString("MMM dd, yyyy")
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <button @onclick="() => EditUser(userWithRole)" class="text-blue-600 hover:text-blue-900 mr-3" title="Edit Roles"><i class="fas fa-user-edit"></i></button>
                                    <button @onclick="() => DeleteUser(userWithRole.User)" class="text-red-600 hover:text-red-900" title="Delete"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Form -->
@if (isModalVisible)
{
    <div class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full z-50 flex items-center justify-center">
        <div class="relative bg-white dark:bg-gray-800 rounded-lg shadow-xl border border-gray-200 dark:border-gray-700 w-full max-w-md mx-4">
            <div class="flex justify-between items-center p-4 border-b border-gray-200 dark:border-gray-700">
                <h3 class="text-lg font-bold text-gray-900 dark:text-white">@(isEditing ? "Edit User Roles" : "Add New User")</h3>
                <button @onclick="CloseModal" class="text-gray-400 hover:text-gray-500 dark:hover:text-white">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            
            <div class="p-4">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="mb-4 bg-red-50 border-l-4 border-red-500 p-2 text-sm text-red-700">@errorMessage</div>
                }

                @if (isEditing)
                {
                    <div class="mb-4 text-gray-700 dark:text-gray-300">
                        Editing roles for <span class="font-bold">@UserModel.Email</span>
                    </div>
                    
                    <div class="space-y-2 mb-6">
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Roles</label>
                        @foreach (var role in AvailableRoles)
                        {
                            <div class="flex items-center">
                                <input type="checkbox" id="role_@role" checked="@SelectedRoles.Contains(role)" @onchange="@((ChangeEventArgs e) => ToggleRole(role, e.Value))" class="h-4 w-4 text-blue-600 rounded border-gray-300" />
                                <label for="role_@role" class="ml-2 text-sm text-gray-700 dark:text-gray-300 capitalize">@role</label>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <EditForm Model="UserModel" OnValidSubmit="SaveUser" id="addUserForm">
                        <DataAnnotationsValidator />
                        
                        <div class="space-y-4 mb-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">First Name</label>
                                <InputText @bind-Value="UserModel.FirstName" class="w-full bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md py-2 px-3 focus:ring-2 focus:ring-blue-500 dark:text-white text-sm" />
                                <ValidationMessage For="@(() => UserModel.FirstName)" class="text-red-500 text-xs mt-1" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Last Name</label>
                                <InputText @bind-Value="UserModel.LastName" class="w-full bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md py-2 px-3 focus:ring-2 focus:ring-blue-500 dark:text-white text-sm" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Email</label>
                                <InputText @bind-Value="UserModel.Email" type="email" class="w-full bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md py-2 px-3 focus:ring-2 focus:ring-blue-500 dark:text-white text-sm" />
                                <ValidationMessage For="@(() => UserModel.Email)" class="text-red-500 text-xs mt-1" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Password</label>
                                <InputText @bind-Value="UserModel.Password" type="password" class="w-full bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md py-2 px-3 focus:ring-2 focus:ring-blue-500 dark:text-white text-sm" />
                                <ValidationMessage For="@(() => UserModel.Password)" class="text-red-500 text-xs mt-1" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Assign Role</label>
                                <select @bind="UserModel.Role" class="w-full bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-md py-2 px-3 focus:ring-2 focus:ring-blue-500 dark:text-white text-sm">
                                    @foreach (var role in AvailableRoles)
                                    {
                                        <option value="@role">@role</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </EditForm>
                }
            </div>
            
            <div class="px-4 py-3 border-t border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 flex justify-end space-x-3 rounded-b-lg">
                <button @onclick="CloseModal" class="px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-md text-gray-700 dark:text-gray-300 text-sm font-medium hover:bg-gray-100 dark:hover:bg-gray-700">
                    Cancel
                </button>
                <button @onclick="SaveUser" class="px-4 py-2 bg-blue-600 text-white rounded-md text-sm font-medium hover:bg-blue-700 flex items-center" disabled="@isSaving">
                    @if(isSaving)
                    {
                        <i class="fas fa-spinner fa-spin mr-2"></i> <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<UserWithRoles>? AppUsers;
    private string SearchTerm = string.Empty;
    private string SelectedRole = string.Empty;
    private string SelectedStatus = string.Empty;

    private IEnumerable<UserWithRoles> FilteredUsers => AppUsers?.Where(u => 
        (string.IsNullOrWhiteSpace(SearchTerm) || 
         u.User.FirstName.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) || 
         u.User.LastName.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) || 
         (u.User.Email?.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ?? false)) &&
        (string.IsNullOrWhiteSpace(SelectedRole) || u.Roles.Contains(SelectedRole))
    ) ?? Enumerable.Empty<UserWithRoles>();
    
    // Modal State
    private bool isModalVisible = false;
    private bool isEditing = false;
    private bool isSaving = false;
    private string? errorMessage;
    
    private List<string> AvailableRoles = new List<string> { "student", "mentor", "creator", "admin" };
    private HashSet<string> SelectedRoles = new HashSet<string>();
    
    private UserModelForm UserModel = new UserModelForm();
    private ApplicationUser? EditingUser;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        var allUsers = await UserManager.Users.ToListAsync();
        
        AppUsers = new List<UserWithRoles>();
        foreach (var user in allUsers)
        {
            var roles = await UserManager.GetRolesAsync(user);
            AppUsers.Add(new UserWithRoles { User = user, Roles = roles.ToList() });
        }
    }

    private void ShowAddUserModal()
    {
        isEditing = false;
        UserModel = new UserModelForm { Role = "student" };
        errorMessage = null;
        isModalVisible = true;
    }

    private void EditUser(UserWithRoles userWithRole)
    {
        isEditing = true;
        EditingUser = userWithRole.User;
        UserModel = new UserModelForm { Email = userWithRole.User.Email ?? "" };
        SelectedRoles = new HashSet<string>(userWithRole.Roles);
        errorMessage = null;
        isModalVisible = true;
    }
    
    private void ToggleRole(string role, object? isChecked)
    {
        if (isChecked is bool checkedVal)
        {
            if (checkedVal) SelectedRoles.Add(role);
            else SelectedRoles.Remove(role);
        }
    }

    private void CloseModal()
    {
        isModalVisible = false;
    }

    private async Task SaveUser()
    {
        isSaving = true;
        errorMessage = null;

        try
        {
            if (isEditing && EditingUser != null)
            {
                // Update roles
                var currentRoles = await UserManager.GetRolesAsync(EditingUser);
                await UserManager.RemoveFromRolesAsync(EditingUser, currentRoles);
                await UserManager.AddToRolesAsync(EditingUser, SelectedRoles);
            }
            else
            {
                // Add new user
                var newUser = new ApplicationUser
                {
                    UserName = UserModel.Email,
                    Email = UserModel.Email,
                    FirstName = UserModel.FirstName,
                    LastName = UserModel.LastName,
                    EmailConfirmed = true
                };

                var result = await UserManager.CreateAsync(newUser, UserModel.Password);
                
                if (result.Succeeded)
                {
                    await UserManager.AddToRoleAsync(newUser, UserModel.Role);
                }
                else
                {
                    errorMessage = string.Join(", ", result.Errors.Select(e => e.Description));
                    isSaving = false;
                    return;
                }
            }

            await LoadUsers();
            isModalVisible = false;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }
    
    private async Task DeleteUser(ApplicationUser user)
    {
        if (user.Email != "admin@lmsnet.com")
        {
            await UserManager.DeleteAsync(user);
            await LoadUsers();
        }
    }

    private class UserWithRoles
    {
        public ApplicationUser User { get; set; } = null!;
        public List<string> Roles { get; set; } = new List<string>();
    }
    
    private class UserModelForm
    {
        [Required]
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        [Required, EmailAddress]
        public string Email { get; set; } = string.Empty;
        [Required, MinLength(6)]
        public string Password { get; set; } = string.Empty;
        public string Role { get; set; } = "student";
    }
}