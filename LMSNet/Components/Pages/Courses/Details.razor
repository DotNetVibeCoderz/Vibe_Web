@page "/courses/{Id:int}"
@using LMSNet.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@inject ApplicationDbContext DbContext
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Course Details - LMSNet</PageTitle>

@if (isLoading)
{
    <div class="flex justify-center items-center py-20">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-500"></div>
    </div>
}
else if (Course == null)
{
    <div class="text-center py-20 bg-white dark:bg-gray-800 rounded-lg shadow-sm">
        <h3 class="text-xl font-medium text-gray-600 dark:text-gray-300">Course not found</h3>
        <a href="/courses" class="text-blue-500 mt-4 inline-block">Back to Courses</a>
    </div>
}
else
{
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-sm border border-gray-100 dark:border-gray-700">
                <div class="h-64 md:h-96 bg-gray-200 dark:bg-gray-700 relative">
                    <img src="@(string.IsNullOrEmpty(Course.ThumbnailUrl) ? "https://images.unsplash.com/photo-1517694712202-14dd9538aa97?ixlib=rb-1.2.1&auto=format&fit=crop&w=1200&q=80" : Course.ThumbnailUrl)" alt="@Course.Title" class="w-full h-full object-cover" />
                </div>
                <div class="p-6 md:p-8">
                    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">@Course.Title</h1>
                    
                    <div class="flex items-center space-x-4 mb-6 text-sm text-gray-500 dark:text-gray-400">
                        <div class="flex items-center">
                            <img src="https://ui-avatars.com/api/?name=@(Course.Instructor?.FirstName + "+" + Course.Instructor?.LastName)&background=random" class="w-8 h-8 rounded-full mr-2" />
                            <span class="font-medium text-gray-900 dark:text-gray-300">@(Course.Instructor?.FirstName) @(Course.Instructor?.LastName)</span>
                        </div>
                        <div><i class="fas fa-clock mr-1"></i> Last updated @(Course.UpdatedAt?.ToString("MMM yyyy") ?? Course.CreatedAt.ToString("MMM yyyy"))</div>
                        <div><i class="fas fa-globe mr-1"></i> English</div>
                    </div>

                    <div class="prose dark:prose-invert max-w-none text-gray-700 dark:text-gray-300">
                        <h3 class="text-xl font-bold mb-4">About this course</h3>
                        @((MarkupString)Course.Description)
                    </div>
                </div>
            </div>

            <!-- Course Content -->
            <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700">
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-6">Course Content</h3>
                
                @if (Course.Modules == null || !Course.Modules.Any())
                {
                    <p class="text-gray-500 dark:text-gray-400">No modules available yet.</p>
                }
                else
                {
                    <div class="space-y-4">
                        @foreach (var module in Course.Modules.OrderBy(m => m.OrderIndex))
                        {
                            <div class="border border-gray-200 dark:border-gray-700 rounded-lg overflow-hidden">
                                <div class="bg-gray-50 dark:bg-gray-700/50 px-4 py-3 flex justify-between items-center cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                                    <h4 class="font-medium text-gray-900 dark:text-white">@module.Title</h4>
                                    <span class="text-sm text-gray-500 dark:text-gray-400">@(module.Lessons.Count) lessons</span>
                                </div>
                                <div class="bg-white dark:bg-gray-800 divide-y divide-gray-100 dark:divide-gray-700">
                                    @foreach (var lesson in module.Lessons.OrderBy(l => l.OrderIndex))
                                    {
                                        <div class="px-4 py-3 flex items-center justify-between hover:bg-gray-50 dark:hover:bg-gray-700/50">
                                            <div class="flex items-center">
                                                <i class="fas @(lesson.Type == "Video" ? "fa-play-circle text-blue-500" : lesson.Type == "Quiz" ? "fa-question-circle text-purple-500" : "fa-file-alt text-green-500") mr-3"></i>
                                                <span class="text-gray-700 dark:text-gray-300 text-sm">@lesson.Title</span>
                                            </div>
                                            @if (isEnrolled)
                                            {
                                                <a href="/learning/@Course.Id/lesson/@lesson.Id" class="text-blue-500 hover:text-blue-700 text-sm">Start</a>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6">
            <div class="bg-white dark:bg-gray-800 rounded-xl p-6 shadow-sm border border-gray-100 dark:border-gray-700 sticky top-6">
                <div class="text-center mb-6">
                    <div class="text-3xl font-bold text-gray-900 dark:text-white mb-2">
                        @(Course.Price == 0 ? "Free" : $"${Course.Price:0.00}")
                    </div>
                </div>

                @if (isEnrolled)
                {
                    <div class="bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 rounded-lg p-4 mb-6 text-center">
                        <p class="text-green-700 dark:text-green-400 font-medium mb-2">You are enrolled in this course</p>
                        <a href="/learning/@Course.Id" class="inline-block w-full bg-green-600 text-white py-3 rounded-md font-bold hover:bg-green-700 transition-colors">
                            Go to Course
                        </a>
                    </div>
                }
                else
                {
                    <button @onclick="EnrollCourse" disabled="@isEnrolling" class="w-full bg-blue-600 text-white py-3 rounded-md font-bold hover:bg-blue-700 transition-colors shadow-md mb-4 flex justify-center items-center">
                        @if (isEnrolling)
                        {
                            <i class="fas fa-spinner fa-spin mr-2"></i> <span>Processing...</span>
                        }
                        else
                        {
                            <span>Enroll Now</span>
                        }
                    </button>
                    <p class="text-xs text-center text-gray-500 dark:text-gray-400 mb-6">30-Day Money-Back Guarantee</p>
                }

                <div class="space-y-4">
                    <h4 class="font-bold text-gray-900 dark:text-white border-b border-gray-200 dark:border-gray-700 pb-2">This course includes:</h4>
                    <ul class="space-y-3 text-sm text-gray-600 dark:text-gray-400">
                        <li class="flex items-center"><i class="fas fa-video w-6 text-center text-gray-400"></i> 14 hours on-demand video</li>
                        <li class="flex items-center"><i class="fas fa-file-download w-6 text-center text-gray-400"></i> 12 downloadable resources</li>
                        <li class="flex items-center"><i class="fas fa-mobile-alt w-6 text-center text-gray-400"></i> Access on mobile and TV</li>
                        <li class="flex items-center"><i class="fas fa-infinity w-6 text-center text-gray-400"></i> Full lifetime access</li>
                        <li class="flex items-center"><i class="fas fa-trophy w-6 text-center text-gray-400"></i> Certificate of completion</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Course? Course;
    private bool isLoading = true;
    private bool isEnrolled = false;
    private bool isEnrolling = false;
    private string? currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        
        if (user.Identity?.IsAuthenticated == true)
        {
            currentUserId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        }

        Course = await DbContext.Courses
            .Include(c => c.Instructor)
            .Include(c => c.Modules)
                .ThenInclude(m => m.Lessons)
            .FirstOrDefaultAsync(c => c.Id == Id);

        if (Course != null && !string.IsNullOrEmpty(currentUserId))
        {
            isEnrolled = await DbContext.Enrollments.AnyAsync(e => e.CourseId == Id && e.StudentId == currentUserId);
        }

        isLoading = false;
    }

    private async Task EnrollCourse()
    {
        if (string.IsNullOrEmpty(currentUserId))
        {
            NavigationManager.NavigateTo($"/Account/Login?ReturnUrl=/courses/{Id}");
            return;
        }

        if (Course == null) return;

        isEnrolling = true;

        var enrollment = new Enrollment
        {
            CourseId = Course.Id,
            StudentId = currentUserId,
            EnrolledAt = DateTime.UtcNow,
            ProgressPercentage = 0
        };

        DbContext.Enrollments.Add(enrollment);
        await DbContext.SaveChangesAsync();

        isEnrolled = true;
        isEnrolling = false;
        
        NavigationManager.NavigateTo($"/learning/{Id}");
    }
}