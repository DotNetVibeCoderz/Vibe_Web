@page "/my-learning"
@using LMSNet.Data
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@inject ApplicationDbContext DbContext
@attribute [Authorize]

<PageTitle>My Learning - LMSNet</PageTitle>

<div class="space-y-6">
    <div class="flex justify-between items-center mb-6">
        <h1 class="text-3xl font-bold text-gray-800 dark:text-white">My Learning</h1>
        <div class="flex space-x-2">
             <button @onclick='() => SetFilter("All")' class="@GetButtonClass("All") px-4 py-2 rounded-md font-medium text-sm transition-colors shadow-sm">All Courses</button>
             <button @onclick='() => SetFilter("InProgress")' class="@GetButtonClass("InProgress") px-4 py-2 rounded-md font-medium text-sm transition-colors shadow-sm">In Progress</button>
             <button @onclick='() => SetFilter("Completed")' class="@GetButtonClass("Completed") px-4 py-2 rounded-md font-medium text-sm transition-colors shadow-sm">Completed</button>
        </div>
    </div>

    @if (Enrollments == null)
    {
        <div class="flex justify-center items-center py-20">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-500"></div>
        </div>
    }
    else if (!FilteredEnrollments.Any())
    {
        <div class="text-center py-20 bg-white dark:bg-gray-800 rounded-lg shadow-sm">
            <i class="fas fa-book-reader text-gray-400 text-5xl mb-4"></i>
            <h3 class="text-xl font-medium text-gray-600 dark:text-gray-300">No courses found.</h3>
            <p class="text-gray-500 dark:text-gray-400 mb-6">Explore our catalog to start learning.</p>
            <a href="/courses" class="bg-blue-600 text-white px-6 py-2 rounded-md hover:bg-blue-700 font-medium transition-colors shadow-sm inline-block">Browse Courses</a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var enrollment in FilteredEnrollments)
            {
                <div class="bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all border border-gray-100 dark:border-gray-700 cursor-pointer flex flex-col h-full" @onclick='() => NavigateToLearning(enrollment.Course.Id)'>
                    <div class="h-40 bg-gray-200 dark:bg-gray-700 relative flex-shrink-0">
                        <img src="@(string.IsNullOrEmpty(enrollment.Course.ThumbnailUrl) ? "https://images.unsplash.com/photo-1516321318423-f06f85e504b3?ixlib=rb-1.2.1&auto=format&fit=crop&w=800&q=80" : enrollment.Course.ThumbnailUrl)" alt="@enrollment.Course.Title" class="w-full h-full object-cover" />
                        <div class="absolute inset-0 bg-black bg-opacity-40 flex items-center justify-center opacity-0 hover:opacity-100 transition-opacity">
                            <i class="fas fa-play-circle text-white text-4xl"></i>
                        </div>
                    </div>
                    
                    <div class="p-5 flex flex-col flex-grow">
                        <h3 class="text-lg font-bold text-gray-800 dark:text-white mb-2 line-clamp-2">@enrollment.Course.Title</h3>
                        
                        <div class="mt-auto pt-4">
                            <div class="mb-2 flex justify-between text-xs text-gray-500 dark:text-gray-400 font-medium">
                                <span>@((int)enrollment.ProgressPercentage)% Complete</span>
                                @if(enrollment.ProgressPercentage >= 100)
                                {
                                    <span class="text-green-500"><i class="fas fa-check-circle mr-1"></i>Completed</span>
                                }
                            </div>
                            <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                                <div class="bg-blue-600 h-2 rounded-full transition-all duration-500" style="width: @(Math.Min(100, enrollment.ProgressPercentage))%"></div>
                            </div>
                            
                            @if(enrollment.ProgressPercentage >= 100)
                            {
                                <button @onclick:stopPropagation="true" @onclick="() => DownloadCertificate(enrollment)" class="mt-4 w-full bg-green-50 text-green-600 dark:bg-green-900/30 dark:text-green-400 border border-green-200 dark:border-green-800 py-2 rounded-md font-medium hover:bg-green-100 dark:hover:bg-green-900/50 transition-colors flex justify-center items-center">
                                    <i class="fas fa-certificate mr-2"></i> View Certificate
                                </button>
                            }
                            else
                            {
                                <button class="mt-4 w-full bg-blue-50 text-blue-600 dark:bg-blue-900/30 dark:text-blue-400 border border-blue-200 dark:border-blue-800 py-2 rounded-md font-medium hover:bg-blue-100 dark:hover:bg-blue-900/50 transition-colors">
                                    Continue Learning
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState>? authenticationState { get; set; }
    @inject NavigationManager NavigationManager
    @inject IJSRuntime JSRuntime
    
    private List<Enrollment>? Enrollments;
    private string activeFilter = "All";

    private IEnumerable<Enrollment> FilteredEnrollments => Enrollments?.Where(e => 
        activeFilter == "All" || 
        (activeFilter == "InProgress" && e.ProgressPercentage < 100) || 
        (activeFilter == "Completed" && e.ProgressPercentage >= 100)) ?? Enumerable.Empty<Enrollment>();

    protected override async Task OnInitializedAsync()
    {
        if (authenticationState is not null)
        {
            var authState = await authenticationState;
            var user = authState?.User;

            if (user?.Identity is not null && user.Identity.IsAuthenticated)
            {
                var userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                if (!string.IsNullOrEmpty(userId))
                {
                     Enrollments = await DbContext.Enrollments
                        .Include(e => e.Course)
                        .Where(e => e.StudentId == userId)
                        .ToListAsync();
                }
            }
        }
    }

    private void SetFilter(string filter)
    {
        activeFilter = filter;
    }

    private string GetButtonClass(string filter)
    {
        if (activeFilter == filter)
        {
            return "bg-blue-600 text-white hover:bg-blue-700";
        }
        return "bg-white dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border border-gray-300 dark:border-gray-600";
    }

    private void NavigateToLearning(int courseId)
    {
        NavigationManager.NavigateTo($"/learning/{courseId}");
    }

    private async Task DownloadCertificate(Enrollment enrollment)
    {
        // Simple alert for now as certificate generation is out of scope for this task
        await JSRuntime.InvokeVoidAsync("alert", $"Generating certificate for {enrollment.Course.Title}...");
    }
}
