@page "/products"
@using Microsoft.EntityFrameworkCore
@using MyPoS.Data
@using Microsoft.AspNetCore.Components.Forms
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject MyPoS.Services.IStorageService StorageService
@inject MyPoS.Services.ExportService ExportService
@attribute [Authorize(Roles = "Admin,Manager")]

<MudText Typo="Typo.h4" Class="mb-6">Products Management</MudText>

<MudCard Class="glass-container pa-4">
    <MudTable Items="@ProductsList" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" 
              Filter="new Func<Product,bool>(FilterFunc1)"
              Style="background: transparent;">
        <ToolBarContent>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNewDialog">Add</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.Download" OnClick="ExportExcel" Class="ml-2">Excel</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.Download" OnClick="ExportCsv" Class="ml-2">CSV</MudButton>
            <MudSpacer />
            <MudTextField @bind-Value="searchString1" Placeholder="Search..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<Product, object>(x=>x.Id)">ID</MudTableSortLabel></MudTh>
            <MudTh>Image</MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Product, object>(x=>x.Barcode)">Barcode</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Product, object>(x=>x.Name)">Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Product, object>(x=>x.Category.Name)">Category</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Product, object>(x=>x.Price)">Price</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Product, object>(x=>x.Stock)">Stock</MudTableSortLabel></MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="ID">@context.Id</MudTd>
            <MudTd DataLabel="Image">
                @if(!string.IsNullOrEmpty(context.ImageUrl))
                {
                    <MudImage Src="@context.ImageUrl" Width="40" Height="40" ObjectFit="ObjectFit.Cover" Elevation="1" Class="rounded-lg"/>
                }
            </MudTd>
            <MudTd DataLabel="Barcode">@context.Barcode</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Category">@context.Category?.Name</MudTd>
            <MudTd DataLabel="Price">@context.Price.ToString("C0")</MudTd>
            <MudTd DataLabel="Stock">@context.Stock</MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="() => OpenEditDialog(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => DeleteProduct(context)" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudCard>

@if (isDialogOpen)
{
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="9999" AutoClose="false">
        <MudCard Class="glass-container pa-6" Style="width:400px; max-width:90vw;">
            <MudText Typo="Typo.h6" Class="mb-4">@(isEdit ? "Edit Product" : "New Product")</MudText>
            
            <div class="mb-2 text-center">
                @if(!string.IsNullOrEmpty(editingProduct.ImageUrl))
                {
                    <MudImage Src="@editingProduct.ImageUrl" Width="100" Height="100" ObjectFit="ObjectFit.Cover" Class="rounded-lg mb-2"/>
                }
                <InputFile id="fileInput" OnChange="UploadImage" hidden />
                <MudButton HtmlTag="label" for="fileInput" Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload">
                    Upload Image
                </MudButton>
            </div>

            <MudTextField @bind-Value="editingProduct.Barcode" Label="Barcode" Class="mb-2" />
            <MudTextField @bind-Value="editingProduct.Name" Label="Name" Required="true" Class="mb-2" />
            <MudSelect T="int" @bind-Value="editingProduct.CategoryId" Label="Category" Class="mb-2">
                @foreach (var cat in CategoriesList)
                {
                    <MudSelectItem Value="@cat.Id">@cat.Name</MudSelectItem>
                }
            </MudSelect>
            <MudNumericField @bind-Value="editingProduct.Price" Label="Price" Class="mb-2" />
            <MudNumericField @bind-Value="editingProduct.Stock" Label="Stock" Class="mb-2" />
            <MudTextField @bind-Value="editingProduct.Description" Label="Description" Lines="3" Class="mb-4" />
            
            <div class="d-flex justify-end">
                <MudButton OnClick="CloseDialog" Class="mr-2">Cancel</MudButton>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveProduct">Save</MudButton>
            </div>
        </MudCard>
    </MudOverlay>
}

@code {
    List<Product> ProductsList = new();
    List<Category> CategoriesList = new();
    string searchString1 = "";

    bool isDialogOpen = false;
    bool isEdit = false;
    Product editingProduct = new Product();
    IBrowserFile uploadedFile;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {
        using var db = DbFactory.CreateDbContext();
        ProductsList = await db.Products.Include(p => p.Category).ToListAsync();
        CategoriesList = await db.Categories.ToListAsync();
    }

    private bool FilterFunc1(Product element) => FilterFunc(element, searchString1);

    private bool FilterFunc(Product element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Barcode != null && element.Barcode.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Category != null && element.Category.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    async Task ExportExcel()
    {
        var data = ProductsList.Select(x => new { x.Id, x.Barcode, x.Name, Category = x.Category?.Name, x.Price, x.Stock }).ToList();
        var bytes = ExportService.ExportToExcel(data, "Products");
        var streamRef = new DotNetStreamReference(new MemoryStream(bytes));
        await JSRuntime.InvokeVoidAsync("downloadFileFromStream", "Products.xlsx", streamRef);
    }

    async Task ExportCsv()
    {
        var data = ProductsList.Select(x => new { x.Id, x.Barcode, x.Name, Category = x.Category?.Name, x.Price, x.Stock }).ToList();
        var bytes = ExportService.ExportToCsv(data);
        var streamRef = new DotNetStreamReference(new MemoryStream(bytes));
        await JSRuntime.InvokeVoidAsync("downloadFileFromStream", "Products.csv", streamRef);
    }

    void OpenNewDialog()
    {
        editingProduct = new Product { CategoryId = CategoriesList.FirstOrDefault()?.Id ?? 0 };
        isEdit = false;
        isDialogOpen = true;
    }

    void OpenEditDialog(Product p)
    {
        editingProduct = new Product
        {
            Id = p.Id,
            Name = p.Name,
            Barcode = p.Barcode,
            Price = p.Price,
            Stock = p.Stock,
            CategoryId = p.CategoryId,
            Description = p.Description,
            ImageUrl = p.ImageUrl
        };
        isEdit = true;
        isDialogOpen = true;
    }

    void CloseDialog()
    {
        isDialogOpen = false;
        uploadedFile = null;
    }

    async Task UploadImage(InputFileChangeEventArgs e)
    {
        uploadedFile = e.File;
        // Mock preview: generate object URL using JS? No, just show uploading message, wait for Save
        Snackbar.Add("File selected. It will be uploaded when you save.", Severity.Info);
    }

    async Task SaveProduct()
    {
        if (string.IsNullOrWhiteSpace(editingProduct.Name))
        {
            Snackbar.Add("Name is required", Severity.Warning);
            return;
        }

        try
        {
            if (uploadedFile != null)
            {
                var url = await StorageService.UploadFileAsync(uploadedFile, uploadedFile.Name);
                if (isEdit && !string.IsNullOrEmpty(editingProduct.ImageUrl))
                {
                    // Optionally delete old file
                    await StorageService.DeleteFileAsync(editingProduct.ImageUrl);
                }
                editingProduct.ImageUrl = url;
            }

            using var db = DbFactory.CreateDbContext();
            if (isEdit)
            {
                var p = await db.Products.FindAsync(editingProduct.Id);
                if (p != null)
                {
                    p.Name = editingProduct.Name;
                    p.Barcode = editingProduct.Barcode;
                    p.Price = editingProduct.Price;
                    p.Stock = editingProduct.Stock;
                    p.CategoryId = editingProduct.CategoryId;
                    p.Description = editingProduct.Description;
                    p.ImageUrl = editingProduct.ImageUrl;
                    db.Products.Update(p);
                }
            }
            else
            {
                db.Products.Add(editingProduct);
            }

            await db.SaveChangesAsync();
            Snackbar.Add("Product saved", Severity.Success);
            isDialogOpen = false;
            uploadedFile = null;
            await LoadData();
        }
        catch(Exception ex)
        {
            Snackbar.Add($"Error saving: {ex.Message}", Severity.Error);
        }
    }

    async Task DeleteProduct(Product p)
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this product?");
        if (confirmed)
        {
            using var db = DbFactory.CreateDbContext();
            var item = await db.Products.FindAsync(p.Id);
            if (item != null)
            {
                db.Products.Remove(item);
                await db.SaveChangesAsync();
                
                if(!string.IsNullOrEmpty(item.ImageUrl))
                    await StorageService.DeleteFileAsync(item.ImageUrl);

                Snackbar.Add("Product deleted", Severity.Info);
                await LoadData();
            }
        }
    }
}
