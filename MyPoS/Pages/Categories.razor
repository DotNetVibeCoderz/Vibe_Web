@page "/categories"
@using Microsoft.EntityFrameworkCore
@using MyPoS.Data
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject MyPoS.Services.ExportService ExportService
@attribute [Authorize(Roles = "Admin,Manager")]

<MudText Typo="Typo.h4" Class="mb-6">Categories Management</MudText>

<MudCard Class="glass-container pa-4">
    <MudTable Items="@CategoriesList" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" 
              Filter="new Func<Category,bool>(FilterFunc1)"
              Style="background: transparent;">
        <ToolBarContent>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNewDialog">Add</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.Download" OnClick="ExportExcel" Class="ml-2">Excel</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.Download" OnClick="ExportCsv" Class="ml-2">CSV</MudButton>
            <MudSpacer />
            <MudTextField @bind-Value="searchString1" Placeholder="Search..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<Category, object>(x=>x.Id)">ID</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Category, object>(x=>x.Name)">Name</MudTableSortLabel></MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="ID">@context.Id</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="() => OpenEditDialog(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => DeleteCategory(context)" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudCard>

@if (isDialogOpen)
{
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="9999" AutoClose="false">
        <MudCard Class="glass-container pa-6" Style="width:400px; max-width:90vw;">
            <MudText Typo="Typo.h6" Class="mb-4">@(isEdit ? "Edit Category" : "New Category")</MudText>
            
            <MudTextField @bind-Value="editingCategory.Name" Label="Name" Required="true" Class="mb-4" />
            
            <div class="d-flex justify-end">
                <MudButton OnClick="CloseDialog" Class="mr-2">Cancel</MudButton>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveCategory">Save</MudButton>
            </div>
        </MudCard>
    </MudOverlay>
}

@code {
    List<Category> CategoriesList = new();
    string searchString1 = "";

    bool isDialogOpen = false;
    bool isEdit = false;
    Category editingCategory = new Category();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {
        using var db = DbFactory.CreateDbContext();
        CategoriesList = await db.Categories.ToListAsync();
    }

    private bool FilterFunc1(Category element) => FilterFunc(element, searchString1);

    private bool FilterFunc(Category element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    async Task ExportExcel()
    {
        var data = CategoriesList.Select(x => new { x.Id, x.Name }).ToList();
        var bytes = ExportService.ExportToExcel(data, "Categories");
        var streamRef = new DotNetStreamReference(new MemoryStream(bytes));
        await JSRuntime.InvokeVoidAsync("downloadFileFromStream", "Categories.xlsx", streamRef);
    }

    async Task ExportCsv()
    {
        var data = CategoriesList.Select(x => new { x.Id, x.Name }).ToList();
        var bytes = ExportService.ExportToCsv(data);
        var streamRef = new DotNetStreamReference(new MemoryStream(bytes));
        await JSRuntime.InvokeVoidAsync("downloadFileFromStream", "Categories.csv", streamRef);
    }

    void OpenNewDialog()
    {
        editingCategory = new Category();
        isEdit = false;
        isDialogOpen = true;
    }

    void OpenEditDialog(Category c)
    {
        editingCategory = new Category
        {
            Id = c.Id,
            Name = c.Name
        };
        isEdit = true;
        isDialogOpen = true;
    }

    void CloseDialog()
    {
        isDialogOpen = false;
    }

    async Task SaveCategory()
    {
        if (string.IsNullOrWhiteSpace(editingCategory.Name))
        {
            Snackbar.Add("Name is required", Severity.Warning);
            return;
        }

        using var db = DbFactory.CreateDbContext();
        if (isEdit)
        {
            var item = await db.Categories.FindAsync(editingCategory.Id);
            if (item != null)
            {
                item.Name = editingCategory.Name;
                db.Categories.Update(item);
            }
        }
        else
        {
            db.Categories.Add(editingCategory);
        }

        await db.SaveChangesAsync();
        Snackbar.Add("Category saved", Severity.Success);
        isDialogOpen = false;
        await LoadData();
    }

    async Task DeleteCategory(Category c)
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this category?");
        if (confirmed)
        {
            using var db = DbFactory.CreateDbContext();
            var item = await db.Categories.FindAsync(c.Id);
            if (item != null)
            {
                db.Categories.Remove(item);
                await db.SaveChangesAsync();
                Snackbar.Add("Category deleted", Severity.Info);
                await LoadData();
            }
        }
    }
}
