@page "/customers"
@using Microsoft.EntityFrameworkCore
@using MyPoS.Data
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject MyPoS.Services.ExportService ExportService
@attribute [Authorize(Roles = "Admin,Manager")]

<MudText Typo="Typo.h4" Class="mb-6">Customers Management</MudText>

<MudCard Class="glass-container pa-4">
    <MudTable Items="@CustomersList" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" 
              Filter="new Func<Customer,bool>(FilterFunc1)"
              Style="background: transparent;">
        <ToolBarContent>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenNewDialog">Add</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.Download" OnClick="ExportExcel" Class="ml-2">Excel</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.Download" OnClick="ExportCsv" Class="ml-2">CSV</MudButton>
            <MudSpacer />
            <MudTextField @bind-Value="searchString1" Placeholder="Search..." Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
        </ToolBarContent>
        <HeaderContent>
            <MudTh><MudTableSortLabel SortBy="new Func<Customer, object>(x=>x.Id)">ID</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Customer, object>(x=>x.Name)">Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Customer, object>(x=>x.Phone)">Phone</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Customer, object>(x=>x.Email)">Email</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortBy="new Func<Customer, object>(x=>x.LoyaltyPoints)">Points</MudTableSortLabel></MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="ID">@context.Id</MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Phone">@context.Phone</MudTd>
            <MudTd DataLabel="Email">@context.Email</MudTd>
            <MudTd DataLabel="Points">@context.LoyaltyPoints</MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="() => OpenEditDialog(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => DeleteCustomer(context)" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
</MudCard>

@if (isDialogOpen)
{
    <MudOverlay Visible="true" DarkBackground="true" ZIndex="9999" AutoClose="false">
        <MudCard Class="glass-container pa-6" Style="width:400px; max-width:90vw;">
            <MudText Typo="Typo.h6" Class="mb-4">@(isEdit ? "Edit Customer" : "New Customer")</MudText>
            
            <MudTextField @bind-Value="editingCustomer.Name" Label="Name" Required="true" Class="mb-2" />
            <MudTextField @bind-Value="editingCustomer.Phone" Label="Phone" Class="mb-2" />
            <MudTextField @bind-Value="editingCustomer.Email" Label="Email" Class="mb-2" />
            <MudNumericField @bind-Value="editingCustomer.LoyaltyPoints" Label="Loyalty Points" Class="mb-4" />
            
            <div class="d-flex justify-end">
                <MudButton OnClick="CloseDialog" Class="mr-2">Cancel</MudButton>
                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SaveCustomer">Save</MudButton>
            </div>
        </MudCard>
    </MudOverlay>
}

@code {
    List<Customer> CustomersList = new();
    string searchString1 = "";

    bool isDialogOpen = false;
    bool isEdit = false;
    Customer editingCustomer = new Customer();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {
        using var db = DbFactory.CreateDbContext();
        CustomersList = await db.Customers.ToListAsync();
    }

    private bool FilterFunc1(Customer element) => FilterFunc(element, searchString1);

    private bool FilterFunc(Customer element, string searchString)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;
        if (element.Name != null && element.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Phone != null && element.Phone.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        if (element.Email != null && element.Email.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;
        return false;
    }

    async Task ExportExcel()
    {
        var data = CustomersList.Select(x => new { x.Id, x.Name, x.Phone, x.Email, x.LoyaltyPoints }).ToList();
        var bytes = ExportService.ExportToExcel(data, "Customers");
        var streamRef = new DotNetStreamReference(new MemoryStream(bytes));
        await JSRuntime.InvokeVoidAsync("downloadFileFromStream", "Customers.xlsx", streamRef);
    }

    async Task ExportCsv()
    {
        var data = CustomersList.Select(x => new { x.Id, x.Name, x.Phone, x.Email, x.LoyaltyPoints }).ToList();
        var bytes = ExportService.ExportToCsv(data);
        var streamRef = new DotNetStreamReference(new MemoryStream(bytes));
        await JSRuntime.InvokeVoidAsync("downloadFileFromStream", "Customers.csv", streamRef);
    }

    void OpenNewDialog()
    {
        editingCustomer = new Customer();
        isEdit = false;
        isDialogOpen = true;
    }

    void OpenEditDialog(Customer c)
    {
        editingCustomer = new Customer
        {
            Id = c.Id,
            Name = c.Name,
            Phone = c.Phone,
            Email = c.Email,
            LoyaltyPoints = c.LoyaltyPoints
        };
        isEdit = true;
        isDialogOpen = true;
    }

    void CloseDialog()
    {
        isDialogOpen = false;
    }

    async Task SaveCustomer()
    {
        if (string.IsNullOrWhiteSpace(editingCustomer.Name))
        {
            Snackbar.Add("Name is required", Severity.Warning);
            return;
        }

        using var db = DbFactory.CreateDbContext();
        if (isEdit)
        {
            var item = await db.Customers.FindAsync(editingCustomer.Id);
            if (item != null)
            {
                item.Name = editingCustomer.Name;
                item.Phone = editingCustomer.Phone;
                item.Email = editingCustomer.Email;
                item.LoyaltyPoints = editingCustomer.LoyaltyPoints;
                db.Customers.Update(item);
            }
        }
        else
        {
            db.Customers.Add(editingCustomer);
        }

        await db.SaveChangesAsync();
        Snackbar.Add("Customer saved", Severity.Success);
        isDialogOpen = false;
        await LoadData();
    }

    async Task DeleteCustomer(Customer c)
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this customer?");
        if (confirmed)
        {
            using var db = DbFactory.CreateDbContext();
            var item = await db.Customers.FindAsync(c.Id);
            if (item != null)
            {
                db.Customers.Remove(item);
                await db.SaveChangesAsync();
                Snackbar.Add("Customer deleted", Severity.Info);
                await LoadData();
            }
        }
    }
}
