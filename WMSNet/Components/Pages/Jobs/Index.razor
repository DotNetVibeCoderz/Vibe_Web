@page "/jobs"
@using WMSNet.Data
@using WMSNet.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject NavigationManager NavManager

<PageTitle>Job Tracking</PageTitle>

<div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
        <h1 class="text-xl font-semibold text-gray-900 dark:text-white">Service Jobs</h1>
        <p class="mt-2 text-sm text-gray-700 dark:text-gray-300">
            A list of all service jobs including their status, vehicle details, and technician assignment.
        </p>
    </div>
    <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
        <button @onclick="OpenAddModal" class="inline-flex items-center justify-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 sm:w-auto">
            Add Job
        </button>
    </div>
</div>

<div class="mt-8 flex flex-col">
    <div class="-my-2 -mx-4 overflow-x-auto sm:-mx-6 lg:-mx-8">
        <div class="inline-block min-w-full py-2 align-middle md:px-6 lg:px-8">
            <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 md:rounded-lg">
                <table class="min-w-full divide-y divide-gray-300 dark:divide-gray-700">
                    <thead class="bg-gray-50 dark:bg-gray-800">
                        <tr>
                            <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 dark:text-white sm:pl-6">ID</th>
                            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Vehicle</th>
                            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Description</th>
                            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Status</th>
                            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900 dark:text-white">Created</th>
                            <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                                <span class="sr-only">Edit</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200 dark:divide-gray-700 bg-white dark:bg-gray-900">
                        @foreach (var job in jobs)
                        {
                            <tr>
                                <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-gray-900 dark:text-white sm:pl-6">#@job.Id</td>
                                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-300">
                                    <div class="font-bold">@job.Vehicle?.Make @job.Vehicle?.Model</div>
                                    <div class="text-xs">@job.Vehicle?.LicensePlate</div>
                                </td>
                                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-300">@job.Description</td>
                                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-300">
                                    <span class="inline-flex rounded-full bg-green-100 px-2 text-xs font-semibold leading-5 text-green-800">
                                        @job.Status
                                    </span>
                                </td>
                                <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500 dark:text-gray-300">@job.CreatedAt.ToShortDateString()</td>
                                <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                                    <button @onclick="() => EditJob(job)" class="text-indigo-600 hover:text-indigo-900 dark:text-indigo-400 dark:hover:text-indigo-300">Edit</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (showModal)
{
    <div class="relative z-10" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity"></div>
        <div class="fixed inset-0 z-10 overflow-y-auto">
            <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
                <div class="relative transform overflow-hidden rounded-lg bg-white dark:bg-gray-800 text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg">
                    <div class="bg-white dark:bg-gray-800 px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                        <h3 class="text-lg font-medium leading-6 text-gray-900 dark:text-white">
                            @(currentJob.Id == 0 ? "Create New Job" : "Edit Job")
                        </h3>
                        <div class="mt-2 space-y-4">
                            @if(currentJob.Id == 0)
                            {
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Select Vehicle</label>
                                    <select @bind="currentJob.VehicleId" class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm dark:bg-gray-700 dark:text-white p-2 border">
                                        <option value="0">-- Select Vehicle --</option>
                                        @foreach (var v in vehicles)
                                        {
                                            <option value="@v.Id">@v.LicensePlate - @v.Make @v.Model (@v.Customer?.Name)</option>
                                        }
                                    </select>
                                </div>
                            }
                            else
                            {
                                <div class="text-sm font-bold dark:text-white">
                                    Vehicle: @currentJob.Vehicle?.LicensePlate (@currentJob.Vehicle?.Make)
                                </div>
                            }

                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Description</label>
                                <textarea @bind="currentJob.Description" rows="3" class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm dark:bg-gray-700 dark:text-white p-2 border"></textarea>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Mechanic Notes</label>
                                <textarea @bind="currentJob.MechanicNotes" rows="3" class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm dark:bg-gray-700 dark:text-white p-2 border"></textarea>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Status</label>
                                <select @bind="currentJob.Status" class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm dark:bg-gray-700 dark:text-white p-2 border">
                                    @foreach (var status in Enum.GetValues(typeof(JobStatus)))
                                    {
                                        <option value="@status">@status</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="bg-gray-50 dark:bg-gray-700 px-4 py-3 sm:flex sm:flex-row-reverse sm:px-6">
                        <button type="button" @onclick="SaveJob" class="inline-flex w-full justify-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-base font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 sm:ml-3 sm:w-auto sm:text-sm">
                            Save
                        </button>
                        <button type="button" @onclick="CloseModal" class="mt-3 inline-flex w-full justify-center rounded-md border border-gray-300 bg-white dark:bg-gray-600 dark:border-gray-500 px-4 py-2 text-base font-medium text-gray-700 dark:text-gray-200 shadow-sm hover:bg-gray-50 dark:hover:bg-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                            Cancel
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ServiceJob> jobs = new();
    private List<Vehicle> vehicles = new();
    private bool showModal = false;
    private ServiceJob currentJob = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        jobs = await DbContext.ServiceJobs
            .Include(j => j.Vehicle)
            .OrderByDescending(j => j.CreatedAt)
            .ToListAsync();
            
        vehicles = await DbContext.Vehicles
            .Include(v => v.Customer)
            .ToListAsync();
    }

    private void OpenAddModal()
    {
        currentJob = new ServiceJob { CreatedAt = DateTime.UtcNow };
        showModal = true;
    }

    private void EditJob(ServiceJob job)
    {
        // Clone for edit
        currentJob = new ServiceJob
        {
            Id = job.Id,
            VehicleId = job.VehicleId,
            Vehicle = job.Vehicle, // Keep ref for display
            Description = job.Description,
            MechanicNotes = job.MechanicNotes,
            Status = job.Status,
            CreatedAt = job.CreatedAt,
            TechnicianId = job.TechnicianId
        };
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task SaveJob()
    {
        if (currentJob.VehicleId == 0) return; // Validation

        if (currentJob.Id == 0)
        {
            // Reset nav prop to null to avoid EF trying to add vehicle again if attached
            currentJob.Vehicle = null;
            DbContext.ServiceJobs.Add(currentJob);
        }
        else
        {
            var j = await DbContext.ServiceJobs.FindAsync(currentJob.Id);
            if (j != null)
            {
                j.Description = currentJob.Description;
                j.MechanicNotes = currentJob.MechanicNotes;
                j.Status = currentJob.Status;
                if (j.Status == JobStatus.Completed && j.CompletedAt == null)
                {
                    j.CompletedAt = DateTime.UtcNow;
                }
            }
        }
        await DbContext.SaveChangesAsync();
        await LoadData();
        CloseModal();
    }
}