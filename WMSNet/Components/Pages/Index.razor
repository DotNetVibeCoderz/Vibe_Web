@page "/"
@using WMSNet.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext

<PageTitle>Dashboard</PageTitle>

<div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
    <!-- Card 1 -->
    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
            <div class="flex items-center">
                <div class="flex-shrink-0 bg-indigo-500 rounded-md p-3">
                    <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                </div>
                <div class="ml-5 w-0 flex-1">
                    <dl>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                            Active Jobs
                        </dt>
                        <dd>
                            <div class="text-lg font-medium text-gray-900 dark:text-white">
                                @activeJobs
                            </div>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700 px-5 py-3">
            <div class="text-sm">
                <a href="jobs" class="font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-500">
                    View all
                </a>
            </div>
        </div>
    </div>

    <!-- Card 2 -->
    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
            <div class="flex items-center">
                <div class="flex-shrink-0 bg-green-500 rounded-md p-3">
                    <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
                <div class="ml-5 w-0 flex-1">
                    <dl>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                            Monthly Revenue
                        </dt>
                        <dd>
                            <div class="text-lg font-medium text-gray-900 dark:text-white">
                                @revenue.ToString("C0")
                            </div>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700 px-5 py-3">
            <div class="text-sm">
                <a href="invoices" class="font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-500">
                    View financials
                </a>
            </div>
        </div>
    </div>

    <!-- Card 3 -->
    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
            <div class="flex items-center">
                <div class="flex-shrink-0 bg-yellow-500 rounded-md p-3">
                    <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                         <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                </div>
                <div class="ml-5 w-0 flex-1">
                    <dl>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                            Low Stock Items
                        </dt>
                        <dd>
                            <div class="text-lg font-medium text-gray-900 dark:text-white">
                                @lowStockCount
                            </div>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700 px-5 py-3">
            <div class="text-sm">
                <a href="inventory" class="font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-500">
                    Restock now
                </a>
            </div>
        </div>
    </div>
    
     <!-- Card 4 -->
    <div class="bg-white dark:bg-gray-800 overflow-hidden shadow rounded-lg">
        <div class="p-5">
            <div class="flex items-center">
                <div class="flex-shrink-0 bg-blue-500 rounded-md p-3">
                    <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                    </svg>
                </div>
                <div class="ml-5 w-0 flex-1">
                    <dl>
                        <dt class="text-sm font-medium text-gray-500 dark:text-gray-400 truncate">
                            Total Customers
                        </dt>
                        <dd>
                            <div class="text-lg font-medium text-gray-900 dark:text-white">
                                @customerCount
                            </div>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="bg-gray-50 dark:bg-gray-700 px-5 py-3">
            <div class="text-sm">
                <a href="customers" class="font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-500">
                    Manage customers
                </a>
            </div>
        </div>
    </div>
</div>

<div class="mt-8">
    <h2 class="text-lg leading-6 font-medium text-gray-900 dark:text-white">Recent Jobs</h2>
    <div class="flex flex-col mt-2">
        <div class="-my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
            <div class="py-2 align-middle inline-block min-w-full sm:px-6 lg:px-8">
                <div class="shadow overflow-hidden border-b border-gray-200 dark:border-gray-700 sm:rounded-lg">
                    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                        <thead class="bg-gray-50 dark:bg-gray-700">
                            <tr>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">ID</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Vehicle</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Description</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Status</th>
                                <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Date</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                            @foreach (var job in recentJobs)
                            {
                                <tr>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-300">#@job.Id</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 dark:text-white">
                                        @job.Vehicle?.Make @job.Vehicle?.Model (@job.Vehicle?.LicensePlate)
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-300">@job.Description</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-300">
                                        <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                                            @(job.Status == WMSNet.Models.JobStatus.Completed ? "bg-green-100 text-green-800" : 
                                              job.Status == WMSNet.Models.JobStatus.InProgress ? "bg-blue-100 text-blue-800" : 
                                              "bg-yellow-100 text-yellow-800")">
                                            @job.Status
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-300">
                                        @job.CreatedAt.ToShortDateString()
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int activeJobs;
    private decimal revenue;
    private int lowStockCount;
    private int customerCount;
    private List<WMSNet.Models.ServiceJob> recentJobs = new();

    protected override async Task OnInitializedAsync()
    {
        activeJobs = await DbContext.ServiceJobs
            .CountAsync(j => j.Status != WMSNet.Models.JobStatus.Completed && j.Status != WMSNet.Models.JobStatus.Cancelled);

        // Revenue calc: Fetch data client-side for SQLite compatibility (no sum on decimal)
        var completedJobIds = await DbContext.ServiceJobs
             .Where(j => j.Status == WMSNet.Models.JobStatus.Completed)
             .Select(j => j.Id)
             .ToListAsync();
             
        // Fetch raw data
        var items = await DbContext.JobItems
            .Where(i => completedJobIds.Contains(i.ServiceJobId))
            .Select(i => new { i.Quantity, i.UnitPrice })
            .ToListAsync();
        
        // Sum in memory
        revenue = items.Sum(i => i.Quantity * i.UnitPrice);

        lowStockCount = await DbContext.Parts.CountAsync(p => p.StockQuantity <= p.LowStockThreshold);
        
        customerCount = await DbContext.Customers.CountAsync();

        recentJobs = await DbContext.ServiceJobs
            .Include(j => j.Vehicle)
            .OrderByDescending(j => j.CreatedAt)
            .Take(5)
            .ToListAsync();
    }
}