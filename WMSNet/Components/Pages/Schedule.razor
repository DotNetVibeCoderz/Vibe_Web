@page "/schedule"
@using WMSNet.Data
@using WMSNet.Models
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject IJSRuntime JS

<PageTitle>Schedule</PageTitle>

<div class="sm:flex sm:items-center">
    <div class="sm:flex-auto">
        <h1 class="text-xl font-semibold text-gray-900 dark:text-white">Schedule</h1>
        <p class="mt-2 text-sm text-gray-700 dark:text-gray-300">
            View upcoming appointments and jobs.
        </p>
    </div>
    <div class="mt-4 sm:mt-0 sm:ml-16 sm:flex-none">
        <button @onclick="OpenAddModal" class="inline-flex items-center justify-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 sm:w-auto">
            Add Appointment
        </button>
    </div>
</div>

<div class="mt-8 space-y-8">
    @if (groupedAppointments == null || !groupedAppointments.Any())
    {
        <div class="text-center py-10 text-gray-500 dark:text-gray-400">
            No appointments scheduled.
        </div>
    }
    else
    {
        @foreach (var group in groupedAppointments)
        {
            <div>
                <h3 class="text-lg font-medium leading-6 text-gray-900 dark:text-white border-b pb-2 mb-4">
                    @group.Key.ToLongDateString()
                </h3>
                <div class="bg-white dark:bg-gray-800 shadow overflow-hidden sm:rounded-md">
                    <ul role="list" class="divide-y divide-gray-200 dark:divide-gray-700">
                        @foreach (var item in group)
                        {
                            <li>
                                <div class="px-4 py-4 sm:px-6 hover:bg-gray-50 dark:hover:bg-gray-700 transition duration-150 ease-in-out cursor-pointer" @onclick="() => EditAppointment(item)">
                                    <div class="flex items-center justify-between">
                                        <div class="text-sm font-medium text-indigo-600 dark:text-indigo-400 truncate">
                                            @item.CustomerName (@item.Phone)
                                        </div>
                                        <div class="ml-2 flex-shrink-0 flex">
                                            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full 
                                                @(item.Status == "Confirmed" ? "bg-green-100 text-green-800" : 
                                                  item.Status == "Cancelled" ? "bg-red-100 text-red-800" : 
                                                  "bg-blue-100 text-blue-800")">
                                                @item.Status
                                            </span>
                                        </div>
                                    </div>
                                    <div class="mt-2 sm:flex sm:justify-between">
                                        <div class="sm:flex">
                                            <p class="flex items-center text-sm text-gray-500 dark:text-gray-300">
                                                <svg class="flex-shrink-0 mr-1.5 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                                </svg>
                                                @item.AppointmentDate.ToShortTimeString()
                                            </p>
                                            <p class="mt-2 flex items-center text-sm text-gray-500 dark:text-gray-300 sm:mt-0 sm:ml-6">
                                                @item.Description
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        }
    }
</div>

@if (showModal)
{
    <div class="relative z-10" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity"></div>
        <div class="fixed inset-0 z-10 overflow-y-auto">
            <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
                <div class="relative transform overflow-hidden rounded-lg bg-white dark:bg-gray-800 text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg">
                    <div class="bg-white dark:bg-gray-800 px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                        <h3 class="text-lg font-medium leading-6 text-gray-900 dark:text-white">
                            @(currentAppointment.Id == 0 ? "Book Appointment" : "Edit Appointment")
                        </h3>
                        <div class="mt-2 space-y-4">
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Customer Name</label>
                                <input @bind="currentAppointment.CustomerName" class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm dark:bg-gray-700 dark:text-white p-2 border" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Phone</label>
                                <input @bind="currentAppointment.Phone" class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm dark:bg-gray-700 dark:text-white p-2 border" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Date & Time</label>
                                <input type="datetime-local" @bind="currentAppointment.AppointmentDate" class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm dark:bg-gray-700 dark:text-white p-2 border" />
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Description</label>
                                <textarea @bind="currentAppointment.Description" class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm dark:bg-gray-700 dark:text-white p-2 border"></textarea>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Status</label>
                                <select @bind="currentAppointment.Status" class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm dark:bg-gray-700 dark:text-white p-2 border">
                                    <option value="Scheduled">Scheduled</option>
                                    <option value="Confirmed">Confirmed</option>
                                    <option value="Completed">Completed</option>
                                    <option value="Cancelled">Cancelled</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="bg-gray-50 dark:bg-gray-700 px-4 py-3 sm:flex sm:flex-row-reverse sm:px-6">
                        <button type="button" @onclick="SaveAppointment" class="inline-flex w-full justify-center rounded-md border border-transparent bg-indigo-600 px-4 py-2 text-base font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 sm:ml-3 sm:w-auto sm:text-sm">
                            Save
                        </button>
                        
                        @if (currentAppointment.Id != 0)
                        {
                            <button type="button" @onclick="DeleteAppointment" class="mt-3 inline-flex w-full justify-center rounded-md border border-transparent bg-red-600 px-4 py-2 text-base font-medium text-white shadow-sm hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-2 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                                Delete
                            </button>
                        }

                        <button type="button" @onclick="CloseModal" class="mt-3 inline-flex w-full justify-center rounded-md border border-gray-300 bg-white dark:bg-gray-600 dark:border-gray-500 px-4 py-2 text-base font-medium text-gray-700 dark:text-gray-200 shadow-sm hover:bg-gray-50 dark:hover:bg-gray-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                            Cancel
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Appointment> appointments = new();
    private IEnumerable<IGrouping<DateTime, Appointment>> groupedAppointments = new List<Appointment>().GroupBy(x => x.AppointmentDate);
    private bool showModal = false;
    private Appointment currentAppointment = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        appointments = await DbContext.Appointments
            .OrderBy(a => a.AppointmentDate)
            .ToListAsync();
            
        groupedAppointments = appointments
            .GroupBy(a => a.AppointmentDate.Date);
    }

    private void OpenAddModal()
    {
        currentAppointment = new Appointment { AppointmentDate = DateTime.Now.AddHours(1) };
        showModal = true;
    }

    private void EditAppointment(Appointment appt)
    {
        currentAppointment = new Appointment
        {
            Id = appt.Id,
            CustomerName = appt.CustomerName,
            Phone = appt.Phone,
            AppointmentDate = appt.AppointmentDate,
            Description = appt.Description,
            Status = appt.Status,
            CustomerId = appt.CustomerId
        };
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task SaveAppointment()
    {
        if (currentAppointment.Id == 0)
        {
            DbContext.Appointments.Add(currentAppointment);
        }
        else
        {
            var a = await DbContext.Appointments.FindAsync(currentAppointment.Id);
            if (a != null)
            {
                a.CustomerName = currentAppointment.CustomerName;
                a.Phone = currentAppointment.Phone;
                a.AppointmentDate = currentAppointment.AppointmentDate;
                a.Description = currentAppointment.Description;
                a.Status = currentAppointment.Status;
            }
        }
        await DbContext.SaveChangesAsync();
        await LoadData();
        CloseModal();
    }

    private async Task DeleteAppointment()
    {
        if (currentAppointment.Id == 0) return;

        if (await JS.InvokeAsync<bool>("confirm", $"Are you sure you want to delete the appointment for {currentAppointment.CustomerName}?"))
        {
            var appt = await DbContext.Appointments.FindAsync(currentAppointment.Id);
            if (appt != null)
            {
                DbContext.Appointments.Remove(appt);
                await DbContext.SaveChangesAsync();
                await LoadData();
                CloseModal();
            }
        }
    }
}