@inherits LayoutComponentBase
@inject NavigationManager NavManager
@using Microsoft.AspNetCore.Components.Authorization

<div class="flex h-screen overflow-hidden bg-gray-100 dark:bg-gray-900 text-gray-800 dark:text-gray-100 font-sans">
    
    <!-- Sidebar -->
    <div class="hidden md:flex md:flex-shrink-0">
        <div class="flex flex-col w-64">
            <div class="flex flex-col h-0 flex-1 bg-white dark:bg-gray-800 border-r border-gray-200 dark:border-gray-700 shadow-lg">
                <div class="flex items-center h-16 flex-shrink-0 px-4 bg-indigo-600 dark:bg-indigo-800 text-white font-bold text-xl shadow-md">
                    WMSNet 🛠️
                </div>
                <div class="flex-1 flex flex-col overflow-y-auto">
                    <nav class="flex-1 px-2 py-4 space-y-1">
                        <NavMenu />
                    </nav>
                </div>
                <div class="flex-shrink-0 flex border-t border-gray-200 dark:border-gray-700 p-4">
                    <AuthorizeView>
                        <Authorized>
                            <div class="w-full">
                                <div class="flex items-center w-full mb-3">
                                    <div class="h-9 w-9 rounded-full bg-indigo-500 flex items-center justify-center text-white font-bold flex-shrink-0">
                                        @context.User.Identity?.Name?.Substring(0,1).ToUpper()
                                    </div>
                                    <div class="ml-3 overflow-hidden">
                                        <p class="text-sm font-medium text-gray-700 dark:text-white truncate">
                                            @context.User.Identity?.Name
                                        </p>
                                        <a href="Identity/Account/Manage" class="text-xs text-indigo-500 hover:text-indigo-700">Edit Profile</a>
                                    </div>
                                </div>
                                <form action="Identity/Account/Logout" method="post" class="w-full">
                                    <button type="submit" class="group flex items-center justify-center w-full px-2 py-2 text-sm font-medium rounded-md text-red-600 dark:text-red-400 border border-red-200 dark:border-red-900 hover:bg-red-50 dark:hover:bg-red-900/20">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                                        </svg>
                                        Sign out
                                    </button>
                                    <input name="__RequestVerificationToken" type="hidden" value="@GetAntiforgeryToken()" />
                                </form>
                            </div>
                        </Authorized>
                        <NotAuthorized>
                            <a href="Identity/Account/Login" class="flex items-center justify-center w-full px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700">
                                Log in
                            </a>
                        </NotAuthorized>
                    </AuthorizeView>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="flex flex-col w-0 flex-1 overflow-hidden">
        <div class="md:hidden pl-1 pt-1 sm:pl-3 sm:pt-3 flex justify-between items-center pr-3">
            <button class="-ml-0.5 -mt-0.5 h-12 w-12 inline-flex items-center justify-center rounded-md text-gray-500 hover:text-gray-900 focus:outline-none focus:ring-2 focus:ring-inset focus:ring-indigo-500">
                <span class="sr-only">Open sidebar</span>
                <!-- Heroicon name: outline/menu -->
                <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
            <div class="text-lg font-bold text-gray-900 dark:text-white">WMSNet</div>
        </div>

        <main class="flex-1 relative z-0 overflow-y-auto focus:outline-none">
            <div class="py-6">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 flex justify-between items-center">
                    <h1 class="text-2xl font-semibold text-gray-900 dark:text-white">@BodyTitle</h1>
                    <button onclick="window.toggleTheme()" class="bg-gray-200 dark:bg-gray-700 p-2 rounded-full text-gray-600 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
                        </svg>
                    </button>
                </div>
                <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 mt-6">
                    @Body
                </div>
            </div>
        </main>
    </div>
</div>

@code {
    private string BodyTitle => "Workshop Management";
    
    // In .NET 8 Blazor, Antiforgery is handled by the framework but for manual forms we might need a workaround 
    // or rely on the endpoint handling it if configured. 
    // For standard Identity, we usually need the token.
    // However, since we are in .razor, we can't easily inject IAntiforgery and generate raw token string without HttpContext.
    // A simple workaround for the Logout button in Blazor is to let the form post naturally.
    // Usually the cookie authentication middleware handles the logout without explicit token if configured loosely, 
    // but strict setup needs it. 
    // For this implementation, we will assume standard cookie auth.
    
    private string GetAntiforgeryToken()
    {
        // Placeholder. In Blazor Server interactive, accessing HttpContext to get tokens is tricky.
        // For a robust solution, one would use a distinct component or JS interop.
        // But Identity pages are standard Razor Pages.
        return ""; 
    }
}
