@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="max-w-4xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
    <div class="md:grid md:grid-cols-3 md:gap-6">
        <div class="md:col-span-1">
            <div class="px-4 sm:px-0">
                <h3 class="text-lg font-medium leading-6 text-gray-900 dark:text-white">Profile</h3>
                <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
                    This information will be displayed publicly so be careful what you share.
                </p>
                <div class="mt-4 flex items-center">
                    <div class="h-20 w-20 rounded-full bg-indigo-600 flex items-center justify-center text-white font-bold text-3xl shadow-lg">
                        @User.Identity?.Name?.Substring(0,1).ToUpper()
                    </div>
                </div>
            </div>
        </div>
        <div class="mt-5 md:mt-0 md:col-span-2">
            <div class="shadow sm:rounded-md sm:overflow-hidden">
                <div class="px-4 py-5 bg-white dark:bg-gray-800 space-y-6 sm:p-6">
                    <form id="profile-form" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>
                        
                        <div class="grid grid-cols-6 gap-6">
                            <div class="col-span-6 sm:col-span-4">
                                <label asp-for="Username" class="block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
                                <input asp-for="Username" class="mt-1 block w-full rounded-md border-gray-300 bg-gray-100 dark:bg-gray-700 dark:border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm dark:text-gray-400 p-2 border" disabled />
                            </div>

                            <div class="col-span-6 sm:col-span-4">
                                <label asp-for="Input.PhoneNumber" class="block text-sm font-medium text-gray-700 dark:text-gray-300"></label>
                                <input asp-for="Input.PhoneNumber" class="mt-1 block w-full rounded-md border-gray-300 dark:border-gray-600 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm dark:bg-gray-700 dark:text-white p-2 border" />
                                <span asp-validation-for="Input.PhoneNumber" class="text-red-500 text-xs"></span>
                            </div>
                        </div>
                        
                        <div class="px-4 py-3 bg-gray-50 dark:bg-gray-700 text-right sm:px-6 mt-6 -mx-6 -mb-6">
                            <button id="update-profile-button" type="submit" class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                                Save
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}