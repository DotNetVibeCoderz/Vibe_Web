@page "/admin/users"
@using System.IO
@using CsvHelper
@using System.Globalization
@using Microsoft.JSInterop
@inject DataService DataService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@attribute [Authorize(Roles = "admin")]

<MudText Typo="Typo.h2" Class="mb-6" Style="font-weight: 900; text-transform: uppercase;">USER MASTER DATA</MudText>

<MudPaper Class="brutalist-card pa-4 mb-4" Elevation="0">
    <div style="display:flex; justify-content:space-between; align-items:center;">
        <MudTextField @bind-Value="_searchString" Placeholder="Search Username or Email" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Class="brutalist-input" Style="width:300px;" Immediate="true" />
        <MudButton OnClick="ExportToCsv" Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.Download" Class="brutalist-btn">EXPORT CSV</MudButton>
    </div>
</MudPaper>

<MudTable Items="@FilteredUsers" Hover="true" Class="brutalist-card" Elevation="0" Dense="true" RowsPerPage="10">
    <HeaderContent>
        <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x.Id)">ID</MudTableSortLabel></MudTh>
        <MudTh>Profile</MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x.Username)">Username</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x.Email)">Email</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x.Role)">Role</MudTableSortLabel></MudTh>
        <MudTh><MudTableSortLabel SortBy="new Func<User, object>(x=>x.CreatedAt)">Joined Date</MudTableSortLabel></MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="ID">@context.Id</MudTd>
        <MudTd DataLabel="Profile">
            <MudAvatar Size="Size.Small" Class="brutalist-card">
                <MudImage Src="@context.ProfileImageUrl" />
            </MudAvatar>
        </MudTd>
        <MudTd DataLabel="Username">@context.Username</MudTd>
        <MudTd DataLabel="Email">@context.Email</MudTd>
        <MudTd DataLabel="Role">@context.Role.ToUpper()</MudTd>
        <MudTd DataLabel="Joined Date">@context.CreatedAt.ToShortDateString()</MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {
    private List<User>? _users;
    private string _searchString = string.Empty;

    private IEnumerable<User> FilteredUsers => string.IsNullOrWhiteSpace(_searchString) 
        ? (_users ?? Enumerable.Empty<User>()) 
        : (_users ?? Enumerable.Empty<User>()).Where(u => u.Username.Contains(_searchString, StringComparison.OrdinalIgnoreCase) || 
                                                          u.Email.Contains(_searchString, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _users = await DataService.GetAllUsersAsync();
    }

    private async Task ExportToCsv()
    {
        if (_users == null) return;

        using var memoryStream = new MemoryStream();
        using var writer = new StreamWriter(memoryStream);
        using var csv = new CsvWriter(writer, CultureInfo.InvariantCulture);

        var exportData = FilteredUsers.Select(u => new {
            u.Id,
            u.Username,
            u.Email,
            u.Role,
            Joined = u.CreatedAt.ToString("yyyy-MM-dd")
        });

        csv.WriteRecords(exportData);
        writer.Flush();
        var bytes = memoryStream.ToArray();
        var base64 = Convert.ToBase64String(bytes);

        await JSRuntime.InvokeVoidAsync("downloadFile", "users_export.csv", "text/csv", base64);
        Snackbar.Add("Exported successfully.", Severity.Success);
    }
}