@page "/security/audit"
@attribute [Authorize(Roles = AppRoles.Admin)]
@inject ApplicationDbContext Db

<h1 class="text-2xl font-semibold mb-6">Audit Trail</h1>

<div class="sms-card">
    <table class="min-w-full text-sm">
        <thead class="text-left text-slate-500 border-b border-slate-200 dark:border-slate-700">
            <tr>
                <th class="py-2">Aksi</th>
                <th class="py-2">Aktor</th>
                <th class="py-2">Waktu</th>
                <th class="py-2">Detail</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var audit in Audits)
            {
                <tr class="border-b border-slate-100 dark:border-slate-800">
                    <td class="py-2">@audit.Action</td>
                    <td class="py-2">@audit.Actor</td>
                    <td class="py-2">@audit.Timestamp.ToString("dd MMM yyyy HH:mm")</td>
                    <td class="py-2">@audit.Detail</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<AuditTrail> Audits { get; set; } = new();

    protected override Task OnInitializedAsync()
    {
        Audits = Db.AuditTrails.OrderByDescending(a => a.Timestamp).ToList();
        return Task.CompletedTask;
    }
}
