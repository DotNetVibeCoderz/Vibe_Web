@page "/master/classes"
@attribute [Authorize(Roles = AppRoles.Admin + "," + AppRoles.Guru)]
@inject ApplicationDbContext Db
@inject IJSRuntime JSRuntime

<h1 class="text-2xl font-semibold mb-6">Master Data - Kelas</h1>

<div class="sms-card space-y-4">
    <div class="flex gap-4 flex-wrap">
        <InputText class="w-full md:w-64 rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" @bind-Value="SearchText" placeholder="Cari kelas" />
        <button class="px-3 py-2 rounded-lg bg-indigo-600 text-white" @onclick="ExportCsv">Export CSV</button>
        <button class="px-3 py-2 rounded-lg border border-slate-200 dark:border-slate-600" @onclick="ShowAdd">Tambah Kelas</button>
    </div>

    <table class="min-w-full text-sm">
        <thead class="text-left text-slate-500 border-b border-slate-200 dark:border-slate-700">
            <tr>
                <th class="py-2">Nama</th>
                <th class="py-2">Wali Kelas</th>
                <th class="py-2">Kapasitas</th>
                <th class="py-2">Aksi</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var room in FilteredClasses)
            {
                <tr class="border-b border-slate-100 dark:border-slate-800">
                    <td class="py-2">@room.Name</td>
                    <td class="py-2">@room.HomeroomTeacher</td>
                    <td class="py-2">@room.Capacity</td>
                    <td class="py-2 flex gap-2">
                        <button class="text-indigo-600" @onclick="() => EditClass(room)">Edit</button>
                        <button class="text-rose-600" @onclick="() => DeleteClass(room.Id)">Hapus</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (ShowForm)
{
    <div class="sms-card mt-6 max-w-xl">
        <h2 class="text-lg font-semibold mb-4">@FormTitle</h2>
        <EditForm Model="FormModel" OnValidSubmit="SaveClass">
            <DataAnnotationsValidator />
            <div class="grid gap-4">
                <InputText class="w-full rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Nama kelas" @bind-Value="FormModel.Name" />
                <InputText class="w-full rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Wali kelas" @bind-Value="FormModel.HomeroomTeacher" />
                <InputNumber class="w-full rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Kapasitas" @bind-Value="FormModel.Capacity" />
            </div>
            <div class="mt-4 flex gap-2">
                <button type="submit" class="px-4 py-2 rounded-lg bg-indigo-600 text-white">Simpan</button>
                <button type="button" class="px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-600" @onclick="Cancel">Cancel</button>
            </div>
        </EditForm>
    </div>
}

@code {
    private List<ClassRoom> ClassItems { get; set; } = new();
    private string SearchText { get; set; } = string.Empty;
    private ClassRoom FormModel { get; set; } = new();
    private string FormTitle => FormModel.Id == 0 ? "Tambah Kelas" : "Edit Kelas";
    private bool ShowForm { get; set; }

    private List<ClassRoom> FilteredClasses => ClassItems
        .Where(c => string.IsNullOrWhiteSpace(SearchText) || c.Name.Contains(SearchText, StringComparison.OrdinalIgnoreCase))
        .ToList();

    protected override Task OnInitializedAsync()
    {
        LoadClasses();
        return Task.CompletedTask;
    }

    private void LoadClasses()
    {
        ClassItems = Db.ClassRooms.AsNoTracking().ToList();
    }

    private void ShowAdd()
    {
        FormModel = new ClassRoom();
        ShowForm = true;
    }

    private void EditClass(ClassRoom room)
    {
        FormModel = new ClassRoom
        {
            Id = room.Id,
            Name = room.Name,
            HomeroomTeacher = room.HomeroomTeacher,
            Capacity = room.Capacity
        };
        ShowForm = true;
    }

    private async Task SaveClass()
    {
        if (FormModel.Id == 0)
        {
            Db.ClassRooms.Add(FormModel);
        }
        else
        {
            Db.ClassRooms.Update(FormModel);
        }
        await Db.SaveChangesAsync();
        Cancel();
        LoadClasses();
    }

    private async Task DeleteClass(int id)
    {
        var room = await Db.ClassRooms.FindAsync(id);
        if (room != null)
        {
            Db.ClassRooms.Remove(room);
            await Db.SaveChangesAsync();
            LoadClasses();
        }
    }

    private void Cancel()
    {
        FormModel = new ClassRoom();
        ShowForm = false;
    }

    private async Task ExportCsv()
    {
        var rows = new List<string> { "Id,Name,HomeroomTeacher,Capacity" };
        foreach (var room in FilteredClasses)
        {
            rows.Add($"{room.Id},\"{room.Name}\",\"{room.HomeroomTeacher}\",{room.Capacity}");
        }
        await JSRuntime.InvokeVoidAsync("smsnetDownload", "classes.csv", string.Join("\n", rows));
    }
}
