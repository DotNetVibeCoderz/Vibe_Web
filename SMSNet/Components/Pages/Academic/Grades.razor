@page "/academic/grades"
@attribute [Authorize]
@inject ApplicationDbContext Db

<h1 class="text-2xl font-semibold mb-6">Penilaian & Rapor Digital</h1>

<div class="grid gap-6 lg:grid-cols-2">
    <div class="sms-card space-y-4">
        <div class="flex items-center justify-between">
            <h2 class="text-lg font-semibold">Input Nilai</h2>
            <button class="px-3 py-2 rounded-lg bg-indigo-600 text-white text-sm" @onclick="ShowAdd">Tambah</button>
        </div>
        <table class="min-w-full text-sm">
            <thead class="text-left text-slate-500 border-b border-slate-200 dark:border-slate-700">
                <tr>
                    <th class="py-2">Siswa</th>
                    <th class="py-2">Mata Pelajaran</th>
                    <th class="py-2">Nilai</th>
                    <th class="py-2">Aksi</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var grade in GradeItems)
                {
                    <tr class="border-b border-slate-100 dark:border-slate-800">
                        <td class="py-2">@grade.StudentName</td>
                        <td class="py-2">@grade.Subject</td>
                        <td class="py-2">@grade.Score</td>
                        <td class="py-2 flex gap-2">
                            <button class="text-indigo-600" @onclick="() => EditGrade(grade)">Edit</button>
                            <button class="text-rose-600" @onclick="() => DeleteGrade(grade.Id)">Hapus</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (ShowForm)
        {
            <EditForm Model="FormModel" OnValidSubmit="SaveGrade">
                <DataAnnotationsValidator />
                <div class="grid gap-3">
                    <InputText class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Nama siswa" @bind-Value="FormModel.StudentName" />
                    <InputText class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Mata pelajaran" @bind-Value="FormModel.Subject" />
                    <InputNumber class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Nilai" @bind-Value="FormModel.Score" />
                    <InputText class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Catatan" @bind-Value="FormModel.Notes" />
                </div>
                <div class="mt-3 flex gap-2">
                    <button type="submit" class="px-4 py-2 rounded-lg bg-indigo-600 text-white">Simpan</button>
                    <button type="button" class="px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-600" @onclick="Cancel">Cancel</button>
                </div>
            </EditForm>
        }
    </div>
    <div class="sms-card">
        <h2 class="text-lg font-semibold mb-4">Analisis Hasil Belajar</h2>
        <ul class="space-y-3">
            <li class="flex items-center justify-between">
                <span>Rata-rata Nilai</span>
                <span class="sms-badge">@AverageScore.ToString("0.0")</span>
            </li>
            <li class="flex items-center justify-between">
                <span>Nilai Tertinggi</span>
                <span class="sms-badge">@MaxScore</span>
            </li>
            <li class="flex items-center justify-between">
                <span>Nilai Terendah</span>
                <span class="sms-badge">@MinScore</span>
            </li>
            <li class="flex items-center justify-between">
                <span>Status Rapor Online</span>
                <span class="sms-badge">Aktif</span>
            </li>
        </ul>
    </div>
</div>

@code {
    private List<GradeRecord> GradeItems { get; set; } = new();
    private GradeRecord FormModel { get; set; } = new();
    private decimal AverageScore { get; set; }
    private decimal MaxScore { get; set; }
    private decimal MinScore { get; set; }
    private bool ShowForm { get; set; }

    protected override Task OnInitializedAsync()
    {
        LoadGrades();
        return Task.CompletedTask;
    }

    private void LoadGrades()
    {
        GradeItems = Db.GradeRecords.AsNoTracking().ToList();
        if (Db.GradeRecords.Any())
        {
            AverageScore = Db.GradeRecords.Average(g => g.Score);
            MaxScore = Db.GradeRecords.Max(g => g.Score);
            MinScore = Db.GradeRecords.Min(g => g.Score);
        }
    }

    private void ShowAdd()
    {
        FormModel = new GradeRecord();
        ShowForm = true;
    }

    private void EditGrade(GradeRecord grade)
    {
        FormModel = new GradeRecord
        {
            Id = grade.Id,
            StudentName = grade.StudentName,
            Subject = grade.Subject,
            Score = grade.Score,
            Notes = grade.Notes
        };
        ShowForm = true;
    }

    private async Task SaveGrade()
    {
        if (FormModel.Id == 0)
        {
            Db.GradeRecords.Add(FormModel);
        }
        else
        {
            Db.GradeRecords.Update(FormModel);
        }
        await Db.SaveChangesAsync();
        Cancel();
        LoadGrades();
    }

    private async Task DeleteGrade(int id)
    {
        var grade = await Db.GradeRecords.FindAsync(id);
        if (grade != null)
        {
            Db.GradeRecords.Remove(grade);
            await Db.SaveChangesAsync();
            LoadGrades();
        }
    }

    private void Cancel()
    {
        FormModel = new GradeRecord();
        ShowForm = false;
    }
}
