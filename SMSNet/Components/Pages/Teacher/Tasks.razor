@page "/teacher/tasks"
@attribute [Authorize]
@inject ApplicationDbContext Db

<h1 class="text-2xl font-semibold mb-6">Manajemen Tugas & Ujian</h1>

<div class="sms-card space-y-4">
    <div class="flex items-center justify-between">
        <p class="text-sm text-slate-500">Upload soal, koreksi otomatis, dan feedback digital</p>
        <button class="px-3 py-2 rounded-lg bg-indigo-600 text-white text-sm" @onclick="ShowAdd">Buat Tugas</button>
    </div>

    <table class="min-w-full text-sm">
        <thead class="text-left text-slate-500 border-b border-slate-200 dark:border-slate-700">
            <tr>
                <th class="py-2">Judul</th>
                <th class="py-2">Jenis</th>
                <th class="py-2">Deadline</th>
                <th class="py-2">Status</th>
                <th class="py-2">Aksi</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var task in TaskItems)
            {
                <tr class="border-b border-slate-100 dark:border-slate-800">
                    <td class="py-2">@task.Title</td>
                    <td class="py-2">@task.Type</td>
                    <td class="py-2">@task.DueDate.ToString("dd MMM yyyy")</td>
                    <td class="py-2"><span class="sms-badge">@task.Status</span></td>
                    <td class="py-2 flex gap-2">
                        <button class="text-indigo-600" @onclick="() => EditTask(task)">Edit</button>
                        <button class="text-rose-600" @onclick="() => DeleteTask(task.Id)">Hapus</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (ShowForm)
    {
        <EditForm Model="FormModel" OnValidSubmit="SaveTask">
            <DataAnnotationsValidator />
            <div class="grid gap-3">
                <InputText class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Judul" @bind-Value="FormModel.Title" />
                <InputSelect class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" @bind-Value="FormModel.Type">
                    <option>Quiz</option>
                    <option>Ujian</option>
                    <option>Tugas</option>
                </InputSelect>
                <InputDate class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" @bind-Value="FormModel.DueDate" />
                <InputSelect class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" @bind-Value="FormModel.Status">
                    <option>Open</option>
                    <option>Scheduled</option>
                    <option>Closed</option>
                </InputSelect>
            </div>
            <div class="mt-3 flex gap-2">
                <button type="submit" class="px-4 py-2 rounded-lg bg-indigo-600 text-white">Simpan</button>
                <button type="button" class="px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-600" @onclick="Cancel">Cancel</button>
            </div>
        </EditForm>
    }
</div>

@code {
    private List<TaskExam> TaskItems { get; set; } = new();
    private TaskExam FormModel { get; set; } = new() { DueDate = DateTime.Today.AddDays(1) };
    private bool ShowForm { get; set; }

    protected override Task OnInitializedAsync()
    {
        LoadTasks();
        return Task.CompletedTask;
    }

    private void LoadTasks()
    {
        TaskItems = Db.TaskExams.AsNoTracking().ToList();
    }

    private void ShowAdd()
    {
        FormModel = new TaskExam { DueDate = DateTime.Today.AddDays(1) };
        ShowForm = true;
    }

    private void EditTask(TaskExam task)
    {
        FormModel = new TaskExam
        {
            Id = task.Id,
            Title = task.Title,
            Type = task.Type,
            DueDate = task.DueDate,
            Status = task.Status
        };
        ShowForm = true;
    }

    private async Task SaveTask()
    {
        if (FormModel.Id == 0)
        {
            Db.TaskExams.Add(FormModel);
        }
        else
        {
            Db.TaskExams.Update(FormModel);
        }
        await Db.SaveChangesAsync();
        Cancel();
        LoadTasks();
    }

    private async Task DeleteTask(int id)
    {
        var task = await Db.TaskExams.FindAsync(id);
        if (task != null)
        {
            Db.TaskExams.Remove(task);
            await Db.SaveChangesAsync();
            LoadTasks();
        }
    }

    private void Cancel()
    {
        FormModel = new TaskExam { DueDate = DateTime.Today.AddDays(1) };
        ShowForm = false;
    }
}
