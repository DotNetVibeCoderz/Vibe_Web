@page "/teacher/communication"
@attribute [Authorize]
@inject ApplicationDbContext Db

<h1 class="text-2xl font-semibold mb-6">Komunikasi Internal</h1>

<div class="sms-card space-y-4">
    <div class="flex items-center justify-between">
        <p class="text-sm text-slate-500">Forum diskusi, chat, dan pengumuman antar guru/staff</p>
        <button class="px-3 py-2 rounded-lg bg-indigo-600 text-white text-sm" @onclick="ShowAdd">Buat Topik</button>
    </div>

    <ul class="space-y-4">
        @foreach (var post in Posts)
        {
            <li class="border border-slate-200 dark:border-slate-700 rounded-xl p-4">
                <div class="flex items-start justify-between">
                    <div>
                        <p class="font-medium">@post.Topic</p>
                        <p class="text-xs text-slate-500">@post.Author • @post.PostedAt.ToString("dd MMM yyyy")</p>
                        <p class="text-sm mt-2">@post.Content</p>
                    </div>
                    <div class="flex gap-2 text-sm">
                        <button class="text-indigo-600" @onclick="() => EditPost(post)">Edit</button>
                        <button class="text-rose-600" @onclick="() => DeletePost(post.Id)">Hapus</button>
                    </div>
                </div>
            </li>
        }
    </ul>

    @if (ShowForm)
    {
        <EditForm Model="FormModel" OnValidSubmit="SavePost">
            <DataAnnotationsValidator />
            <div class="grid gap-3">
                <InputText class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Topik" @bind-Value="FormModel.Topic" />
                <InputText class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Author" @bind-Value="FormModel.Author" />
                <InputTextArea class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Konten" @bind-Value="FormModel.Content" />
            </div>
            <div class="mt-3 flex gap-2">
                <button type="submit" class="px-4 py-2 rounded-lg bg-indigo-600 text-white">Simpan</button>
                <button type="button" class="px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-600" @onclick="Cancel">Cancel</button>
            </div>
        </EditForm>
    }
</div>

@code {
    private List<ForumPost> Posts { get; set; } = new();
    private ForumPost FormModel { get; set; } = new() { PostedAt = DateTime.Today };
    private bool ShowForm { get; set; }

    protected override Task OnInitializedAsync()
    {
        LoadPosts();
        return Task.CompletedTask;
    }

    private void LoadPosts()
    {
        Posts = Db.ForumPosts.AsNoTracking().OrderByDescending(p => p.PostedAt).ToList();
    }

    private void ShowAdd()
    {
        FormModel = new ForumPost { PostedAt = DateTime.Today };
        ShowForm = true;
    }

    private void EditPost(ForumPost post)
    {
        FormModel = new ForumPost
        {
            Id = post.Id,
            Topic = post.Topic,
            Author = post.Author,
            Content = post.Content,
            PostedAt = post.PostedAt
        };
        ShowForm = true;
    }

    private async Task SavePost()
    {
        if (FormModel.Id == 0)
        {
            FormModel.PostedAt = DateTime.Today;
            Db.ForumPosts.Add(FormModel);
        }
        else
        {
            Db.ForumPosts.Update(FormModel);
        }
        await Db.SaveChangesAsync();
        Cancel();
        LoadPosts();
    }

    private async Task DeletePost(int id)
    {
        var post = await Db.ForumPosts.FindAsync(id);
        if (post != null)
        {
            Db.ForumPosts.Remove(post);
            await Db.SaveChangesAsync();
            LoadPosts();
        }
    }

    private void Cancel()
    {
        FormModel = new ForumPost { PostedAt = DateTime.Today };
        ShowForm = false;
    }
}
