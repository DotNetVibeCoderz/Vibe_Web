@page "/parent/documents"
@attribute [Authorize]
@inject ApplicationDbContext Db

<h1 class="text-2xl font-semibold mb-6">Sertifikat & Dokumen Digital</h1>

<div class="sms-card space-y-4">
    <div class="flex items-center justify-between">
        <p class="text-sm text-slate-500">Akses ijazah, rapor, dan surat resmi.</p>
        <button class="px-3 py-2 rounded-lg bg-indigo-600 text-white text-sm" @onclick="ShowAdd">Tambah Dokumen</button>
    </div>

    <table class="min-w-full text-sm">
        <thead class="text-left text-slate-500 border-b border-slate-200 dark:border-slate-700">
            <tr>
                <th class="py-2">Jenis Dokumen</th>
                <th class="py-2">Pemilik</th>
                <th class="py-2">File</th>
                <th class="py-2">Aksi</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var doc in DocumentItems)
            {
                <tr class="border-b border-slate-100 dark:border-slate-800">
                    <td class="py-2">@doc.DocumentType</td>
                    <td class="py-2">@doc.OwnerName</td>
                    <td class="py-2"><a class="text-indigo-600" href="@doc.FilePath">Download</a></td>
                    <td class="py-2 flex gap-2">
                        <button class="text-indigo-600" @onclick="() => EditDocument(doc)">Edit</button>
                        <button class="text-rose-600" @onclick="() => DeleteDocument(doc.Id)">Hapus</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (ShowForm)
    {
        <EditForm Model="FormModel" OnValidSubmit="SaveDocument">
            <DataAnnotationsValidator />
            <div class="grid gap-3">
                <InputText class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Jenis dokumen" @bind-Value="FormModel.DocumentType" />
                <InputText class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Nama pemilik" @bind-Value="FormModel.OwnerName" />
                <InputText class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Path file" @bind-Value="FormModel.FilePath" />
            </div>
            <div class="mt-3 flex gap-2">
                <button type="submit" class="px-4 py-2 rounded-lg bg-indigo-600 text-white">Simpan</button>
                <button type="button" class="px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-600" @onclick="Cancel">Cancel</button>
            </div>
        </EditForm>
    }
</div>

@code {
    private List<DocumentItem> DocumentItems { get; set; } = new();
    private DocumentItem FormModel { get; set; } = new();
    private bool ShowForm { get; set; }

    protected override Task OnInitializedAsync()
    {
        LoadDocuments();
        return Task.CompletedTask;
    }

    private void LoadDocuments()
    {
        DocumentItems = Db.Documents.AsNoTracking().ToList();
    }

    private void ShowAdd()
    {
        FormModel = new DocumentItem();
        ShowForm = true;
    }

    private void EditDocument(DocumentItem doc)
    {
        FormModel = new DocumentItem
        {
            Id = doc.Id,
            DocumentType = doc.DocumentType,
            OwnerName = doc.OwnerName,
            FilePath = doc.FilePath
        };
        ShowForm = true;
    }

    private async Task SaveDocument()
    {
        if (FormModel.Id == 0)
        {
            Db.Documents.Add(FormModel);
        }
        else
        {
            Db.Documents.Update(FormModel);
        }
        await Db.SaveChangesAsync();
        Cancel();
        LoadDocuments();
    }

    private async Task DeleteDocument(int id)
    {
        var doc = await Db.Documents.FindAsync(id);
        if (doc != null)
        {
            Db.Documents.Remove(doc);
            await Db.SaveChangesAsync();
            LoadDocuments();
        }
    }

    private void Cancel()
    {
        FormModel = new DocumentItem();
        ShowForm = false;
    }
}
