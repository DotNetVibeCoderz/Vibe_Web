@page "/events"
@attribute [Authorize]
@inject ApplicationDbContext Db

<h1 class="text-2xl font-semibold mb-6">Event & Extracurricular Management</h1>

<div class="sms-card space-y-4">
    <div class="flex items-center justify-between">
        <p class="text-sm text-slate-500">Manajemen kegiatan sekolah dan organisasi siswa.</p>
        <button class="px-3 py-2 rounded-lg bg-indigo-600 text-white text-sm" @onclick="ShowAdd">Tambah Event</button>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
        @foreach (var ev in EventItems)
        {
            <div class="border border-slate-200 dark:border-slate-700 rounded-xl p-4">
                <div class="flex items-start justify-between">
                    <div>
                        <p class="font-medium">@ev.Title</p>
                        <p class="text-xs text-slate-500">@ev.Date.ToString("dd MMM yyyy") • @ev.Location</p>
                        <span class="sms-badge mt-2">@ev.Type</span>
                    </div>
                    <div class="flex gap-2 text-sm">
                        <button class="text-indigo-600" @onclick="() => EditEvent(ev)">Edit</button>
                        <button class="text-rose-600" @onclick="() => DeleteEvent(ev.Id)">Hapus</button>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (ShowForm)
    {
        <EditForm Model="FormModel" OnValidSubmit="SaveEvent">
            <DataAnnotationsValidator />
            <div class="grid gap-3 md:grid-cols-2">
                <InputText class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Judul event" @bind-Value="FormModel.Title" />
                <InputDate class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" @bind-Value="FormModel.Date" />
                <InputText class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Lokasi" @bind-Value="FormModel.Location" />
                <InputText class="rounded-lg border border-slate-300 px-3 py-2 dark:bg-slate-800 dark:border-slate-600" placeholder="Jenis event" @bind-Value="FormModel.Type" />
            </div>
            <div class="mt-3 flex gap-2">
                <button type="submit" class="px-4 py-2 rounded-lg bg-indigo-600 text-white">Simpan</button>
                <button type="button" class="px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-600" @onclick="Cancel">Cancel</button>
            </div>
        </EditForm>
    }
</div>

@code {
    private List<EventItem> EventItems { get; set; } = new();
    private EventItem FormModel { get; set; } = new() { Date = DateTime.Today };
    private bool ShowForm { get; set; }

    protected override Task OnInitializedAsync()
    {
        LoadEvents();
        return Task.CompletedTask;
    }

    private void LoadEvents()
    {
        EventItems = Db.Events.AsNoTracking().OrderBy(e => e.Date).ToList();
    }

    private void ShowAdd()
    {
        FormModel = new EventItem { Date = DateTime.Today };
        ShowForm = true;
    }

    private void EditEvent(EventItem ev)
    {
        FormModel = new EventItem
        {
            Id = ev.Id,
            Title = ev.Title,
            Date = ev.Date,
            Location = ev.Location,
            Type = ev.Type
        };
        ShowForm = true;
    }

    private async Task SaveEvent()
    {
        if (FormModel.Id == 0)
        {
            Db.Events.Add(FormModel);
        }
        else
        {
            Db.Events.Update(FormModel);
        }
        await Db.SaveChangesAsync();
        Cancel();
        LoadEvents();
    }

    private async Task DeleteEvent(int id)
    {
        var ev = await Db.Events.FindAsync(id);
        if (ev != null)
        {
            Db.Events.Remove(ev);
            await Db.SaveChangesAsync();
            LoadEvents();
        }
    }

    private void Cancel()
    {
        FormModel = new EventItem { Date = DateTime.Today };
        ShowForm = false;
    }
}
