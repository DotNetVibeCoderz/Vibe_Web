@page "/auth/reset-password"
@attribute [AllowAnonymous]

<h1 class="text-2xl font-semibold mb-6">Reset Password</h1>

<div class="sms-card max-w-lg">
    <p class="text-slate-500 mb-4">Masukkan username untuk mengirimkan instruksi reset password.</p>
    <EditForm Model="Model" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <InputText class="mt-1 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 dark:bg-slate-800 dark:border-slate-600" @bind-Value="Model.UserName" />

        <button type="submit" class="mt-4 px-4 py-2 rounded-lg bg-indigo-600 text-white">Kirim Instruksi</button>
    </EditForm>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <p class="mt-4 text-emerald-500">@Message</p>
    }
</div>

@code {
    private ResetInput Model { get; set; } = new();
    private string? Message { get; set; }

    private void HandleSubmit()
    {
        Message = "Instruksi reset telah dikirim (demo).";
    }

    public class ResetInput
    {
        [Required]
        public string UserName { get; set; } = string.Empty;
    }
}
