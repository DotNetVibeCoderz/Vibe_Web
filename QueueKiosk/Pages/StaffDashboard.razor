@page "/staff"
@using Microsoft.AspNetCore.Components.Authorization
@using QueueKiosk.Models
@using QueueKiosk.Services
@using QueueKiosk.Data
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject QueueManagerService QueueService
@implements IDisposable

<AuthorizeView>
    <Authorized>
        <div class="neo-container">
            <div class="header-bar">
                <h1>STAFF DASHBOARD</h1>
                <div>
                    User: @context.User.Identity?.Name | Role: @context.User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value
                </div>
            </div>

            <div style="display:flex; gap:20px;">
                <div class="neo-box" style="flex:1;">
                    <h2>Counter Selection</h2>
                    <select class="neo-input" @bind="selectedCounterId">
                        <option value="0">-- Select Counter --</option>
                        @foreach(var counter in counters)
                        {
                            <option value="@counter.Id">@counter.Name</option>
                        }
                    </select>
                    
                    <button class="neo-button accent" style="width:100%; font-size:1.5em; padding:20px;" disabled="@(selectedCounterId == 0)" @onclick="CallNext">CALL NEXT</button>
                    
                    <hr style="border: 2px solid var(--border); margin:20px 0;"/>
                    
                    @if(currentServing != null)
                    {
                        <div style="text-align:center; background-color:var(--primary); padding:20px; border:4px solid var(--border);">
                            <h3 style="margin:0;">CURRENT SERVING</h3>
                            <h1 style="font-size:4em; margin:10px 0;">@currentServing.TicketNumber</h1>
                            <button class="neo-button" style="background-color:#00ff00;" @onclick="CompleteTicket">COMPLETE</button>
                            <button class="neo-button secondary" @onclick="SkipTicket">SKIP / ABSENT</button>
                        </div>
                    }
                </div>

                <div class="neo-box" style="flex:2;">
                    <h2>Waiting Queue</h2>
                    <table class="neo-table">
                        <thead>
                            <tr>
                                <th>Ticket No</th>
                                <th>Service</th>
                                <th>Priority</th>
                                <th>Waiting Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var q in waitingQueue)
                            {
                                <tr style="background-color:@(q.IsPriority ? "var(--secondary)" : "transparent")">
                                    <td style="font-weight:bold;">@q.TicketNumber</td>
                                    <td>@q.Service?.Name</td>
                                    <td>@(q.IsPriority ? "YES" : "NO")</td>
                                    <td>@(Math.Round((DateTime.Now - q.CreatedAt).TotalMinutes, 0)) min</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="neo-container">
            <h1>Access Denied</h1>
            <a href="/login">Please login first.</a>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<AppCounter> counters = new();
    private int selectedCounterId = 0;
    
    private List<AppQueueTicket> waitingQueue = new();
    private AppQueueTicket? currentServing;

    protected override async Task OnInitializedAsync()
    {
        counters = await Db.Counters.Where(c => c.IsActive).ToListAsync();
        QueueService.OnQueueUpdated += UpdateQueue;
        await LoadQueue();
    }

    private async void UpdateQueue()
    {
        await InvokeAsync(async () =>
        {
            await LoadQueue();
            StateHasChanged();
        });
    }

    private async Task LoadQueue()
    {
        waitingQueue = await QueueService.GetWaitingQueueAsync();
    }

    private async Task CallNext()
    {
        if(selectedCounterId > 0)
        {
            var counterInfo = counters.FirstOrDefault(c => c.Id == selectedCounterId);
            if(counterInfo != null)
            {
                currentServing = await QueueService.CallNextForCounterAsync(selectedCounterId, counterInfo.SupportedServiceIds);
                if (currentServing != null)
                {
                    // We show this to the staff who pressed Call Next
                }
            }
        }
    }

    private async Task CompleteTicket()
    {
        if(currentServing != null)
        {
            await QueueService.CompleteTicketAsync(currentServing.Id);
            currentServing = null;
        }
    }

    private async Task SkipTicket()
    {
        if(currentServing != null)
        {
            await QueueService.SkipTicketAsync(currentServing.Id);
            currentServing = null;
        }
    }

    public void Dispose()
    {
        QueueService.OnQueueUpdated -= UpdateQueue;
    }
}
