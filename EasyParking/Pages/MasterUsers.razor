@page "/master/users"
@using EasyParking.Models
@using EasyParking.Services
@using CsvHelper
@using System.Globalization
@using System.IO
@using Microsoft.JSInterop
@inject CrudService<User> UserService
@inject IJSRuntime JSRuntime

<h1 class="neo-heading">Manage Users</h1>

<div class="neo-card mb-4" style="background-color: var(--neo-blue); color:#000;">
    <div class="row">
        <div class="col-md-6">
            <input type="text" class="neo-input" placeholder="Search username, role, email..." @bind="searchQuery" @bind:event="oninput" />
        </div>
        <div class="col-md-6 text-right">
            <button class="neo-btn" @onclick="() => isAddMode = true">+ Add User</button>
            <button class="neo-btn neo-btn-tertiary ml-2" @onclick="ExportCsv">Export CSV</button>
        </div>
    </div>
</div>

@if (isAddMode)
{
    <div class="neo-card mb-4">
        <h3>@(currentUser.Id == 0 ? "Add New User" : "Edit User")</h3>
        <div class="row">
            <div class="col-md-3">
                <label>Username</label>
                <input class="neo-input" @bind="currentUser.Username" />
            </div>
            <div class="col-md-3">
                <label>Email</label>
                <input class="neo-input" @bind="currentUser.Email" />
            </div>
            <div class="col-md-3">
                <label>Password</label>
                <input type="password" class="neo-input" @bind="currentUser.Password" placeholder="Leave empty if not changing" />
            </div>
            <div class="col-md-3">
                <label>Role</label>
                <select class="neo-input" @bind="currentUser.Role">
                    <option value="admin">Admin</option>
                    <option value="operator">Operator</option>
                    <option value="pelanggan">Pelanggan</option>
                </select>
            </div>
        </div>
        <div class="mt-3">
            <button class="neo-btn" @onclick="SaveUser">Save</button>
            <button class="neo-btn neo-btn-danger" @onclick="CancelEdit">Cancel</button>
        </div>
    </div>
}

<div class="neo-table-container">
    <table class="neo-table">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Role</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in FilteredUsers)
            {
                <tr>
                    <td>@user.Username</td>
                    <td>@user.Email</td>
                    <td>@user.Role</td>
                    <td>
                        <button class="neo-btn neo-btn-secondary" style="padding: 5px 10px; font-size: 0.8em;" @onclick="() => EditUser(user)">Edit</button>
                        <button class="neo-btn neo-btn-danger" style="padding: 5px 10px; font-size: 0.8em;" @onclick="() => DeleteUser(user.Id)">Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private List<User> users = new();
    private string searchQuery = "";
    private bool isAddMode = false;
    private User currentUser = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        users = await UserService.GetAllAsync();
    }

    private IEnumerable<User> FilteredUsers => users.Where(u => 
        string.IsNullOrEmpty(searchQuery) ||
        u.Username.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
        u.Email.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
        u.Role.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)
    );

    private void EditUser(User user)
    {
        currentUser = new User 
        { 
            Id = user.Id, 
            Username = user.Username, 
            Email = user.Email, 
            Role = user.Role, 
            Password = user.Password
        };
        isAddMode = true;
    }

    private void CancelEdit()
    {
        currentUser = new User();
        isAddMode = false;
    }

    private async Task SaveUser()
    {
        if (currentUser.Id == 0)
        {
            await UserService.AddAsync(currentUser);
        }
        else
        {
            await UserService.UpdateAsync(currentUser);
        }
        await LoadUsers();
        CancelEdit();
    }

    private async Task DeleteUser(int id)
    {
        await UserService.DeleteAsync(id);
        await LoadUsers();
    }

    private async Task ExportCsv()
    {
        using var memoryStream = new MemoryStream();
        using var writer = new StreamWriter(memoryStream);
        using var csv = new CsvWriter(writer, CultureInfo.InvariantCulture);

        csv.WriteRecords(FilteredUsers);
        await writer.FlushAsync();
        
        var bytes = memoryStream.ToArray();
        var base64 = Convert.ToBase64String(bytes);

        await JSRuntime.InvokeVoidAsync("downloadFile", "Users.csv", "text/csv", base64);
    }
}
