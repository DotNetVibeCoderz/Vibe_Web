@page "/monitoring"
@implements IDisposable
@using EasyParking.Services
@using EasyParking.Models
@inject ParkingService ParkingService
@using System.Timers

<h1 class="neo-heading">Live Monitoring 📡</h1>
<p class="neo-text">Real-time slot availability mapped by Level.</p>

<div class="row mb-3">
    <div class="col-12">
        <div class="neo-card" style="display:flex; gap: 20px;">
            <div><span style="display:inline-block; width: 20px; height:20px; border:2px solid #000; background:var(--neo-green)"></span> Available</div>
            <div><span style="display:inline-block; width: 20px; height:20px; border:2px solid #000; background:var(--neo-red)"></span> Occupied</div>
            <div><span style="display:inline-block; width: 20px; height:20px; border:2px solid #000; background:var(--neo-yellow)"></span> Reserved</div>
            <div><span style="display:inline-block; width: 20px; height:20px; border:2px solid #000; background:var(--neo-pink)"></span> EV Station</div>
        </div>
    </div>
</div>

@foreach (var levelGroup in slots.GroupBy(s => s.Level))
{
    <h3 class="mt-4">@levelGroup.Key</h3>
    <div style="display: flex; flex-wrap: wrap; gap: 10px;">
        @foreach (var slot in levelGroup.OrderBy(s => s.Code))
        {
            string bgColor = "var(--neo-green)"; // default Available
            if (slot.IsOccupied) bgColor = "var(--neo-red)";
            else if (slot.IsReserved) bgColor = "var(--neo-yellow)";
            else if (slot.IsEV) bgColor = "var(--neo-pink)";

            <div style="width: 80px; height: 100px; border: 3px solid #000; box-shadow: 2px 2px 0px #000; background-color: @bgColor; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:5px; text-align:center;">
                <strong>@slot.Code</strong>
                <small style="font-size: 0.6em; margin-top:5px; font-weight:bold; color:#000;">
                    @(slot.Type)<br/>
                    @(slot.IsEV ? "🔌" : "")
                </small>
            </div>
        }
    </div>
}

@code {
    private List<ParkingSlot> slots = new();
    private Timer? timer;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        // Simulate real-time monitoring every 5 seconds
        timer = new Timer(5000);
        timer.Elapsed += async (sender, e) =>
        {
            await LoadData();
            await InvokeAsync(StateHasChanged);
        };
        timer.Start();
    }

    private async Task LoadData()
    {
        slots = await ParkingService.GetSlotsAsync();
    }

    public void Dispose()
    {
        timer?.Dispose();
    }
}
