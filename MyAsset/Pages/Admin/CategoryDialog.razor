@using MyAsset.Models
@using MudBlazor
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext

<MudDialog>
    <DialogContent>
        <MudForm Model="@Category" @ref="form">
            <MudTextField Label="Name" @bind-Value="Category.Name" Required="true" />
            <MudTextField Label="Description" @bind-Value="Category.Description" Lines="3" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public Category Category { get; set; } = new();

    MudForm form;

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        await form.Validate();
        if (form.IsValid)
        {
            if (Category.Id == 0) DbContext.Categories.Add(Category);
            else DbContext.Categories.Update(Category);
            
            await DbContext.SaveChangesAsync();
            MudDialog.Close(DialogResult.Ok(true));
        }
    }
}