@page
@model MyAsset.Pages.Account.LogoutModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Logged Out - MyAsset</title>
    <link rel="stylesheet" href="~/css/bootstrap/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f3f4f6;
            background-image: radial-gradient(#e5e7eb 1px, transparent 1px);
            background-size: 20px 20px;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logout-card {
            background: white;
            border-radius: 16px;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 400px;
            padding: 2.5rem;
            text-align: center;
            border: 1px solid rgba(229, 231, 235, 0.5);
        }

        .icon-circle {
            width: 72px;
            height: 72px;
            background-color: #ecfdf5;
            color: #10b981;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2rem;
        }

        .logout-title {
            font-weight: 700;
            color: #111827;
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }

        .logout-text {
            color: #6b7280;
            font-size: 0.95rem;
            margin-bottom: 2rem;
        }

        .btn-primary {
            background-color: #2563eb;
            border-color: #2563eb;
            padding: 0.75rem 1.5rem;
            font-weight: 600;
            border-radius: 8px;
            transition: all 0.2s;
            width: 100%;
        }

        .btn-primary:hover {
            background-color: #1d4ed8;
            border-color: #1d4ed8;
            transform: translateY(-1px);
            box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.3);
        }
    </style>
</head>
<body>

    <div class="logout-card">
        <div class="icon-circle">
            <i class="bi bi-check-lg"></i>
        </div>
        <h1 class="logout-title">You've been logged out</h1>
        <p class="logout-text">Thank you for using MyAsset. You can now close this window or sign in again.</p>
        
        <a href="/Account/Login" class="btn btn-primary">Sign In Again</a>
    </div>

</body>
</html>