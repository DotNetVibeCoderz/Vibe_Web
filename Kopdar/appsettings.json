{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SqliteConnection": "Data Source=kopdar.db",
    "SqlServerConnection": "Server=tcp:xxx.database.windows.net,1433;Initial Catalog=kopdardb;Persist Security Info=False;User ID=xxx;Password=xxx;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;",
    "MySqlConnection": "server=localhost;database=kopdardb;user=root;password=password"
  },
  "DatabaseProvider": "Sqlite",
  "StorageProvider": "FileSystem",
  "AzureBlob": {
    "ConnectionString": "DefaultEndpointsProtocol=https;AccountName=xxx;AccountKey=xxx;EndpointSuffix=core.windows.net",
    "ContainerName": "kopdar-uploads"
  },
  "AwsS3": {
    "BucketName": "kopdar-s3-bucket",
    "Region": "us-east-1"
  }
}
