{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=kopdar.db"
  },
  "StorageProvider": "FileSystem", 
  "AzureBlob": {
    "ConnectionString": "DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net",
    "ContainerName": "kopdar-uploads"
  },
  "AwsS3": {
    "BucketName": "kopdar-s3-bucket",
    "Region": "us-east-1"
  }
}
