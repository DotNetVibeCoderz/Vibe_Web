@page "/auth"
@inject Kopdar.Services.AppService AppService

<div style="max-width: 400px; margin: 0 auto; margin-top: 50px; text-align: center;">
    
    <!-- Logo Kopdar -->
    <img src="/images/logo.svg" width="100" height="100" style="border: 4px solid #111; border-radius: 50%; background: #ffe66d; margin-bottom: 20px;" />
    
    <div class="brutal-card" style="text-align: left;">
        <h2 style="text-align: center; margin-top: 0;">Welcome to Kopdar!</h2>
        
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div style="background: var(--primary); color: #fff; padding: 10px; border: 2px solid #111; margin-bottom: 15px; font-weight: bold; text-align: center;">
                @errorMessage
            </div>
        }
        else if (!string.IsNullOrEmpty(successMessage))
        {
            <div style="background: var(--secondary); color: #111; padding: 10px; border: 2px solid #111; margin-bottom: 15px; font-weight: bold; text-align: center;">
                @successMessage
            </div>
        }

        @if (isLogin)
        {
            <input @bind="username" class="brutal-input" placeholder="Username (e.g., kangfadhil)" />
            <input @bind="password" type="password" class="brutal-input" placeholder="Password (e.g., admin)" />
            <button class="brutal-btn" style="width: 100%" @onclick="Login">Login</button>
            <p style="text-align: center; margin-top: 20px; cursor: pointer; text-decoration: underline;" @onclick="Toggle">Don't have an account? Register</p>
        }
        else
        {
            <input @bind="username" class="brutal-input" placeholder="Choose Username" />
            <input @bind="email" class="brutal-input" placeholder="Email Address" />
            <input @bind="password" type="password" class="brutal-input" placeholder="Password" />
            <button class="brutal-btn secondary" style="width: 100%" @onclick="Register">Register</button>
            <p style="text-align: center; margin-top: 20px; cursor: pointer; text-decoration: underline;" @onclick="Toggle">Already have an account? Login</p>
        }
    </div>

    <!-- Copyright & Social Medias -->
    <div style="margin-top: 30px; font-weight: bold;">
        <p>&copy; 2023 Kopdar App. Built with 🔥 by Gravicode Studios.</p>
        <div style="display: flex; gap: 15px; justify-content: center; margin-top: 10px;">
            <a href="#" style="color: #111; text-decoration: none; border: 2px solid #111; padding: 5px 10px; background: var(--secondary);">🐦 Twitter</a>
            <a href="#" style="color: #111; text-decoration: none; border: 2px solid #111; padding: 5px 10px; background: var(--accent);">📘 Facebook</a>
            <a href="#" style="color: #111; text-decoration: none; border: 2px solid #111; padding: 5px 10px; background: var(--primary); color: white;">📸 Instagram</a>
        </div>
    </div>
</div>

@code {
    private bool isLogin = true;
    private string username = "";
    private string email = "";
    private string password = "";
    
    private string errorMessage = "";
    private string successMessage = "";

    private void Toggle() 
    {
        isLogin = !isLogin;
        errorMessage = "";
        successMessage = "";
    }

    private async Task Login()
    {
        errorMessage = "";
        successMessage = "";
        
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Username and password cannot be empty!";
            return;
        }

        await AppService.LoginAsync(username, password);
        
        if (AppService.CurrentUser == null)
        {
            errorMessage = "Invalid username or password! Please try again.";
        }
    }

    private async Task Register()
    {
        errorMessage = "";
        successMessage = "";

        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Username and password cannot be empty!";
            return;
        }

        bool success = await AppService.RegisterAsync(username, email, password);
        if (success)
        {
            isLogin = true;
            successMessage = "Registration successful! Please login to your account.";
            password = ""; 
        }
        else
        {
            errorMessage = "Username is already taken! Please choose another one.";
        }
    }
}