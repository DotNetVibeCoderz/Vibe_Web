@page "/profile/{UserId:int}"
@inject Kopdar.Services.AppService AppService
@inject Kopdar.Services.IStorageService StorageService
@using Kopdar.Models
@using Kopdar.Helpers

<PageTitle>Profile - Kopdar</PageTitle>

@if (user == null)
{
    <p>Loading profile...</p>
}
else
{
    <div class="brutal-card" style="text-align: center; background: var(--secondary);">
        
        <div style="position: relative; display: inline-block;">
            <img src="@user.ProfilePictureUrl" width="120" height="120" style="border: 4px solid #111; border-radius: 50%; background: #fff; object-fit: cover;" />
            
            @if (user.Id == AppService.CurrentUser?.Id)
            {
                <label style="position: absolute; bottom: 0; right: 0; background: var(--accent); border: 2px solid #111; padding: 5px; cursor: pointer; border-radius: 50%;">
                    📷
                    <InputFile OnChange="HandleProfilePicUpload" style="display: none;" />
                </label>
            }
        </div>
        
        @if (isEditing)
        {
            <div style="margin-top: 15px; max-width: 300px; margin-left: auto; margin-right: auto; text-align: left;">
                <label><b>Bio</b></label>
                <textarea @bind="editBio" class="brutal-input" rows="2"></textarea>
                
                <label><b>Gender</b></label>
                <select @bind="editGender" class="brutal-input">
                    <option value="">Select...</option>
                    <option value="Male">Male</option>
                    <option value="Female">Female</option>
                </select>
                
                <div style="display: flex; gap: 10px;">
                    <button class="brutal-btn primary" style="flex: 1;" @onclick="SaveProfile">Save</button>
                    <button class="brutal-btn" style="flex: 1;" @onclick="() => isEditing = false">Cancel</button>
                </div>
            </div>
        }
        else
        {
            <h1 style="margin: 10px 0;">@user.Username</h1>
            <p style="font-size: 1.2rem; font-style: italic;">"@user.Bio"</p>
            <p><strong>@(string.IsNullOrEmpty(user.Gender) ? "Unspecified" : user.Gender)</strong> | Location: @user.Latitude.ToString("0.00"), @user.Longitude.ToString("0.00")</p>

            @if (user.Id != AppService.CurrentUser?.Id)
            {
                <div style="margin-top: 20px; display: flex; gap: 10px; justify-content: center;">
                    <button class="brutal-btn accent" @onclick="ToggleFollow">
                        @(isFollowing ? "Unfollow" : "Follow")
                    </button>
                    <a href="/chat/@user.Id" class="brutal-btn primary">Message</a>
                </div>
            }
            else
            {
                <div style="margin-top: 20px; display: flex; gap: 10px; justify-content: center;">
                    <button class="brutal-btn accent" @onclick="EnableEdit">Edit Profile</button>
                    <button class="brutal-btn primary" @onclick="() => isCreatingGroup = true">Create Group</button>
                </div>
            }
        }
    </div>

    <!-- Create Group Modal/Section -->
    @if (isCreatingGroup)
    {
        <div class="brutal-card" style="background: #fff; border: 4px solid var(--primary);">
            <h3>Create a New Group</h3>
            <input @bind="newGroupName" class="brutal-input" placeholder="Group Name" />
            <textarea @bind="newGroupDesc" class="brutal-input" rows="2" placeholder="Description"></textarea>
            
            <h4>Add Members (Followers)</h4>
            <div style="max-height: 150px; overflow-y: auto; border: 2px solid #111; padding: 10px; margin-bottom: 15px;">
                @if (followersList == null || !followersList.Any())
                {
                    <p style="font-style: italic;">No followers to add. Tell people to follow you first!</p>
                }
                else
                {
                    @foreach(var f in followersList)
                    {
                        <label style="display: block; margin-bottom: 5px; cursor: pointer;">
                            <input type="checkbox" checked="@selectedMembers.Contains(f.Id)" @onchange="@(e => ToggleMemberSelection(f.Id, e.Value))" /> 
                            @f.Username
                        </label>
                    }
                }
            </div>

            <div style="display: flex; gap: 10px;">
                <button class="brutal-btn primary" @onclick="SaveNewGroup">Create</button>
                <button class="brutal-btn secondary" @onclick="() => isCreatingGroup = false">Cancel</button>
            </div>
        </div>
    }

    <!-- Follow Stats -->
    <div style="display: flex; gap: 20px; text-align: center; margin-bottom: 30px;">
        <div class="brutal-card" style="flex: 1; cursor: pointer; background: @(viewingStats == "followers" ? "var(--accent)" : "#fff")" @onclick='() => ToggleStatsView("followers")'>
            <h2>@followersList?.Count</h2>
            <p>Followers</p>
        </div>
        <div class="brutal-card" style="flex: 1; cursor: pointer; background: @(viewingStats == "following" ? "var(--accent)" : "#fff")" @onclick='() => ToggleStatsView("following")'>
            <h2>@followingList?.Count</h2>
            <p>Following</p>
        </div>
        <div class="brutal-card" style="flex: 1; cursor: pointer; background: @(viewingStats == "groups" ? "var(--accent)" : "#fff")" @onclick='() => ToggleStatsView("groups")'>
            <h2>@createdGroups?.Count</h2>
            <p>My Groups</p>
        </div>
    </div>

    @if (viewingStats == "followers")
    {
        <div class="brutal-card">
            <h3>Followers List</h3>
            @if(followersList != null && followersList.Any()) {
                <ul style="list-style: none; padding: 0;">
                    @foreach(var f in followersList) {
                        <li style="margin-bottom: 10px; display: flex; align-items: center; gap: 10px;">
                            <img src="@f.ProfilePictureUrl" width="30" height="30" style="border: 2px solid #111; border-radius: 50%; object-fit: cover;" />
                            <a href="/profile/@f.Id" style="color: inherit;"><strong>@f.Username</strong></a>
                        </li>
                    }
                </ul>
            } else { <p>No followers.</p> }
        </div>
    }
    else if (viewingStats == "following")
    {
        <div class="brutal-card">
            <h3>Following List</h3>
            @if(followingList != null && followingList.Any()) {
                <ul style="list-style: none; padding: 0;">
                    @foreach(var f in followingList) {
                        <li style="margin-bottom: 10px; display: flex; align-items: center; gap: 10px;">
                            <img src="@f.ProfilePictureUrl" width="30" height="30" style="border: 2px solid #111; border-radius: 50%; object-fit: cover;" />
                            <a href="/profile/@f.Id" style="color: inherit;"><strong>@f.Username</strong></a>
                        </li>
                    }
                </ul>
            } else { <p>Not following anyone.</p> }
        </div>
    }
    else if (viewingStats == "groups")
    {
        <div class="brutal-card">
            <h3>Groups Created by @user.Username</h3>
            @if(createdGroups != null && createdGroups.Any()) {
                <ul style="list-style: none; padding: 0;">
                    @foreach(var g in createdGroups) {
                        <li style="margin-bottom: 10px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px dashed #111; padding-bottom: 5px;">
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <img src="@g.GroupPictureUrl" width="30" height="30" style="border: 2px solid #111;" />
                                <div>
                                    <a href="/group/@g.Id" style="color: inherit; text-decoration: none; font-weight: bold;">@g.Name</a><br/>
                                    <small>@g.Description</small>
                                </div>
                            </div>
                            <a href="/chat/group/@g.Id" class="brutal-btn" style="padding: 5px 10px; font-size: 0.8rem;">Chat</a>
                        </li>
                    }
                </ul>
            } else { <p>No groups created yet.</p> }
        </div>
    }

    <h3>Recent Activity</h3>
    @if (userPosts != null && userPosts.Any())
    {
        @foreach (var post in userPosts)
        {
            <div class="brutal-card" style="border-left: 10px solid var(--primary);">
                <small>@TimeHelper.ToFriendlyTime(post.CreatedAt)</small>
                <p>@post.Content</p>
                @if (!string.IsNullOrEmpty(post.MediaUrl))
                {
                    <div style="margin-bottom: 10px;">
                        <a href="@post.MediaUrl" target="_blank" class="brutal-btn secondary" style="font-size: 0.8rem; padding: 5px;">View Attachment</a>
                    </div>
                }
                <span style="font-size: 0.8rem; font-weight: bold;">❤️ @post.Likes?.Count Likes | 💬 @post.Comments?.Count Comments</span>
            </div>
        }
    }
    else
    {
        <p>No posts yet.</p>
    }
}

@code {
    [Parameter] public int UserId { get; set; }
    private AppUser user;
    private List<Post> userPosts;
    private bool isFollowing;
    
    private List<AppUser> followersList = new();
    private List<AppUser> followingList = new();
    private List<ChatGroup> createdGroups = new();

    // Edit states
    private bool isEditing = false;
    private string editBio;
    private string editGender;

    // View stats state
    private string viewingStats = "";

    // Group states
    private bool isCreatingGroup = false;
    private string newGroupName = "";
    private string newGroupDesc = "";
    private HashSet<int> selectedMembers = new();

    protected override async Task OnParametersSetAsync()
    {
        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        var allUsers = await AppService.GetAllActiveUsersAsync();
        user = allUsers.FirstOrDefault(u => u.Id == UserId);
        
        if (user != null)
        {
            var allPosts = await AppService.GetTimelineAsync(0, 500);
            userPosts = allPosts.Where(p => p.UserId == UserId).ToList();
            
            followersList = await AppService.GetFollowersAsync(UserId);
            followingList = await AppService.GetFollowingAsync(UserId);
            createdGroups = await AppService.GetUserCreatedGroupsAsync(UserId);

            if (AppService.CurrentUser != null)
            {
                isFollowing = followersList.Any(f => f.Id == AppService.CurrentUser.Id);
            }
        }
    }

    private void EnableEdit()
    {
        editBio = user.Bio;
        editGender = user.Gender;
        isEditing = true;
    }

    private async Task SaveProfile()
    {
        await AppService.UpdateProfileAsync(UserId, editBio, editGender);
        isEditing = false;
        await LoadProfileAsync();
    }

    private async Task HandleProfilePicUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        using var stream = file.OpenReadStream(10 * 1024 * 1024); // 10MB max
        var url = await StorageService.UploadFileAsync(file.Name, stream);
        await AppService.UpdateProfilePictureAsync(UserId, url);
        await LoadProfileAsync();
    }

    private async Task ToggleFollow()
    {
        if (AppService.CurrentUser == null) return;
        await AppService.ToggleFollowAsync(UserId);
        await LoadProfileAsync(); // refresh UI and states automatically
    }

    private void ToggleStatsView(string stat)
    {
        if (viewingStats == stat) viewingStats = "";
        else viewingStats = stat;
    }

    private void ToggleMemberSelection(int memberId, object isChecked)
    {
        if ((bool)isChecked)
            selectedMembers.Add(memberId);
        else
            selectedMembers.Remove(memberId);
    }

    private async Task SaveNewGroup()
    {
        if (!string.IsNullOrWhiteSpace(newGroupName))
        {
            await AppService.CreateGroupAsync(newGroupName, newGroupDesc, selectedMembers.ToList());
            isCreatingGroup = false;
            newGroupName = "";
            newGroupDesc = "";
            selectedMembers.Clear();
            await LoadProfileAsync(); // refresh group lists
        }
    }
}