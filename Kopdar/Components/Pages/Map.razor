@page "/map"
@inject Kopdar.Services.AppService AppService
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@using Kopdar.Models

<PageTitle>Social Map - Kopdar</PageTitle>

<div class="map-header">
    <div class="title-section">
        <h2>Social Map</h2>
        <p>Interactive map showing users and groups nearby.</p>
    </div>
    <div class="stats-section">
        <div class="brutal-card stat-item" style="background: var(--accent);">
            <h3 style="margin: 0;">@allUsers?.Count</h3>
            <small>Active Users</small>
        </div>
        <div class="brutal-card stat-item" style="background: var(--primary); color: white;">
            <h3 style="margin: 0;">@allGroups?.Count</h3>
            <small>Public Groups</small>
        </div>
    </div>
</div>

<div class="brutal-card" style="padding: 0; overflow: hidden; border: 4px solid #111; margin-bottom: 20px;">
    <div id="map" style="height: 400px; width: 100%; z-index: 1;"></div>
</div>

<div class="directory-container">
    <div class="directory-item brutal-card">
        <h3>User Directory</h3>
        <div class="table-wrapper">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: var(--secondary); border-bottom: 3px solid #111;">
                        <th style="padding: 10px; text-align: left;">User</th>
                        <th style="padding: 10px; text-align: left;">Bio</th>
                        <th style="padding: 10px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (allUsers != null)
                    {
                        foreach (var u in allUsers)
                        {
                            <tr style="border-bottom: 1px solid #ccc;">
                                <td style="padding: 10px;">
                                    <div style="display: flex; align-items: center; gap: 10px;">
                                        <img src="@u.ProfilePictureUrl" width="30" height="30" style="border: 2px solid #111;" />
                                        <strong>@u.Username</strong>
                                    </div>
                                </td>
                                <td style="padding: 10px;"><small>@u.Bio</small></td>
                                <td style="padding: 10px; text-align: center;">
                                    <a href="/profile/@u.Id" class="brutal-btn" style="padding: 5px 10px; font-size: 0.8rem;">Profile</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="directory-item brutal-card">
        <h3>Public Groups</h3>
        <div class="table-wrapper">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: var(--primary); color: white; border-bottom: 3px solid #111;">
                        <th style="padding: 10px; text-align: left;">Group Name</th>
                        <th style="padding: 10px; text-align: left;">Description</th>
                        <th style="padding: 10px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (allGroups != null)
                    {
                        foreach (var g in allGroups)
                        {
                            <tr style="border-bottom: 1px solid #ccc;">
                                <td style="padding: 10px;">
                                    <div style="display: flex; align-items: center; gap: 10px;">
                                        <img src="@g.GroupPictureUrl" width="30" height="30" style="border: 2px solid #111;" />
                                        <strong>@g.Name</strong>
                                    </div>
                                </td>
                                <td style="padding: 10px;"><small>@g.Description</small></td>
                                <td style="padding: 10px; text-align: center;">
                                    <div style="display: flex; gap: 5px; justify-content: center;">
                                        <a href="/group/@g.Id" class="brutal-btn" style="padding: 5px 10px; font-size: 0.8rem; background: var(--accent);">Info</a>
                                        <button class="brutal-btn secondary" style="padding: 5px 10px; font-size: 0.8rem;" @onclick="() => JoinAndChat(g.Id)">Join</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .map-header {
        display: flex;
        gap: 20px;
        align-items: center;
        margin-bottom: 20px;
    }

    .title-section {
        flex: 1;
    }

    .stats-section {
        display: flex;
        gap: 10px;
    }

    .stat-item {
        margin: 0;
        padding: 10px 20px;
        text-align: center;
        min-width: 100px;
    }

    .directory-container {
        display: flex;
        gap: 20px;
        margin-bottom: 20px;
    }

    .directory-item {
        flex: 1;
        margin: 0;
    }

    .table-wrapper {
        max-height: 300px;
        overflow-y: auto;
        overflow-x: auto;
    }

    /* Responsive Styles */
    @@media (max-width: 992px) {
        .directory-container {
            flex-direction: column;
        }
    }

    @@media (max-width: 768px) {
        .map-header {
            flex-direction: column;
            align-items: stretch;
            text-align: center;
        }

        .stats-section {
            justify-content: center;
        }

        .stat-item {
            flex: 1;
        }
        
        #map {
            height: 300px;
        }
    }

    @@media (max-width: 480px) {
        .stats-section {
            flex-direction: column;
        }
        
        .brutal-btn {
            display: block;
            width: 100%;
            margin-bottom: 5px;
        }
    }
</style>

@code {
    private List<AppUser> allUsers;
    private List<ChatGroup> allGroups;

    protected override async Task OnInitializedAsync()
    {
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && AppService.CurrentUser != null)
        {
            allUsers = await AppService.GetAllActiveUsersAsync();
            allGroups = await AppService.GetAllPublicGroupsAsync();

            var lat = AppService.CurrentUser.Latitude;
            var lon = AppService.CurrentUser.Longitude;

            var userPayload = allUsers.Select(u => new { u.Id, u.Username, u.Bio, u.Latitude, u.Longitude }).ToList();
            var groupPayload = allGroups.Select(g => new { g.Id, g.Name, g.Description, g.Latitude, g.Longitude }).ToList();

            await JSRuntime.InvokeVoidAsync("initMap", "map", lat, lon, userPayload, groupPayload);
            StateHasChanged();
        }
    }

    private async Task JoinAndChat(int groupId)
    {
        await AppService.JoinGroupAsync(groupId);
        NavManager.NavigateTo($"/chat/group/{groupId}");
    }
}
