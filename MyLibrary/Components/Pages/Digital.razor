@page "/digital"
@inject ApplicationDbContext DbContext

<h1>Digital Resource Management</h1>

<div class="card glass">
    <p>Integrasi e-book, database penelitian, dan konten digital.</p>
    <div class="table-toolbar">
        <input class="input" placeholder="Free text search" @bind="tableState.SearchText" @bind:event="oninput" />
        <select class="input" @bind="tableState.PageSize">
            <option value="5">5</option>
            <option value="10">10</option>
        </select>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th class="sortable" @onclick="() => SortBy(nameof(Book.Title))">Judul @SortIndicator(nameof(Book.Title))</th>
                <th class="sortable" @onclick="() => SortBy(nameof(Book.Author))">Penulis @SortIndicator(nameof(Book.Author))</th>
                <th class="sortable" @onclick="() => SortBy(nameof(Book.DigitalUrl))">URL @SortIndicator(nameof(Book.DigitalUrl))</th>
                <th class="sortable" @onclick="() => SortBy(nameof(Book.MetadataStandard))">Metadata @SortIndicator(nameof(Book.MetadataStandard))</th>
                <th>Aksi</th>
            </tr>
            <tr class="filter-row">
                <th><input class="input" placeholder="Filter judul" @bind="tableState.ColumnFilters[nameof(Book.Title)]" @bind:event="oninput" /></th>
                <th><input class="input" placeholder="Filter penulis" @bind="tableState.ColumnFilters[nameof(Book.Author)]" @bind:event="oninput" /></th>
                <th><input class="input" placeholder="Filter URL" @bind="tableState.ColumnFilters[nameof(Book.DigitalUrl)]" @bind:event="oninput" /></th>
                <th><input class="input" placeholder="Filter metadata" @bind="tableState.ColumnFilters[nameof(Book.MetadataStandard)]" @bind:event="oninput" /></th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in PagedBooks)
            {
                <tr>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(book.DigitalUrl))
                        {
                            <a href="@book.DigitalUrl" target="_blank">Open</a>
                        }
                    </td>
                    <td>@book.MetadataStandard</td>
                    <td>
                        <button class="btn" @onclick="() => OpenModal(book)">Edit</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="table-pagination">
        <button class="btn" @onclick="PrevPage" disabled="@(tableState.PageIndex == 1)">Prev</button>
        <span>Page @tableState.PageIndex / @TotalPages</span>
        <button class="btn" @onclick="NextPage" disabled="@(tableState.PageIndex == TotalPages)">Next</button>
    </div>
</div>

<Modal IsOpen="isModalOpen" Title="@modalTitle" OnClose="CloseModal">
    <EditForm Model="editBook" OnValidSubmit="SaveBook" FormName="digitalForm">
        <DataAnnotationsValidator />
        <div class="form-grid">
            <InputText class="input" @bind-Value="editBook.Title" placeholder="Judul" />
            <InputText class="input" @bind-Value="editBook.Author" placeholder="Penulis" />
            <InputText class="input" @bind-Value="editBook.DigitalUrl" placeholder="Digital URL" />
            <InputText class="input" @bind-Value="editBook.MetadataStandard" placeholder="Metadata" />
            <label style="display:flex; gap:8px; align-items:center;">
                <InputCheckbox @bind-Value="editBook.IsDigital" />
                Digital
            </label>
        </div>
        <div class="table-toolbar">
            <button class="btn primary" type="submit">Simpan</button>
            <button class="btn" type="button" @onclick="CloseModal">Batal</button>
        </div>
    </EditForm>
</Modal>

@code {
    private readonly TableState<Book> tableState = new() { SortColumn = nameof(Book.Title), PageSize = 10 };
    private readonly Dictionary<string, Func<Book, string?>> columnSelectors = new();

    private List<Book> digitalBooks = new();
    private Book editBook = new();
    private bool isModalOpen;
    private string modalTitle = "Edit Digital";

    protected override async Task OnInitializedAsync()
    {
        columnSelectors[nameof(Book.Title)] = b => b.Title;
        columnSelectors[nameof(Book.Author)] = b => b.Author;
        columnSelectors[nameof(Book.DigitalUrl)] = b => b.DigitalUrl;
        columnSelectors[nameof(Book.MetadataStandard)] = b => b.MetadataStandard;

        tableState.ColumnFilters[nameof(Book.Title)] = string.Empty;
        tableState.ColumnFilters[nameof(Book.Author)] = string.Empty;
        tableState.ColumnFilters[nameof(Book.DigitalUrl)] = string.Empty;
        tableState.ColumnFilters[nameof(Book.MetadataStandard)] = string.Empty;

        await LoadBooks();
    }

    private IEnumerable<Book> FilteredBooks => tableState.Apply(digitalBooks, columnSelectors);
    private IEnumerable<Book> PagedBooks
    {
        get
        {
            tableState.EnsureValidPage(TotalPages);
            return tableState.ApplyPaging(FilteredBooks);
        }
    }

    private int TotalPages => tableState.TotalPages(FilteredBooks);

    private async Task LoadBooks()
    {
        digitalBooks = await DbContext.Books.Where(b => b.IsDigital).ToListAsync();
    }

    private void SortBy(string column)
    {
        if (tableState.SortColumn == column)
        {
            tableState.SortAscending = !tableState.SortAscending;
        }
        else
        {
            tableState.SortColumn = column;
            tableState.SortAscending = true;
        }
        tableState.PageIndex = 1;
    }

    private string SortIndicator(string column)
    {
        if (tableState.SortColumn != column)
        {
            return string.Empty;
        }
        return tableState.SortAscending ? "▲" : "▼";
    }

    private void OpenModal(Book book)
    {
        modalTitle = "Edit Digital";
        editBook = new Book
        {
            Id = book.Id,
            Title = book.Title,
            Author = book.Author,
            DigitalUrl = book.DigitalUrl,
            MetadataStandard = book.MetadataStandard,
            IsDigital = book.IsDigital,
            Category = book.Category,
            ISBN = book.ISBN,
            Type = book.Type,
            Barcode = book.Barcode
        };
        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
    }

    private async Task SaveBook()
    {
        DbContext.Books.Update(editBook);
        await DbContext.SaveChangesAsync();
        await LoadBooks();
        CloseModal();
    }

    private void PrevPage()
    {
        if (tableState.PageIndex > 1) tableState.PageIndex--;
    }

    private void NextPage()
    {
        if (tableState.PageIndex < TotalPages) tableState.PageIndex++;
    }
}
