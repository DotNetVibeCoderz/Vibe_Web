@page "/acquisition"
@attribute [Authorize(Roles = "admin,petugas")]
@inject ApplicationDbContext DbContext

<h1>Acquisition & Procurement</h1>

<div class="card glass">
    <div class="table-toolbar">
        <input class="input" placeholder="Free text search" @bind="tableState.SearchText" @bind:event="oninput" />
        <select class="input" @bind="tableState.PageSize">
            <option value="5">5</option>
            <option value="10">10</option>
            <option value="20">20</option>
        </select>
        <button class="btn primary" @onclick="() => OpenModal(null)">Tambah Pengadaan</button>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th class="sortable" @onclick="() => SortBy(nameof(Acquisition.Supplier))">Supplier @SortIndicator(nameof(Acquisition.Supplier))</th>
                <th class="sortable" @onclick="() => SortBy(nameof(Acquisition.Title))">Judul @SortIndicator(nameof(Acquisition.Title))</th>
                <th class="sortable" @onclick="() => SortBy(nameof(Acquisition.Quantity))">Qty @SortIndicator(nameof(Acquisition.Quantity))</th>
                <th class="sortable" @onclick="() => SortBy(nameof(Acquisition.Cost))">Biaya @SortIndicator(nameof(Acquisition.Cost))</th>
                <th class="sortable" @onclick="() => SortBy(nameof(Acquisition.Status))">Status @SortIndicator(nameof(Acquisition.Status))</th>
                <th>Aksi</th>
            </tr>
            <tr class="filter-row">
                <th><input class="input" placeholder="Filter supplier" @bind="tableState.ColumnFilters[nameof(Acquisition.Supplier)]" @bind:event="oninput" /></th>
                <th><input class="input" placeholder="Filter judul" @bind="tableState.ColumnFilters[nameof(Acquisition.Title)]" @bind:event="oninput" /></th>
                <th><input class="input" placeholder="Filter qty" @bind="tableState.ColumnFilters[nameof(Acquisition.Quantity)]" @bind:event="oninput" /></th>
                <th><input class="input" placeholder="Filter biaya" @bind="tableState.ColumnFilters[nameof(Acquisition.Cost)]" @bind:event="oninput" /></th>
                <th><input class="input" placeholder="Filter status" @bind="tableState.ColumnFilters[nameof(Acquisition.Status)]" @bind:event="oninput" /></th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in PagedAcquisitions)
            {
                <tr>
                    <td>@item.Supplier</td>
                    <td>@item.Title</td>
                    <td>@item.Quantity</td>
                    <td>@item.Cost.ToString("C0")</td>
                    <td>@item.Status</td>
                    <td>
                        <button class="btn" @onclick="() => OpenModal(item)">Edit</button>
                        <button class="btn danger" @onclick="() => DeleteItem(item)">Hapus</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="table-pagination">
        <button class="btn" @onclick="PrevPage" disabled="@(tableState.PageIndex == 1)">Prev</button>
        <span>Page @tableState.PageIndex / @TotalPages</span>
        <button class="btn" @onclick="NextPage" disabled="@(tableState.PageIndex == TotalPages)">Next</button>
    </div>
</div>

<Modal IsOpen="isModalOpen" Title="@modalTitle" OnClose="CloseModal">
    <EditForm Model="editItem" OnValidSubmit="SaveItem" FormName="acquisitionForm">
        <DataAnnotationsValidator />
        <div class="form-grid">
            <InputText class="input" @bind-Value="editItem.Supplier" placeholder="Supplier" />
            <InputText class="input" @bind-Value="editItem.Title" placeholder="Judul" />
            <InputNumber class="input" @bind-Value="editItem.Quantity" />
            <InputNumber class="input" @bind-Value="editItem.Cost" />
            <InputText class="input" @bind-Value="editItem.Status" placeholder="Status" />
            <InputDate class="input" @bind-Value="editItem.OrderedAt" />
        </div>
        <div class="table-toolbar">
            <button class="btn primary" type="submit">Simpan</button>
            <button class="btn" type="button" @onclick="CloseModal">Batal</button>
        </div>
    </EditForm>
</Modal>

@code {
    private readonly TableState<Acquisition> tableState = new() { SortColumn = nameof(Acquisition.OrderedAt), PageSize = 10 };
    private readonly Dictionary<string, Func<Acquisition, string?>> columnSelectors = new();

    private List<Acquisition> acquisitions = new();
    private Acquisition editItem = new();
    private bool isModalOpen;
    private string modalTitle = "Tambah Pengadaan";

    protected override async Task OnInitializedAsync()
    {
        columnSelectors[nameof(Acquisition.Supplier)] = a => a.Supplier;
        columnSelectors[nameof(Acquisition.Title)] = a => a.Title;
        columnSelectors[nameof(Acquisition.Quantity)] = a => a.Quantity.ToString();
        columnSelectors[nameof(Acquisition.Cost)] = a => a.Cost.ToString("F0");
        columnSelectors[nameof(Acquisition.Status)] = a => a.Status;
        columnSelectors[nameof(Acquisition.OrderedAt)] = a => a.OrderedAt.ToString("d");

        tableState.ColumnFilters[nameof(Acquisition.Supplier)] = string.Empty;
        tableState.ColumnFilters[nameof(Acquisition.Title)] = string.Empty;
        tableState.ColumnFilters[nameof(Acquisition.Quantity)] = string.Empty;
        tableState.ColumnFilters[nameof(Acquisition.Cost)] = string.Empty;
        tableState.ColumnFilters[nameof(Acquisition.Status)] = string.Empty;

        await LoadAcquisitions();
    }

    private IEnumerable<Acquisition> FilteredAcquisitions => tableState.Apply(acquisitions, columnSelectors);
    private IEnumerable<Acquisition> PagedAcquisitions
    {
        get
        {
            tableState.EnsureValidPage(TotalPages);
            return tableState.ApplyPaging(FilteredAcquisitions);
        }
    }

    private int TotalPages => tableState.TotalPages(FilteredAcquisitions);

    private async Task LoadAcquisitions()
    {
        acquisitions = await DbContext.Acquisitions.OrderByDescending(a => a.OrderedAt).ToListAsync();
    }

    private void SortBy(string column)
    {
        if (tableState.SortColumn == column)
        {
            tableState.SortAscending = !tableState.SortAscending;
        }
        else
        {
            tableState.SortColumn = column;
            tableState.SortAscending = true;
        }
        tableState.PageIndex = 1;
    }

    private string SortIndicator(string column)
    {
        if (tableState.SortColumn != column)
        {
            return string.Empty;
        }
        return tableState.SortAscending ? "▲" : "▼";
    }

    private void OpenModal(Acquisition? item)
    {
        if (item == null)
        {
            modalTitle = "Tambah Pengadaan";
            editItem = new Acquisition { OrderedAt = DateTime.UtcNow };
        }
        else
        {
            modalTitle = "Edit Pengadaan";
            editItem = new Acquisition
            {
                Id = item.Id,
                Supplier = item.Supplier,
                Title = item.Title,
                Quantity = item.Quantity,
                Cost = item.Cost,
                Status = item.Status,
                OrderedAt = item.OrderedAt
            };
        }

        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
    }

    private async Task SaveItem()
    {
        if (editItem.Id == 0)
        {
            DbContext.Acquisitions.Add(editItem);
        }
        else
        {
            DbContext.Acquisitions.Update(editItem);
        }

        DbContext.AuditLogs.Add(new AuditLog
        {
            Actor = "system",
            Action = $"Saved acquisition {editItem.Title}",
            Module = "Acquisition"
        });

        await DbContext.SaveChangesAsync();
        await LoadAcquisitions();
        CloseModal();
    }

    private async Task DeleteItem(Acquisition item)
    {
        DbContext.Acquisitions.Remove(item);
        DbContext.AuditLogs.Add(new AuditLog
        {
            Actor = "system",
            Action = $"Deleted acquisition {item.Title}",
            Module = "Acquisition"
        });
        await DbContext.SaveChangesAsync();
        await LoadAcquisitions();
    }

    private void PrevPage()
    {
        if (tableState.PageIndex > 1)
        {
            tableState.PageIndex--;
        }
    }

    private void NextPage()
    {
        if (tableState.PageIndex < TotalPages)
        {
            tableState.PageIndex++;
        }
    }
}
