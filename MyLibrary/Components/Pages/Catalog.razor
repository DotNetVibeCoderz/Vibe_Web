@page "/catalog"
@attribute [Authorize(Roles = "admin,petugas")]
@inject ApplicationDbContext DbContext

<h1>Cataloging</h1>

<div class="card glass">
    <div class="table-toolbar">
        <input class="input" placeholder="Free text search" @bind="tableState.SearchText" @bind:event="oninput" />
        <select class="input" @bind="tableState.PageSize">
            <option value="5">5</option>
            <option value="10">10</option>
            <option value="20">20</option>
        </select>
        <button class="btn primary" @onclick="() => OpenModal(null)">Tambah Buku</button>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th class="sortable" @onclick="() => SortBy(nameof(Book.Title))">Judul @SortIndicator(nameof(Book.Title))</th>
                <th class="sortable" @onclick="() => SortBy(nameof(Book.Author))">Penulis @SortIndicator(nameof(Book.Author))</th>
                <th class="sortable" @onclick="() => SortBy(nameof(Book.ISBN))">ISBN @SortIndicator(nameof(Book.ISBN))</th>
                <th class="sortable" @onclick="() => SortBy(nameof(Book.Category))">Kategori @SortIndicator(nameof(Book.Category))</th>
                <th class="sortable" @onclick="() => SortBy(nameof(Book.Type))">Tipe @SortIndicator(nameof(Book.Type))</th>
                <th>Aksi</th>
            </tr>
            <tr class="filter-row">
                <th><input class="input" placeholder="Filter judul" @bind="tableState.ColumnFilters[nameof(Book.Title)]" @bind:event="oninput" /></th>
                <th><input class="input" placeholder="Filter penulis" @bind="tableState.ColumnFilters[nameof(Book.Author)]" @bind:event="oninput" /></th>
                <th><input class="input" placeholder="Filter ISBN" @bind="tableState.ColumnFilters[nameof(Book.ISBN)]" @bind:event="oninput" /></th>
                <th><input class="input" placeholder="Filter kategori" @bind="tableState.ColumnFilters[nameof(Book.Category)]" @bind:event="oninput" /></th>
                <th><input class="input" placeholder="Filter tipe" @bind="tableState.ColumnFilters[nameof(Book.Type)]" @bind:event="oninput" /></th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var book in PagedBooks)
            {
                <tr>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td>@book.ISBN</td>
                    <td>@book.Category</td>
                    <td>@book.Type</td>
                    <td>
                        <button class="btn" @onclick="() => OpenModal(book)">Edit</button>
                        <button class="btn danger" @onclick="() => DeleteBook(book)">Hapus</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="table-pagination">
        <button class="btn" @onclick="PrevPage" disabled="@(tableState.PageIndex == 1)">Prev</button>
        <span>Page @tableState.PageIndex / @TotalPages</span>
        <button class="btn" @onclick="NextPage" disabled="@(tableState.PageIndex == TotalPages)">Next</button>
    </div>
</div>

<Modal IsOpen="isModalOpen" Title="@modalTitle" OnClose="CloseModal">
    <EditForm Model="editBook" OnValidSubmit="SaveBook" FormName="bookForm">
        <DataAnnotationsValidator />
        <div class="form-grid">
            <InputText class="input" @bind-Value="editBook.Title" placeholder="Judul" />
            <InputText class="input" @bind-Value="editBook.Author" placeholder="Penulis" />
            <InputText class="input" @bind-Value="editBook.ISBN" placeholder="ISBN" />
            <InputText class="input" @bind-Value="editBook.Category" placeholder="Kategori" />
            <InputText class="input" @bind-Value="editBook.Type" placeholder="Tipe" />
            <InputText class="input" @bind-Value="editBook.MetadataStandard" placeholder="Standar Metadata" />
            <InputText class="input" @bind-Value="editBook.Barcode" placeholder="Barcode" />
            <InputText class="input" @bind-Value="editBook.DigitalUrl" placeholder="Digital URL" />
            <label style="display:flex; gap:8px; align-items:center;">
                <InputCheckbox @bind-Value="editBook.IsDigital" />
                Digital
            </label>
        </div>
        <div class="table-toolbar">
            <button class="btn primary" type="submit">Simpan</button>
            <button class="btn" type="button" @onclick="CloseModal">Batal</button>
        </div>
    </EditForm>
</Modal>

@code {
    private readonly TableState<Book> tableState = new() { SortColumn = nameof(Book.Title), PageSize = 10 };
    private readonly Dictionary<string, Func<Book, string?>> columnSelectors = new();

    private List<Book> books = new();
    private Book editBook = new();
    private bool isModalOpen;
    private string modalTitle = "Tambah Buku";

    protected override async Task OnInitializedAsync()
    {
        columnSelectors[nameof(Book.Title)] = b => b.Title;
        columnSelectors[nameof(Book.Author)] = b => b.Author;
        columnSelectors[nameof(Book.ISBN)] = b => b.ISBN;
        columnSelectors[nameof(Book.Category)] = b => b.Category;
        columnSelectors[nameof(Book.Type)] = b => b.Type;

        tableState.ColumnFilters[nameof(Book.Title)] = string.Empty;
        tableState.ColumnFilters[nameof(Book.Author)] = string.Empty;
        tableState.ColumnFilters[nameof(Book.ISBN)] = string.Empty;
        tableState.ColumnFilters[nameof(Book.Category)] = string.Empty;
        tableState.ColumnFilters[nameof(Book.Type)] = string.Empty;

        await LoadBooks();
    }

    private IEnumerable<Book> FilteredBooks => tableState.Apply(books, columnSelectors);
    private IEnumerable<Book> PagedBooks
    {
        get
        {
            tableState.EnsureValidPage(TotalPages);
            return tableState.ApplyPaging(FilteredBooks);
        }
    }

    private int TotalPages => tableState.TotalPages(FilteredBooks);

    private async Task LoadBooks()
    {
        books = await DbContext.Books.OrderBy(b => b.Title).ToListAsync();
    }

    private void SortBy(string column)
    {
        if (tableState.SortColumn == column)
        {
            tableState.SortAscending = !tableState.SortAscending;
        }
        else
        {
            tableState.SortColumn = column;
            tableState.SortAscending = true;
        }
        tableState.PageIndex = 1;
    }

    private string SortIndicator(string column)
    {
        if (tableState.SortColumn != column)
        {
            return string.Empty;
        }
        return tableState.SortAscending ? "▲" : "▼";
    }

    private void OpenModal(Book? book)
    {
        if (book == null)
        {
            modalTitle = "Tambah Buku";
            editBook = new Book();
        }
        else
        {
            modalTitle = "Edit Buku";
            editBook = new Book
            {
                Id = book.Id,
                Title = book.Title,
                Author = book.Author,
                ISBN = book.ISBN,
                Category = book.Category,
                Type = book.Type,
                MetadataStandard = book.MetadataStandard,
                Barcode = book.Barcode,
                IsDigital = book.IsDigital,
                DigitalUrl = book.DigitalUrl
            };
        }

        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
    }

    private async Task SaveBook()
    {
        if (editBook.Id == 0)
        {
            DbContext.Books.Add(editBook);
        }
        else
        {
            DbContext.Books.Update(editBook);
        }

        DbContext.AuditLogs.Add(new AuditLog
        {
            Actor = "system",
            Action = $"Saved book {editBook.Title}",
            Module = "Catalog"
        });

        await DbContext.SaveChangesAsync();
        await LoadBooks();
        CloseModal();
    }

    private async Task DeleteBook(Book book)
    {
        DbContext.Books.Remove(book);
        DbContext.AuditLogs.Add(new AuditLog
        {
            Actor = "system",
            Action = $"Deleted book {book.Title}",
            Module = "Catalog"
        });
        await DbContext.SaveChangesAsync();
        await LoadBooks();
    }

    private void PrevPage()
    {
        if (tableState.PageIndex > 1)
        {
            tableState.PageIndex--;
        }
    }

    private void NextPage()
    {
        if (tableState.PageIndex < TotalPages)
        {
            tableState.PageIndex++;
        }
    }
}
