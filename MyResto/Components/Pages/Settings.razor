@page "/settings"
@using MudBlazor
@inject ISnackbar Snackbar

<PageTitle>System Settings</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">System Settings</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4">
            <MudForm @ref="form" Model="@SettingsModel">
                <MudText Typo="Typo.h6" Class="mb-4">General Configuration</MudText>
                
                <MudTextField Label="Restaurant Name" @bind-Value="SettingsModel.RestaurantName" Required="true" />
                <MudTextField Label="Tax Rate (%)" @bind-Value="SettingsModel.TaxRate" InputType="InputType.Number" Required="true" />
                
                <MudSelect T="string" Label="File Storage Provider" @bind-Value="SettingsModel.StorageProvider">
                    <MudSelectItem Value="@("FileSystem")">Local FileSystem</MudSelectItem>
                    <MudSelectItem Value="@("AzureBlob")">Azure Blob Storage</MudSelectItem>
                    <MudSelectItem Value="@("AWSS3")">AWS S3</MudSelectItem>
                </MudSelect>

                <MudSwitch T="bool" @bind-Value="SettingsModel.EnableDarkTheme" Label="Default Dark Theme" Color="Color.Primary" Class="mt-4" />

                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-6" OnClick="SaveSettings">Save Settings</MudButton>
            </MudForm>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private MudForm form = null!;
    private AppSettings SettingsModel = new AppSettings();

    private class AppSettings
    {
        public string RestaurantName { get; set; } = "MyResto RMS";
        public decimal TaxRate { get; set; } = 11.0m;
        public string StorageProvider { get; set; } = "FileSystem";
        public bool EnableDarkTheme { get; set; } = false;
    }

    private async Task SaveSettings()
    {
        await form.Validate();
        if (form.IsValid)
        {
            // Mock saving logic
            Snackbar.Add("Settings saved successfully!", Severity.Success);
        }
    }
}