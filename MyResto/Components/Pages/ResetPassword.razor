@page "/reset-password"
@layout Layout.EmptyLayout
@using MudBlazor
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Reset Password - MyResto</PageTitle>

<MudPaper Class="pa-8 w-100" Elevation="3">
    <MudText Typo="Typo.h5" Align="Align.Center" Class="mb-6">Reset Password</MudText>
    <MudText Typo="Typo.body2" Class="mb-6 text-center">Enter your email address and we'll send you a link to reset your password.</MudText>
    
    <MudForm @ref="form">
        <MudTextField T="string" Label="Email Address" @bind-Value="Email" InputType="InputType.Email" Required="true" RequiredError="Email is required!" Class="mb-6" />
        
        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large" OnClick="SendResetLinkAsync">Send Reset Link</MudButton>
        
        <div class="d-flex justify-center mt-4">
            <MudLink Href="/login" Typo="Typo.body2">Back to Login</MudLink>
        </div>
    </MudForm>
</MudPaper>

@code {
    private MudForm form = null!;
    private string Email = "";

    private async Task SendResetLinkAsync()
    {
        await form.Validate();
        if (form.IsValid)
        {
            // Simulate sending email
            Snackbar.Add("Reset link has been sent to your email.", Severity.Success);
            await Task.Delay(2000);
            NavigationManager.NavigateTo("/login");
        }
    }
}