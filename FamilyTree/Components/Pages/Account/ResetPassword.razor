@page "/account/reset"
@attribute [AllowAnonymous]
@layout FamilyTree.Components.Layout.AuthLayout
@inject UserManager<ApplicationUser> UserManager

<div class="card" style="max-width:480px; margin:auto;">
    <h3>Reset Password</h3>
    <div class="form-grid">
        <label>Email</label>
        <input type="email" @bind="_email" />

        <label>New Password</label>
        <input type="password" @bind="_newPassword" />

        <button class="btn" @onclick="ResetAsync">Reset</button>
        <p>@_message</p>
        <div class="reset-links">
            <a href="/account/login">Back to login</a>
        </div>
    </div>
</div>

@code {
    private string _email = string.Empty;
    private string _newPassword = string.Empty;
    private string _message = string.Empty;

    private async Task ResetAsync()
    {
        _message = string.Empty;
        var user = await UserManager.FindByEmailAsync(_email);
        if (user == null)
        {
            _message = "User tidak ditemukan.";
            return;
        }

        var token = await UserManager.GeneratePasswordResetTokenAsync(user);
        var result = await UserManager.ResetPasswordAsync(user, token, _newPassword);
        _message = result.Succeeded ? "Password berhasil direset." : string.Join("; ", result.Errors.Select(e => e.Description));
    }
}
