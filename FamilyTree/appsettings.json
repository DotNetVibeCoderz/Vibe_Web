{
  "Database": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "Sqlite": "Data Source=familytree.db",
    "SqlServer": "Server=localhost;Database=FamilyTree;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Storage": {
    "Provider": "FileSystem",
    "UploadRoot": "wwwroot/uploads",
    "AzureBlob": {
      "ConnectionString": "",
      "ContainerName": "familytree"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
